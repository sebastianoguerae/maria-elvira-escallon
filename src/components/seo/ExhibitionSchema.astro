---
import SchemaOrg from './SchemaOrg.astro';

interface Props {
  title: string;
  venue: string;
  city: string;
  country: string;
  startDate: string;
  endDate?: string;
  description: string;
  url?: string;
}

const { title, venue, city, country, startDate, endDate, description, url } = Astro.props;

const schema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "ExhibitionEvent",
  "name": title,
  "description": description,
  "startDate": startDate,
  "location": {
    "@type": "Place",
    "name": venue,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": city,
      "addressCountry": country
    }
  },
  "organizer": {
    "@type": "Person",
    "name": "María Elvira Escallón",
    "url": "https://mariaelviraescallon.com"
  }
};

if (endDate) {
  schema["endDate"] = endDate;
}

if (url) {
  schema["url"] = url;
}
---
<SchemaOrg schema={schema} />

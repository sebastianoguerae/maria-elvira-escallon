---
import Layout from '../components/layout/Layout.astro';

const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
---

<Layout lang="es" title="Página no encontrada" showDust={false}>

  <article class="notfound-page">
    <div class="container">

      <p class="notfound-page__code">404</p>

      <h1>Página no encontrada</h1>
      <p class="notfound-page__sub">Page not found</p>

      <p class="notfound-page__text">
        La página que busca no existe o fue trasladada.<br>
        The page you are looking for does not exist or has been moved.
      </p>

      <nav class="notfound-page__links" aria-label="Idiomas / Languages">
        <a href={`${base}/es/`}>Inicio (Español) →</a>
        <a href={`${base}/en/`}>Home (English) →</a>
      </nav>

    </div>
  </article>

</Layout>

<style>
  .notfound-page {
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s5);
    min-height: 60vh;
  }

  .notfound-page__code {
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
    margin-bottom: var(--s3);
  }

  .notfound-page h1 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 4rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: var(--s1) 0;
    color: var(--ink);
  }

  .notfound-page__sub {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--ash);
    margin-bottom: var(--s3);
  }

  .notfound-page__text {
    font-family: var(--mono);
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--ink-soft);
    margin-bottom: var(--s4);
  }

  .notfound-page__links {
    display: flex;
    flex-direction: column;
    gap: var(--s1);
  }

  .notfound-page__links a {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--moss);
    border-bottom: 1px solid var(--paper-dark);
    align-self: flex-start;
    transition: color 0.2s;
  }

  .notfound-page__links a:hover {
    color: var(--ink);
  }
</style>

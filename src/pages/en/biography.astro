---
import Layout from '../../components/layout/Layout.astro';

const lang = 'en' as const;
const title = 'Biography';

const retrato = (await import('../../assets/images/retrato/retrato.jpg')).default;
const libroEnEstadoDeComa = (await import('../../assets/images/libros/en-estado-de-coma-libro.jpg')).default;
---

<Layout
  lang={lang}
  title="Biography — Maria Elvira Escallon"
  description="Biography of Maria Elvira Escallon. Colombian visual artist. Born in London, 1954. Sculpture, installation, photography."
>

  <article class="bio-page">
    <div class="container">

      <!-- ===== 1. OPENING ===== -->
      <header class="bio-page__header">
        <p class="label">Biography</p>
        <h1>Maria Elvira<br>Escallon</h1>
      </header>

      <div class="bio-page__opening">
        <div class="bio-page__portrait">
          <img src={retrato.src} alt="Portrait of Maria Elvira Escallon" loading="eager">
        </div>
        <div class="bio-page__intro">
          <p class="curatorial" style="font-style: italic; font-size: 1.3rem;">
            Maria Elvira Escallon does not illustrate violence. She points. She does not criticize — she reveals.
          </p>

          <p class="curatorial" style="margin-top: var(--s3);">
            Born in London in 1954 and initially trained as a psychologist, Escallon has spent more than four decades building a body of work situated at the frontier between history and memory. Her practice articulates sculptural processes, photography and in-situ work to reveal a present threatened by historical failures, establishing thresholds that connect times and fragments of stories through elements of material culture.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Her interventions — sometimes subtle and imperceptible, sometimes monumental — take place in abandoned hospitals, ruined train stations, native trees, or buildings marked by violence. Deterioration is not her subject: it is her material. Dust, melting ice, bark reclaiming a baroque carving — each work makes time visible as a sculptural phenomenon.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            She belongs to a generation of Colombian artists who work with the memory of conflict without being literal — alongside figures like Doris Salcedo, Oscar Munoz, and Clemencia Echeverri — but her voice is distinct: quieter, more documentary, closer to the archive than to the gesture.
          </p>
        </div>
      </div>

      <hr class="rule">

      <!-- ===== 2. AWARDS AND RECOGNITION ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Awards and Recognition</h2>
          <span class="label">1993–2024</span>
        </div>

        <div class="bio-entry bio-entry--highlight">
          <span class="bio-entry__year">2024</span>
          <div class="bio-entry__info">
            <strong>Premio Nacional de Fotografia (National Photography Prize)</strong>
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2019</span>
          <div class="bio-entry__info">
            Honorable Mention — Individual Creation Grant, Ministry of Culture
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2018</span>
          <div class="bio-entry__info">
            Nomination X Premio Luis Caballero — IDARTES (<em>En el fertil suelo</em>)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2014</span>
          <div class="bio-entry__info">
            National Individual Creation Grant — MinCultura (<em>Aerolito</em>)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2006</span>
          <div class="bio-entry__info">
            First Prize, Heritage Category — IDCT (<em>En estado de coma</em>)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2005</span>
          <div class="bio-entry__info">
            National Individual Creation Grant — MinCultura (<em>En estado de coma</em>)
          </div>
        </div>

        <div class="bio-entry bio-entry--highlight">
          <span class="bio-entry__year">2003</span>
          <div class="bio-entry__info">
            <strong>First Prize — III Premio Luis Caballero (<em>Nuevas Floras</em>)</strong>
          </div>
        </div>

        <div class="bio-entry bio-entry--highlight">
          <span class="bio-entry__year">1997</span>
          <div class="bio-entry__info">
            <strong>First Prize — VIII Regional Salon, Central Zone (<em>In Vitro</em>)</strong>
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">1993</span>
          <div class="bio-entry__info">
            First Individual Creation Grant — Colcultura (<em>Turismo en la frontera</em>)
          </div>
        </div>
      </section>

      <hr class="rule--light">

      <!-- ===== 3. SELECTED SOLO EXHIBITIONS ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Selected Solo Exhibitions</h2>
          <span class="label">2000–2024</span>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2024</span>
          <div class="bio-entry__info">
            <em>Encuentros en la fabrica de polvo</em> — MAMU, Banco de la Republica (80 works)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2019</span>
          <div class="bio-entry__info">
            <em>En el fertil suelo</em> — MAMBO
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2017</span>
          <div class="bio-entry__info">
            <em>Nuevas Floras Versalles</em> — Tuileries Garden/FIAC, Arboretum de Chevreloup, France
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2014</span>
          <div class="bio-entry__info">
            <em>Pequeno Museo del Aerolito</em> — Museo Nacional de Colombia
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2012</span>
          <div class="bio-entry__info">
            <em>Urgencias</em> — Museo de Arte Universidad Nacional
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2007</span>
          <div class="bio-entry__info">
            <em>En estado de coma</em> — Museo de Bogota / Planetario Distrital
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2003</span>
          <div class="bio-entry__info">
            <em>Nuevas Floras</em> — Galeria Santa Fe (III Premio Luis Caballero)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2000</span>
          <div class="bio-entry__info">
            <em>El reino de este mundo</em> — MAMBO
          </div>
        </div>
      </section>

      <hr class="rule--light">

      <!-- ===== 4. INTERNATIONAL GROUP EXHIBITIONS ===== -->
      <section class="section">
        <div class="section__header">
          <h2>International Group Exhibitions</h2>
          <span class="label">2000–2019</span>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2019</span>
          <div class="bio-entry__info">
            <em>Urban Impulses: Latin American Photography</em> — The Photographers' Gallery, London
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2018</span>
          <div class="bio-entry__info">
            <em>Hibridos</em> — Deutsche Bank Gallery, New York
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2017</span>
          <div class="bio-entry__info">
            <em>La vuelta</em> — Les Rencontres de la Photographie, Arles, France
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2013</span>
          <div class="bio-entry__info">
            <em>Palimpsestes</em> — Galerie Mor-Charpentier, Paris / <em>In Motion</em> — Galeria Bianconi, Milan
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2011</span>
          <div class="bio-entry__info">
            VIII Mercosur Biennial
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2009</span>
          <div class="bio-entry__info">
            X Havana Biennial
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2008</span>
          <div class="bio-entry__info">
            <em>Focus on Contemporary</em> — Sydney / <em>Colombian Contemporary Photography</em> — FotoFest, Houston
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2007</span>
          <div class="bio-entry__info">
            <em>Displaced: Contemporary Art from Colombia</em> — Glynn Vivian Gallery, Wales
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2000</span>
          <div class="bio-entry__info">
            VII Havana Biennial — <em>Escenas de Caza</em>
          </div>
        </div>
      </section>

      <hr class="rule">

      <!-- ===== 5. PUBLICATIONS ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Publications</h2>
          <span class="label">Monographs</span>
        </div>

        <div class="bio-publications">

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover bio-pub-card__cover--placeholder">
              <span>Coleccion Seguros Bolivar</span>
            </div>
            <div class="bio-pub-card__info">
              <h3>Coleccion Seguros Bolivar de Arte Contemporaneo</h3>
              <div class="ficha">
                2018<br>
                Dir. Jose Roca<br>
                Monograph, 112 pp.
              </div>
            </div>
          </article>

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover bio-pub-card__cover--placeholder">
              <span>Polvo Eres</span>
            </div>
            <div class="bio-pub-card__info">
              <h3>Polvo Eres: El correr del tiempo</h3>
              <div class="ficha">
                2014<br>
                Julia Buenaventura<br>
                MinCultura, 212 pp.
              </div>
            </div>
          </article>

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover">
              <img src={libroEnEstadoDeComa.src} alt="Cover — En estado de coma" loading="lazy">
            </div>
            <div class="bio-pub-card__info">
              <h3>En estado de coma</h3>
              <div class="ficha">
                2007<br>
                IDPC / Johns Hopkins
              </div>
            </div>
          </article>

        </div>
      </section>

      <hr class="rule">

      <!-- ===== 6. COLLECTIONS + REPRESENTATION ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Collections and Representation</h2>
        </div>

        <div class="bio-two-col">
          <div class="bio-two-col__left">
            <h4>COLLECTIONS</h4>
            <ul class="ficha">
              <li>Art Gallery of NSW, Sydney</li>
              <li>Banco de la Republica, Bogota</li>
              <li>MAMBO — Museo de Arte Moderno de Bogota</li>
              <li>Museo Nacional de Colombia</li>
              <li>ESCALA, University of Essex, United Kingdom</li>
              <li>Coleccion Seguros Bolivar</li>
              <li>Fundacion Alzate Avendano</li>
              <li>FNAC, France</li>
              <li>Fundacion Cisneros Fontanals (CIFO)</li>
              <li>LPS Latin American Photography Collection</li>
              <li>Art Gallery of South West Sydney</li>
            </ul>
          </div>

          <div class="bio-two-col__right">
            <h4>REPRESENTATION</h4>
            <div class="ficha" style="margin-bottom: var(--s3);">
              Galeria Espacio Continuo
            </div>

            <h4>TEACHING</h4>
            <div class="ficha">
              Universidad Javeriana (2007–present)<br>
              MA History and Theory of Art — Universidad Nacional
            </div>
          </div>
        </div>
      </section>

    </div>
  </article>

</Layout>

<style>
  /* ===== Page base ===== */
  .bio-page {
    padding-top: calc(var(--s5) + 40px);
  }

  .bio-page__header {
    margin-bottom: var(--s4);
  }

  .bio-page__header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.4rem, 6vw, 5rem);
    line-height: 1;
    margin: var(--s1) 0;
  }

  /* ===== Opening: portrait + text grid ===== */
  .bio-page__opening {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--s4);
    margin-bottom: var(--s4);
    align-items: start;
  }

  .bio-page__portrait img {
    width: 100%;
    display: block;
    filter: grayscale(15%);
  }

  .bio-page__intro .curatorial {
    font-size: 1.15rem;
    line-height: 1.8;
  }

  /* ===== Bio entries (year + info) ===== */
  .bio-entry {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--s3);
    padding: var(--s2) 0;
    border-bottom: 1px solid var(--paper-dark);
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .bio-entry__year {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ash-light);
    padding-top: 0.15rem;
    letter-spacing: 0.05em;
  }

  .bio-entry__info {
    color: var(--ink-soft);
  }

  .bio-entry__info em {
    font-style: italic;
  }

  .bio-entry__info strong {
    font-weight: 700;
    color: var(--ink);
  }

  .bio-entry--highlight {
    background-color: var(--white);
  }

  /* ===== Publications grid ===== */
  .bio-publications {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s3);
  }

  .bio-pub-card {
    display: flex;
    flex-direction: column;
  }

  .bio-pub-card__cover {
    aspect-ratio: 3/4;
    background-color: var(--paper-dark);
    overflow: hidden;
    margin-bottom: var(--s2);
  }

  .bio-pub-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bio-pub-card__cover--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bio-pub-card__cover--placeholder span {
    font-family: var(--mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ash-light);
  }

  .bio-pub-card__info h3 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--s1);
  }

  /* ===== Two-column (Collections + Representation) ===== */
  .bio-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s5);
  }

  .bio-two-col h4 {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    margin-bottom: var(--s2);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .bio-two-col ul {
    list-style: none;
  }

  .bio-two-col ul li {
    padding: var(--s1) 0;
    border-bottom: 1px solid var(--paper-dark);
  }

  /* ===== hr overrides inside bio-page ===== */
  .bio-page .rule--light {
    border: none;
    border-top: 1px solid var(--paper-dark);
    margin: var(--s4) 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .bio-page__opening {
      grid-template-columns: 1fr;
    }

    .bio-page__portrait {
      max-width: 280px;
    }

    .bio-entry {
      grid-template-columns: 56px 1fr;
      gap: var(--s2);
    }

    .bio-publications {
      grid-template-columns: 1fr;
    }

    .bio-two-col {
      grid-template-columns: 1fr;
      gap: var(--s4);
    }
  }
</style>

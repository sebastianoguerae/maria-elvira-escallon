---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'En el fertil suelo — La travesia';

const img1 = (await import('../../../assets/images/obras/fertil-suelo/fertil-suelo-01.webp')).default;
const img2 = (await import('../../../assets/images/obras/fertil-suelo/fertil-suelo-02.webp')).default;
---

<Layout
  lang={lang}
  title="En el fertil suelo — Work"
  description="En el fertil suelo — La travesia (2017–2018). Video, sculpture. X Premio Luis Caballero nomination. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="En el fertil suelo"
    year="2017–2018"
    medium="Video, sculpture"
    description="Installation for the X Premio Luis Caballero. Sand accumulating in a domestic space."
    url="https://mariaelviraescallon.com/en/works/en-el-fertil-suelo/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 008</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2017–2018 &nbsp;/&nbsp; Video, sculpture &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="En el fertil suelo — General view of the sculptural installation" loading="eager">
        <img src={img2.src} alt="En el fertil suelo — Detail of the sculptural figures" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Inspired by Homer's <em>Iliad</em> — specifically the passage in which Achaeans
            and Trojans, after ten years of war, decide to lay down their arms on the
            battlefield — the work presents two characters who, despite enormous impediments,
            have found each other in order to move forward.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The artist perceives them as "antiguos adversarios que regresan de la guerra y
            emprenden un viaje que con frecuencia se lleva a cabo en soledad y hacia la
            incertidumbre." The work relates this historical moment of vulnerability between
            former enemies to the contemporary sociopolitical context of Colombia and its
            peace process.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The project includes light and sound installations that explore "la enredada
            administracion de justicia en la Colombia contemporanea," using sensory elements
            — sounds, shadows, footsteps — rather than directly representing the protagonists.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            Created during the period following Colombia's peace agreement (signed in 2016),
            the work addresses the difficult transition from conflict to coexistence without
            being literal. The Homeric reference allows Escallon to speak about the present
            through antiquity, finding in the Greek epic a mirror for the Colombian moment.
          </p>
          <p style="margin-top: var(--s2);">
            The title itself — <em>En el fertil suelo</em> — evokes both Colombian soil and the
            battlefield where arms are laid down, establishing a tension between fertility and
            destruction, between what grows and what has been devastated.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>En el fertil suelo — La travesia</strong><br>
            2017–2018<br><br>
            Video, sculpture.<br>
            Light and sound installations.<br>
            Variable dimensions
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            X Premio Luis Caballero nomination<br>
            IDARTES, 2018
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            MAMBO, Bogota, 2019<br>
            X Premio Luis Caballero — Galeria Santa Fe, Bogota, 2018
          </div>

          <h4 style="margin-top: var(--s3);">LOCATION</h4>
          <div class="ficha">
            Galeria Santa Fe, Bogota (X Premio Luis Caballero)<br>
            MAMBO, Bogota, 2019
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2017–2018). <em>En el fertil suelo — La travesia</em>.
            Video, sculpture. Available at:
            mariaelviraescallon.com/en/works/en-el-fertil-suelo/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

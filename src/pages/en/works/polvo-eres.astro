---
import { Image } from 'astro:assets';
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Polvo eres';

const imgPortada = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-portada.webp')).default;
const img01 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-01.webp')).default;
const img02 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-02.webp')).default;
const img03 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-03.webp')).default;
const img04 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-04.webp')).default;
const img05 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-05.webp')).default;
const img06 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-06.webp')).default;
const img07 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-07.webp')).default;
const img08 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-08.webp')).default;
const img09 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-09.webp')).default;
const img10 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-10.webp')).default;
---

<Layout
  lang={lang}
  title="Polvo eres — Work"
  description="Polvo eres (2024). Wall carving, brick wall, carving debris, plaster, paint. Maria Elvira Escallon."
  ogImage={imgPortada.src}
>


  <ArtworkSchema
    title="Polvo eres"
    year="2024"
    medium="Wall carving"
    description="Inscription carved directly into the wall of the MAMU, Bogota. Biblical reference to dust and mortality."
    url="https://mariaelviraescallon.org/en/works/polvo-eres/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 012</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2024 &nbsp;/&nbsp; Wall carving, brick wall, carving debris, plaster, paint &nbsp;/&nbsp; Approx. 60 x 400 cm</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <Image src={imgPortada} alt="Polvo eres — Vista frontal de la talla sobre el muro, MAMU" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img01} alt="Polvo eres — General view of the wall carving" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img02} alt="Polvo eres — Detail of carved inscription" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img03} alt="Polvo eres — Carving debris on the floor" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img04} alt="Polvo eres — Texture of exposed brick wall" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img05} alt="Polvo eres — Detail of carved letters" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img06} alt="Polvo eres — Side view of the intervention" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img07} alt="Polvo eres — Dust accumulation at the base of the wall" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img08} alt="Polvo eres — Detail of carving process" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img09} alt="Polvo eres — Gallery view at MAMU" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img10} alt="Polvo eres — Final view of the installed work" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Polvo eres</span>
        </div>
        <video controls preload="metadata">
          <source src="/video/polvo-eres-web.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Project planned for the central hall of the Hospital Santa Rosa. Stop-motion video of the phrase "Polvo eres" [Dust thou art] slowly appearing as it is carved with chisel and mallet on the reception wall of the hall. Each of the blows can be seen appearing on the wall, but the subject performing the action is never visible. It was first projected on a wall of the Hospital Santa Rosa in 2008 and later carved into the wall of the Art Museum of the Universidad Nacional de Colombia.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Subsequently, as time has passed, this gesture has been repeated, taking on other connotations in other spaces. "Polvo eres" as stardust, in the sense that we are made of the same atoms as the stars; "Polvo eres" in the sense that we are not beings as solid as we perceive: everything is in permanent transformation, and we are really clusters of vibrating molecules, perhaps as the Buddha's phrase in his Fire Sermon suggests: “everything is burning.”
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            For the International Biennial of Antioquia and Medellín, a new version of this work was installed in the COLTABACO Building. A large space was found there, mysteriously carpeted with a layer of 40 to 60 cm of rubble from walls of the building itself, demolished in the past but never removed — resulting in an extraordinary panorama of a building coexisting with its own remains. The installation reminds us at once of the primordial law to which all living beings are bound — from single-celled organisms to the stars — and of the terrible historical juncture we inhabit in 2025. On the other hand, in this version of Polvo eres we find something not present in any of the previous versions: among the rubble, we see small pioneer plants emerging, as if something beneath it, despite everything, insisted on resurging and manifesting itself.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Polvo eres</strong><br>
            2008–2024<br><br>
            Wall carving, brick wall, carving debris, plaster, paint.<br><br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2008–2024). “Polvo eres”.
            Wall carving. Available at:
            mariaelviraescallon.org/en/works/polvo-eres/
          </div>
        </aside>
      </div>

  </article>

</Layout>

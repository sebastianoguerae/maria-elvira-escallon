---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Polvo eres';

const img01 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-01.webp')).default;
const img02 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-02.webp')).default;
const img03 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-03.webp')).default;
const img04 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-04.webp')).default;
const img05 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-05.webp')).default;
const img06 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-06.webp')).default;
const img07 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-07.webp')).default;
const img08 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-08.webp')).default;
const img09 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-09.webp')).default;
const img10 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-10.webp')).default;
---

<Layout
  lang={lang}
  title="Polvo eres — Work"
  description="Polvo eres (2024). Wall carving, brick wall, carving debris, plaster, paint. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Polvo eres"
    year="2024"
    medium="Wall carving"
    description="Inscription carved directly into the wall of the MAMU, Bogota. Biblical reference to dust and mortality."
    url="https://mariaelviraescallon.com/en/works/polvo-eres/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 012</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2024 &nbsp;/&nbsp; Wall carving, brick wall, carving debris, plaster, paint &nbsp;/&nbsp; Approx. 60 x 400 cm</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img01.src} alt="Polvo eres — General view of the wall carving" loading="eager">
        <img src={img02.src} alt="Polvo eres — Detail of carved inscription" loading="lazy">
        <img src={img03.src} alt="Polvo eres — Carving debris on the floor" loading="lazy">
        <img src={img04.src} alt="Polvo eres — Texture of exposed brick wall" loading="lazy">
        <img src={img05.src} alt="Polvo eres — Detail of carved letters" loading="lazy">
        <img src={img06.src} alt="Polvo eres — Side view of the intervention" loading="lazy">
        <img src={img07.src} alt="Polvo eres — Dust accumulation at the base of the wall" loading="lazy">
        <img src={img08.src} alt="Polvo eres — Detail of carving process" loading="lazy">
        <img src={img09.src} alt="Polvo eres — Gallery view at MAMU" loading="lazy">
        <img src={img10.src} alt="Polvo eres — Final view of the installed work" loading="lazy">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Polvo eres</span>
        </div>
        <video controls preload="metadata">
          <source src="/maria-elvira-escallon/video/polvo-eres-web.mp4" type="video/mp4">
        </video>
      </div>

  </article>

</Layout>

---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Precipitaciones de arenas del rio Cauca';

const img1 = (await import('../../../assets/images/obras/precipitaciones-cauca/cauca-01.jpg')).default;
const img2 = (await import('../../../assets/images/obras/precipitaciones-cauca/cauca-02.jpg')).default;
---

<Layout
  lang={lang}
  title="Precipitaciones de arenas del rio Cauca — Work"
  description="Precipitaciones de arenas del rio Cauca (2008–2009). Installation — river sand, furniture. 41st National Artists' Salon, Cali. Maria Elvira Escallon."
>

  <ArtworkSchema
    title="Precipitaciones de arenas del rio Cauca"
    year="2008–2009"
    medium="Installation. River sand, furniture"
    description="Sand from the Cauca River continuously poured into a room at the Colegio Sagrada Familia. Waiting-room furniture is gradually buried. 41st National Artists' Salon, Cali."
    url="https://mariaelviraescallon.com/en/works/precipitaciones-cauca/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 023</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2008–2009 &nbsp;/&nbsp; Installation — river sand, furniture &nbsp;/&nbsp; 41st National Artists' Salon, Cali</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Precipitaciones de arenas del rio Cauca — Sand burying furniture at the Colegio Sagrada Familia" loading="eager">
        <img src={img2.src} alt="Precipitaciones de arenas del rio Cauca — Detail of sand accumulation over furniture" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Sand from the Cauca River was continuously poured into a room at the Colegio
            Sagrada Familia in Cali. The space contained waiting-room furniture — chairs,
            tables — that was gradually buried under the sand as the exhibition progressed.
            The process was slow, visible only to those who returned to the room at different
            moments.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The work operates as a temporal device: it makes the passage of time visible
            through material accumulation. The waiting-room furniture — objects designed for
            transit, for the pause before something that will come — become buried, fossilized
            objects. Waiting is transformed into burial. What was meant to be provisional
            becomes permanent.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The Cauca River, which runs through the Valle del Cauca and whose sands have been
            witnesses and repositories of Colombian violence, adds an additional layer of
            meaning. The sand is not a neutral material: it carries the history of the
            territory with it. This work constituted the conceptual origin of what would later
            develop into <em>Precipitacion de arenas</em>.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            The installation was presented at the 41st National Artists' Salon in Cali,
            curated by Jaime Ceron. Maria Elvira Escallon participated by invitation of
            the artist Wilson Diaz. The Colegio Sagrada Familia, as the venue for the work,
            added an institutional resonance — a space of education and formation turned into
            a scene of accumulation and burial.
          </p>

          <h3 style="margin-top: var(--s4);">RELATED WORKS</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/en/works/precipitacion-de-arenas/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Precipitacion de arenas (2022–2024)</a>
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/en/works/dispositivos-para-ver-pasar-el-tiempo/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Dispositivos para ver pasar el tiempo (2009–2024)</a>
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Precipitaciones de arenas del rio Cauca</strong><br>
            2008–2009<br><br>
            Installation.<br>
            River sand, furniture.<br><br>
            Variable dimensions.<br>
            Colegio Sagrada Familia, Cali.
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            41st National Artists' Salon — Cali, 2008–2009<br>
            Curated by: Jaime Ceron<br>
            Invitation: Wilson Diaz
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2008–2009). <em>Precipitaciones de arenas del rio Cauca</em>.
            Installation. Available at:
            mariaelviraescallon.com/en/works/precipitaciones-cauca/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

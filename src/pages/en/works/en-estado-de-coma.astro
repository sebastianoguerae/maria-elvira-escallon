---
import { Image } from 'astro:assets';
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'En estado de coma';

// Cultivos
const cultivos01 = (await import('../../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-01.webp')).default;
const cultivos02 = (await import('../../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-02.webp')).default;
const cultivos03 = (await import('../../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-03.webp')).default;
// Serie tejido blando
const tejido04 = (await import('../../../assets/images/obras/en-estado-de-coma/serie-tejido-blando/serie-tejido-blando-04.webp')).default;
const tejido05 = (await import('../../../assets/images/obras/en-estado-de-coma/serie-tejido-blando/serie-tejido-blando-05.webp')).default;
const tejido06 = (await import('../../../assets/images/obras/en-estado-de-coma/serie-tejido-blando/serie-tejido-blando-06.webp')).default;
const tejido07 = (await import('../../../assets/images/obras/en-estado-de-coma/serie-tejido-blando/serie-tejido-blando-07.webp')).default;
// Serie extracciones
const extracciones08 = (await import('../../../assets/images/obras/en-estado-de-coma/serie-extracciones/serie-extracciones-08.webp')).default;
const extracciones09 = (await import('../../../assets/images/obras/en-estado-de-coma/serie-extracciones/serie-extracciones-09.webp')).default;
// Recorridos nocturnos
const recorridoG1 = (await import('../../../assets/images/obras/en-estado-de-coma/recorridos-nocturnos/recorrido-grande-01.webp')).default;
const recorridoG2 = (await import('../../../assets/images/obras/en-estado-de-coma/recorridos-nocturnos/recorrido-grande-02.webp')).default;
const recorridoG3 = (await import('../../../assets/images/obras/en-estado-de-coma/recorridos-nocturnos/recorrido-grande-03.webp')).default;
const recorridoG4 = (await import('../../../assets/images/obras/en-estado-de-coma/recorridos-nocturnos/recorrido-grande-04.webp')).default;
// Postales
const postales14 = (await import('../../../assets/images/obras/en-estado-de-coma/postales/postales-14.webp')).default;
const postales15 = (await import('../../../assets/images/obras/en-estado-de-coma/postales/postales-15.webp')).default;
const postales16 = (await import('../../../assets/images/obras/en-estado-de-coma/postales/postales-16.webp')).default;
const postales17 = (await import('../../../assets/images/obras/en-estado-de-coma/postales/postales-17.webp')).default;
---

<Layout
  lang={lang}
  title="En estado de coma — Work"
  description="En estado de coma (2005-2007). 5 photographic series, video, sculptural installation. Hospital San Juan de Dios, Bogota. Maria Elvira Escallon."
  ogImage={cultivos01.src}
>


  <ArtworkSchema
    title="En estado de coma"
    year="2005-2007"
    medium="Photography, video, installation"
    description="Documentation of the abandoned Hospital San Juan de Dios, Bogota. Photographs, videos, and extractions from the building."
    url="https://mariaelviraescallon.org/en/works/en-estado-de-coma/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 006</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2005-2007 &nbsp;/&nbsp; 5 photographic series, video, sculptural installation &nbsp;/&nbsp; Hospital San Juan de Dios, Bogota</p>
      </header>


      <!-- Main text (before the images, per the artist's instruction) -->
      <div class="work-page__text" style="margin-bottom: var(--s4); max-width: 72ch;">
        <p class="curatorial">
          A set of photographic, sculptural, and video series about the Hospital San Juan de Dios in Bogota, which was, at the scientific and social level, one of the most important public hospitals in the country. Traditionally, it was the hospital that provided care to the lowest-income sectors of the city. The San Juan de Dios was closed in 2001 as a consequence of a combination of mismanagement and health service privatization policies.
        </p>
        <p class="curatorial" style="margin-top: var(--s2);">
          "En estado de coma" began as a documentary project seeking to give visibility to the state of a deserted and fully equipped hospital. Little by little, it shifted toward other practices, and a series of interventions on the hospital furniture were carried out. The project is centered on the space of the bed, the only "private" space accessible to a patient in a public hospital.
        </p>
        <p class="curatorial" style="margin-top: var(--s2);">
          "En estado de coma" seeks to approach some of the processes that converge in that space: the immobility in which an enormous and optimal physical plant and equipment are immersed, permanently threatened by deterioration (Postcard Project and video); the absent body of patients who have ceased to inhabit the Hospital during these years but whose traces we still find ("Soft Tissue" Series and "Nocturnal Walks" Series); the progressive process of usurpation of the Hospital's assets by government authorities ("Extractions" Series); and the resistance of a small group of its former employees who, with precarious means, insist on counteracting the institutional abandonment ("Cultures" Series and video).
        </p>
      </div>
      <!-- Gallery: Cultivos -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">SERIE “CULTIVOS”</h3>
        <Image src={cultivos01} alt="En estado de coma — Cultures, vegetation invading the hospital" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={cultivos02} alt="En estado de coma — Cultures, nature reclaiming spaces" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={cultivos03} alt="En estado de coma — Cultures, organic growth in abandonment" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">SERIE “TEJIDO BLANDO”</h3>
        <Image src={tejido04} alt="En estado de coma — Soft Tissue, hospital sheets" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={tejido05} alt="En estado de coma — Soft Tissue, curtains and textiles" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={tejido06} alt="En estado de coma — Soft Tissue, vestiges of medical activity" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={tejido07} alt="En estado de coma — Soft Tissue, fabrics on empty beds" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">SERIE “EXTRACCIONES”</h3>
        <Image src={extracciones08} alt="En estado de coma — Extractions, isolated architectural element" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={extracciones09} alt="En estado de coma — Extractions, specimen of the sick body" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">SERIE “RECORRIDOS NOCTURNOS”</h3>
        <Image src={recorridoG1} alt="En estado de coma — Nocturnal Walks, room with a bed" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={recorridoG2} alt="En estado de coma — Nocturnal Walks, ward in half-light" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={recorridoG3} alt="En estado de coma — Nocturnal Walks, large window at dusk" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={recorridoG4} alt="En estado de coma — Nocturnal Walks, medical records archive" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">SERIE “POSTALES”</h3>
        <div class="postales-grid">
          <Image src={postales14} alt="En estado de coma — Postcard 1" loading="lazy" widths={[300, 600]} sizes="(max-width: 640px) 50vw, 25vw" />
          <Image src={postales15} alt="En estado de coma — Postcard 2" loading="lazy" widths={[300, 600]} sizes="(max-width: 640px) 50vw, 25vw" />
          <Image src={postales16} alt="En estado de coma — Postcard 3" loading="lazy" widths={[300, 600]} sizes="(max-width: 640px) 50vw, 25vw" />
          <Image src={postales17} alt="En estado de coma — Postcard 4" loading="lazy" widths={[300, 600]} sizes="(max-width: 640px) 50vw, 25vw" />
        </div>
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">
          <h3 style="margin-top: var(--s4);">TEXT ON THE BACK OF THE POSTCARDS</h3>

          <div class="ficha" style="margin-top: var(--s2); line-height: 2;">
            <strong>Hospital San Juan de Dios</strong><br>
            2800 days at a standstill<br>
            540 hospital beds installed ● Basements: Emergency service with hospitalization capacity for 80 patients, 500,000 medical records in the active archive, passive archive with more than 2,000,000 medical records, central kitchen with capacity to serve 1,200 meals a day, central laundry with capacity to wash 1,200 sheets and 2,000 pieces of linen daily ● Floor 1: outpatient services, 50 consulting rooms ● Floor 2: Gastroscopy department, Pathology unit, Gastroenterology laboratory, Central clinical laboratory, National serum bank, Blood bank, Hemodynamics, CT scanning, Ultrasound, Nuclear medicine, Radiology, Tuberculosis unit, Pneumology department, Central sterilization ● Floor 3: 16 operating rooms, Intensive Care Unit with capacity for 21 patients ● Floor 5: Hospitalization for surgical specialties, men and women ● Floor 6: General surgery, men and women ● Floor 7: Internal Medicine, Renal and hemodialysis unit with capacity for 11 patients in 4 shifts, Nephrology laboratory, Electroencephalography ● Floor 8: All specialties ● Peripheral buildings: San Lucas Pavilion: Infectious patients, burn patients, Rehabilitation service ● San Eduardo Pavilion: Maxillofacial surgery, Plastic surgery, 30 dental units ● Maximiliano Rueda Mental Health Unit: Hospitalization for 40 patients, occupational therapies, day hospital ● Institute of Immunology ● Magnetic resonance imaging equipment ● Carrión: Eye bank, Bone densitometry, Endocrinology unit, Clinical hematology laboratory, Morgue ● Santa Marta Unit for tropical diseases ● Human team: 1,580 employees on standby<br>
            June 3, 2009
          </div>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>En estado de coma</strong><br>
            2005-2007<br><br>
            5 photographic series, video,<br>
            sculptural installation.<br><br>
            Hospital San Juan de Dios, Bogota.<br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">PUBLICATION</h4>
          <div class="ficha">
            IDPC / Johns Hopkins University Press<br>
            (Project MUSE)
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Hospital San Juan de Dios, Bogota<br>
            National and international exhibitions
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/en/texts/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Related texts
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2005-2007). “En estado de coma”.
            Photographic series, video, and installation. Available at:
            mariaelviraescallon.org/en/works/en-estado-de-coma/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  .postales-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s1);
    align-items: start;
  }
  @media (max-width: 640px) {
    .postales-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

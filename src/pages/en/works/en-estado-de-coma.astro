---
import Layout from '../../../components/layout/Layout.astro';

const lang = 'en' as const;
const title = 'En estado de coma';

const img1 = (await import('../../../assets/images/obras/en-estado-de-coma/coma-hospital-01.jpg')).default;
const img2 = (await import('../../../assets/images/obras/en-estado-de-coma/coma-hospital-02.jpg')).default;
const img3 = (await import('../../../assets/images/obras/en-estado-de-coma/coma-hospital-03.jpg')).default;
const img4 = (await import('../../../assets/images/obras/en-estado-de-coma/coma-pared-detalle.jpg')).default;
const img5 = (await import('../../../assets/images/obras/en-estado-de-coma/coma-cultivos-cama.jpg')).default;
---

<Layout
  lang={lang}
  title="En estado de coma — Work"
  description="En estado de coma (2005–2007). 5 photographic series, video, sculptural installation. Hospital San Juan de Dios, Bogota. Maria Elvira Escallon."
>

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 006</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2005–2007 &nbsp;/&nbsp; 5 photographic series, video, sculptural installation &nbsp;/&nbsp; Hospital San Juan de Dios, Bogota</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="En estado de coma — Hospital San Juan de Dios, general view of deterioration" loading="eager">
        <img src={img2.src} alt="En estado de coma — Hospital San Juan de Dios, abandoned corridors" loading="lazy">
        <img src={img3.src} alt="En estado de coma — Hospital San Juan de Dios, vegetation reclaiming spaces" loading="lazy">
        <img src={img4.src} alt="En estado de coma — Deteriorated wall detail, exposed layers" loading="lazy">
        <img src={img5.src} alt="Cultures — Hospital bed with grass growing, En estado de coma series" loading="lazy">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Extracciones · Full video · 1:26 min</span>
        </div>
        <video controls preload="metadata" poster="">
          <source src="/maria-elvira-escallon/video/extracciones-obra.mp4" type="video/mp4">
          Your browser does not support HTML5 video.
        </video>
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            The project began in 2005 as a documentary seeking to make visible the conditions
            of Hospital San Juan de Dios — founded in 1564, outstanding for its level of
            specialization — after falling into abandonment. It includes five photographic
            series: <em>Postcards</em>, <em>Nocturnal Walks</em>, <em>Soft Tissue</em>,
            <em>Extractions</em>, and <em>Cultures</em>.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The hospital was closed in 2001 as a consequence of mismanagement and the
            privatization of the healthcare system. A small group of employees continued
            giving 'oxygen to the terminal patient.' The title of the work refers to
            'an entity that is not dead and about which there is hope.'
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Escallon did not document the hospital as a picturesque ruin but as an organism
            in a state of suspension. The five series address different facets of this
            liminal condition: the inverted tourist postcards, the nocturnal walks that
            reveal what daylight conceals, the soft tissue of sheets still covering empty
            beds, the extractions of architectural elements as if they were clinical samples,
            and the cultures of vegetation reclaiming the abandoned spaces.
          </p>

          <h3 style="margin-top: var(--s4);">SERIES</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Postcards</strong> — Photographs of the hospital treated as tourist postcards, inverting the promotional logic to reveal deterioration.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Nocturnal Walks</strong> — Photographic record of the hospital corridors and wards at night, when absence becomes more palpable.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Soft Tissue</strong> — Documentation of the sheets, curtains, and hospital textiles that remain as vestiges of medical activity.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Extractions</strong> — Architectural and hospital elements isolated from their context, treated as samples from a sick body.
            </li>
            <li style="padding: var(--s1) 0;">
              <strong>Cultures</strong> — Record of the vegetation that invades and reclaims the abandoned spaces of the hospital.
            </li>
          </ul>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            Hospital San Juan de Dios, founded in 1564, was one of Colombia's most important
            public hospitals, providing care to the poorest. After its closure in 2001, it
            was declared national cultural heritage in 2002. The building, designed by
            architect Pablo de la Cruz, represents a central chapter in the history of
            Colombian public health.
          </p>
          <p style="margin-top: var(--s2);">
            Escallon's work is part of her line of research on heritage in abandonment and
            the relationship between the State and the buildings that embody collective
            memory. As in <em>In Vitro</em>, the artist works with a heritage building
            that the State has left in ruins, but here the scale is monumental and the
            deterioration extends over years.
          </p>
          <p style="margin-top: var(--s2);">
            The project was published as a book by the IDPC and Johns Hopkins University Press
            (Project MUSE), consolidating its importance both in the artistic field and in the
            discussion on cultural heritage and public health in Colombia.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>En estado de coma</strong><br>
            2005–2007<br><br>
            5 photographic series, video,<br>
            sculptural installation.<br><br>
            Hospital San Juan de Dios, Bogota.<br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            First Prize Heritage Category — IDCT, 2006<br><br>
            National Individual Creation Grant — MinCultura, 2005
          </div>

          <h4 style="margin-top: var(--s3);">PUBLICATION</h4>
          <div class="ficha">
            IDPC / Johns Hopkins University Press<br>
            (Project MUSE)
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Hospital San Juan de Dios, Bogota<br>
            National and international exhibitions
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/es/textos/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Related texts (ES)
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2005–2007). <em>En estado de coma</em>.
            Photographic series, video, and installation. Available at:
            mariaelviraescallon.com/en/works/en-estado-de-coma/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  .work-page {
    padding-top: calc(var(--s5) + 40px);
  }

  .work-page__header {
    margin-bottom: var(--s4);
  }

  .work-page__header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4rem);
    margin: var(--s1) 0;
  }

  .work-page__meta {
    font-size: 0.75rem;
    color: var(--ash);
    letter-spacing: 0.03em;
  }

  .work-page__gallery {
    display: grid;
    gap: var(--s2);
    margin-bottom: var(--s4);
  }

  .work-page__gallery img {
    width: 100%;
    display: block;
  }

  .work-page__body {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--s5);
    margin-bottom: var(--s5);
  }

  .work-page__text h3 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--ash);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .work-page__ficha h4 {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    margin-bottom: var(--s1);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .placeholder-img {
    width: 100%;
    background-color: var(--paper-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ash-light);
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-page__video {
    margin: var(--s4) 0;
  }
  .work-page__video-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s2);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--ink);
  }
  .work-page__video-header h3 {
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .work-page__video video {
    width: 100%;
    background: var(--ink);
    display: block;
  }

  @media (max-width: 768px) {
    .work-page__body {
      grid-template-columns: 1fr;
    }
  }
</style>

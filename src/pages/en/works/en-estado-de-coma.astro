---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';
import AudioPlayer from '../../../components/interactive/AudioPlayer';

const lang = 'en' as const;
const title = 'En estado de coma';

// Cultivos
const imgsCultivos = await Promise.all(
  Array.from({ length: 3 }, (_, i) =>
    import(`../../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Serie tejido blando
const imgsTejido = await Promise.all(
  [4,5,6,7].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/serie-tejido-blando/serie-tejido-blando-${String(n).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Serie extracciones
const imgsExtracciones = await Promise.all(
  [8,9].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/serie-extracciones/serie-extracciones-${String(n).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Recorridos nocturnos
const imgsRecorridos = await Promise.all(
  [10,11,12,13].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/recorridos-nocturnos/recorridos-nocturnos-${n}.webp`)
  )
).then(m => m.map(x => x.default));
// Postales
const imgsPostales = await Promise.all(
  [14,15,16,17].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/postales/postales-${n}.webp`)
  )
).then(m => m.map(x => x.default));
---

<Layout
  lang={lang}
  title="En estado de coma — Work"
  description="En estado de coma (2005–2007). 5 photographic series, video, sculptural installation. Hospital San Juan de Dios, Bogota. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="En estado de coma"
    year="2005–2007"
    medium="Photography, video, installation"
    description="Documentation of the abandoned Hospital San Juan de Dios, Bogota. Photographs, videos, and extractions from the building."
    url="https://mariaelviraescallon.com/en/works/en-estado-de-coma/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 006</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2005–2007 &nbsp;/&nbsp; 5 photographic series, video, sculptural installation &nbsp;/&nbsp; Hospital San Juan de Dios, Bogota</p>
      </header>

      <!-- Gallery: Cultures -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">CULTURES</h3>
        {imgsCultivos.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Cultures ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'}>
        ))}
      </div>

      <!-- Gallery: Soft Tissue series -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">SOFT TISSUE SERIES</h3>
        {imgsTejido.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Soft Tissue series ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Extractions series -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">EXTRACTIONS SERIES</h3>
        {imgsExtracciones.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Extractions series ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Nocturnal Walks -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">NOCTURNAL WALKS</h3>
        {imgsRecorridos.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Nocturnal Walks ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Postcards -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">POSTCARDS</h3>
        {imgsPostales.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Postcards ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Extracciones · Full video · 1:26 min</span>
        </div>
        <video controls preload="metadata" poster="">
          <source src="/maria-elvira-escallon/video/extracciones-obra.mp4" type="video/mp4">
          Your browser does not support HTML5 video.
        </video>
      </div>

      <!-- Audio -->
      <div style="margin: var(--s3) 0;">
        <AudioPlayer client:visible title="Maria Elvira on En estado de coma" />
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            The project began in 2005 as a documentary that sought to make visible the
            conditions of Hospital San Juan de Dios -- founded in 1564, distinguished by its
            level of specialization -- after falling into abandonment. It includes five
            photographic series: <em>Postcards</em>, <em>Nocturnal Walks</em>, <em>Soft
            Tissue</em>, <em>Extractions</em>, and <em>Cultures</em>.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The hospital was closed in 2001 as a consequence of mismanagement and the
            privatization of the healthcare system. A small group of employees continued
            giving "oxygen to the terminal patient" [Spanish: "oxigeno al paciente terminal"].
            The title of the work refers to "an entity that is not dead and about which there
            is hope" [Spanish: "una entidad que no esta muerta y sobre la cual hay esperanza"].
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Escallon did not document the hospital as a picturesque ruin but as an organism
            in a state of suspension. The five series address different facets of that
            liminal condition: the inverted tourist postcards, the nocturnal walks that
            reveal what daylight conceals, the soft tissue of the sheets that still cover
            empty beds, the extractions of architectural elements as if they were clinical
            samples, and the cultures of vegetation that reclaim the abandoned spaces.
          </p>

          <h3 style="margin-top: var(--s4);">SERIES</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Postcards</strong> — Photographs of the hospital treated as tourist postcards, inverting the promotional logic to reveal the deterioration.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Nocturnal Walks</strong> — Photographic record of the hospital corridors and wards at night, when absence becomes more palpable.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Soft Tissue</strong> — Documentation of the sheets, curtains, and hospital textiles that remain as vestiges of medical activity.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Extractions</strong> — Architectural and hospital elements isolated from their context, treated as samples from a sick body.
            </li>
            <li style="padding: var(--s1) 0;">
              <strong>Cultures</strong> — Record of the vegetation that invades and reclaims the abandoned spaces of the hospital.
            </li>
          </ul>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            Hospital San Juan de Dios, founded in 1564, was one of Colombia's most important
            public hospitals, providing care to the poorest. After its closure in 2001, it
            was declared national cultural heritage in 2002. The building, designed by
            architect Pablo de la Cruz, represents a central chapter in the history of
            Colombian public health.
          </p>
          <p style="margin-top: var(--s2);">
            Escallon's work is part of her line of research on heritage in abandonment and
            the relationship between the State and the buildings that embody collective
            memory. As in <em>In Vitro</em>, the artist works with a heritage building
            that the State has left in ruins, but here the scale is monumental and the
            deterioration extends over years.
          </p>
          <p style="margin-top: var(--s2);">
            The project was published as a book by the IDPC and Johns Hopkins University Press
            (Project MUSE), consolidating its importance both in the artistic field and in the
            discussion on cultural heritage and public health in Colombia.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>En estado de coma</strong><br>
            2005–2007<br><br>
            5 photographic series, video,<br>
            sculptural installation.<br><br>
            Hospital San Juan de Dios, Bogota.<br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            First Prize, Heritage Category — IDCT, 2006<br><br>
            National Individual Creation Grant — MinCultura, 2005
          </div>

          <h4 style="margin-top: var(--s3);">PUBLICATION</h4>
          <div class="ficha">
            IDPC / Johns Hopkins University Press<br>
            (Project MUSE)
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Hospital San Juan de Dios, Bogota<br>
            National and international exhibitions
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/en/texts/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Related texts
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2005–2007). <em>En estado de coma</em>.
            Photographic series, video, and installation. Available at:
            mariaelviraescallon.com/en/works/en-estado-de-coma/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

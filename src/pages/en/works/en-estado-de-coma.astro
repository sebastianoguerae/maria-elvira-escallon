---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'En estado de coma';

// Cultivos
const imgsCultivos = await Promise.all(
  Array.from({ length: 3 }, (_, i) =>
    import(`../../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Serie tejido blando
const imgsTejido = await Promise.all(
  [4,5,6,7].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/serie-tejido-blando/serie-tejido-blando-${String(n).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Serie extracciones
const imgsExtracciones = await Promise.all(
  [8,9].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/serie-extracciones/serie-extracciones-${String(n).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Recorridos nocturnos
const imgsRecorridos = await Promise.all(
  [10,11,12,13].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/recorridos-nocturnos/recorridos-nocturnos-${n}.webp`)
  )
).then(m => m.map(x => x.default));
// Postales
const imgsPostales = await Promise.all(
  [14,15,16,17].map(n =>
    import(`../../../assets/images/obras/en-estado-de-coma/postales/postales-${n}.webp`)
  )
).then(m => m.map(x => x.default));
---

<Layout
  lang={lang}
  title="En estado de coma — Work"
  description="En estado de coma (2005–2007). 5 photographic series, video, sculptural installation. Hospital San Juan de Dios, Bogota. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="En estado de coma"
    year="2005–2007"
    medium="Photography, video, installation"
    description="Documentation of the abandoned Hospital San Juan de Dios, Bogota. Photographs, videos, and extractions from the building."
    url="https://mariaelviraescallon.com/en/works/en-estado-de-coma/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 006</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2005–2007 &nbsp;/&nbsp; 5 photographic series, video, sculptural installation &nbsp;/&nbsp; Hospital San Juan de Dios, Bogota</p>
      </header>

      <!-- Gallery: Cultures -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">CULTURES</h3>
        {imgsCultivos.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Cultures ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'}>
        ))}
      </div>

      <!-- Gallery: Soft Tissue series -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">SOFT TISSUE SERIES</h3>
        {imgsTejido.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Soft Tissue series ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Extractions series -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">EXTRACTIONS SERIES</h3>
        {imgsExtracciones.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Extractions series ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Nocturnal Walks -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">NOCTURNAL WALKS</h3>
        {imgsRecorridos.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Nocturnal Walks ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Postcards -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">POSTCARDS</h3>
        {imgsPostales.map((img, i) => (
          <img src={img.src} alt={`En estado de coma — Postcards ${i + 1}`} loading="lazy">
        ))}
      </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

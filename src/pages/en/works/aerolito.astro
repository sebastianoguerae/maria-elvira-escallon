---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Pequeno Museo del Aerolito de Santa Rosa de Viterbo';

const imgs = await Promise.all(
  Array.from({ length: 22 }, (_, i) =>
    import(`../../../assets/images/obras/aerolito/aerolito-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
---

<Layout
  lang={lang}
  title="Pequeno Museo del Aerolito — Work"
  description="Pequeno Museo del Aerolito de Santa Rosa de Viterbo (2014-2015). Research, installation, historical and photographic archives, iron replica. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Pequeno Museo del Aerolito de Santa Rosa de Viterbo"
    year="2014-2015"
    medium="Research, installation"
    description="Artistic research on the Santa Rosa de Viterbo meteorite and its history of colonial plunder."
    url="https://mariaelviraescallon.com/en/works/aerolito/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 007</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2014-2015 &nbsp;/&nbsp; Research, installation, historical and photographic archives, iron replica &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        {imgs.map((img, i) => (
          <img src={img.src} alt={`Pequeno Museo del Aerolito — Image ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'}>
        ))}
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Meteorito — Pequeno Museo del Aerolito · Documentary video · 2:00 min</span>
        </div>
        <video controls preload="metadata" poster="">
          <source src="/maria-elvira-escallon/video/meteorito-obra.mp4" type="video/mp4">
          Your browser does not support HTML5 video.
        </video>
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Comprising various departments, collections, historical and photographic archives
            that track the history of the meteorite that fell in the department of Boyaca
            on a Holy Saturday in 1810. The project includes an iron replica of the aerolite
            currently held by the Museo Nacional.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The installation realized for "Encuentros en la fabrica de polvo" [Encounters in
            the Dust Factory] at MAMU (2024) was the most complete ever produced, installed in
            the El Parqueadero hall. The Pequeno Museo functions as an institution within an
            institution — a fictional museum that questions the ways in which knowledge is
            constructed, preserved, and exhibited.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Each "department" of the museum addresses a different aspect: geological history,
            cultural impact, local narratives, and scientific documentation.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            The meteorite fell in Santa Rosa de Viterbo, Boyaca, on a Holy Saturday in 1810 —
            the same year as Colombia's independence movement. This temporal coincidence
            adds layers of meaning about origins, cosmic events, and national identity.
          </p>
          <p style="margin-top: var(--s2);">
            The original aerolite rests in the Museo Nacional de Colombia and has been
            the subject of multiple narratives: scientific, religious, popular, and
            institutional. Escallon builds a museographic device that brings them all
            together, questioning the authority of each and revealing how knowledge is
            fabricated as much as it is discovered.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Pequeno Museo del Aerolito de Santa Rosa de Viterbo</strong><br>
            2014-2015<br><br>
            Research, installation, historical and
            photographic archives, iron replica.<br>
            Variable dimensions
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            National Grant for Individual Creation<br>
            MinCultura, 2014
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Encuentros en la fabrica de polvo — MAMU, 2024<br>
            Planetario Distrital, Bogota, 2018<br>
            Museo Nacional de Colombia, Bogota, 2014
          </div>

          <h4 style="margin-top: var(--s3);">LOCATION</h4>
          <div class="ficha">
            Museo Nacional de Colombia, Bogota<br>
            MAMU, Bogota, 2024
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2014-2015). <em>Pequeno Museo del Aerolito de Santa Rosa de Viterbo</em>.
            Research, installation. Available at:
            mariaelviraescallon.com/en/works/aerolito/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

---
import { Image } from 'astro:assets';
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Extractions at the University Hospital';

const img1 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-01.webp')).default;
const img2 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-02.webp')).default;
const img3 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-03.webp')).default;
const img4 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-04.webp')).default;
const img5 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-05.webp')).default;
---

<Layout
  lang={lang}
  title="Extractions at the University Hospital — Work"
  description="Extractions at the University Hospital (2012). Installation, digital giclee print on cotton paper. Maria Elvira Escallon."
  ogImage={img1.src}
>

  <ArtworkSchema
    title="Extractions at the University Hospital"
    year="2012"
    medium="Installation, digital giclee print"
    description="Intervention at the Hospital Santa Rosa. Material extractions from the deteriorating building."
    url="https://sebastianoguerae.github.io/maria-elvira-escallon/en/works/extracciones-hospital/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 012</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2012 &nbsp;/&nbsp; Installation, digital giclee print on cotton paper &nbsp;/&nbsp; 36 x 60 cm each</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <Image src={img1} alt="Extractions at the University Hospital — View of the intervention" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img2} alt="Extractions at the University Hospital — Cladding removal process" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img3} alt="Extractions at the University Hospital — Room stripped to bare structure" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img4} alt="Extractions at the University Hospital — Detail of the extraction" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img5} alt="Extractions at the University Hospital — Record of the process" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            The action of removing the architectural cladding of the Hospital rooms known as the Triage was carried out, located in the emergency area where patients in medical emergency are attended and diagnosed. This cladding was removed manually with chisel and mallet, thus reversing the construction process until bringing these rooms to a state of bare structure. The process has been conceived as the acceleration of a ruin.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Extractions at the University Hospital</strong><br>
            2012<br><br>
            Installation, digital giclee print on cotton paper.<br><br>
            36 x 60 cm each<br>
            Hospital Santa Rosa, Universidad Nacional de Colombia
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2012). “Extractions at the University Hospital”.
            Installation. Available at:
            sebastianoguerae.github.io/maria-elvira-escallon/en/works/extracciones-hospital/
          </div>
        </aside>
      </div>

  </article>

</Layout>

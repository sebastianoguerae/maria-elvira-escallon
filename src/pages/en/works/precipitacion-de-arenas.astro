---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Precipitacion de arenas';

// Rio Cauca 2008 (root)
const prec01 = (await import('../../../assets/images/obras/precipitacion/precipitacion-01.webp')).default;
const prec02 = (await import('../../../assets/images/obras/precipitacion/precipitacion-02.webp')).default;
// 2020
const y2020_01 = (await import('../../../assets/images/obras/precipitacion/2020/2020-01.webp')).default;
const y2020_02 = (await import('../../../assets/images/obras/precipitacion/2020/2020-02.webp')).default;
const y2020_03 = (await import('../../../assets/images/obras/precipitacion/2020/2020-03.webp')).default;
const y2020_04 = (await import('../../../assets/images/obras/precipitacion/2020/2020-04.webp')).default;
// 2024
const y2024_01 = (await import('../../../assets/images/obras/precipitacion/2024/2024-01.webp')).default;
const y2024_02 = (await import('../../../assets/images/obras/precipitacion/2024/2024-02.webp')).default;
const y2024_03 = (await import('../../../assets/images/obras/precipitacion/2024/2024-03.webp')).default;
const y2024_04 = (await import('../../../assets/images/obras/precipitacion/2024/2024-04.webp')).default;
const y2024_05 = (await import('../../../assets/images/obras/precipitacion/2024/2024-05.webp')).default;
const y2024_06 = (await import('../../../assets/images/obras/precipitacion/2024/2024-06.webp')).default;
const y2024_07 = (await import('../../../assets/images/obras/precipitacion/2024/2024-07.webp')).default;
---

<Layout
  lang={lang}
  title="Precipitacion de arenas — Work"
  description="Precipitacion de arenas (2022-2024). Installation — sand, furniture, security glass, speaker. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Precipitacion de arenas"
    year="2022-2024"
    medium="Installation"
    description="Sand slowly precipitating over domestic objects inside a sealed display case. MAMU, Bogota."
    url="https://mariaelviraescallon.com/en/works/precipitacion-de-arenas/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 010</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022-2024 (various versions) &nbsp;/&nbsp; Installation — sand, furniture, security glass, speaker &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Gallery -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">RIO CAUCA, 2008</h3>
        <img src={prec01.src} alt="Precipitacion de arenas — Rio Cauca, sand precipitating" loading="eager">
        <img src={prec02.src} alt="Precipitacion de arenas — Rio Cauca, sand record" loading="lazy">

        <h3 style="margin-top: var(--s3);">PRECIPITACIONES 2020</h3>
        <img src={y2020_01.src} alt="Precipitacion de arenas 2020 — Installation with sand and furniture" loading="lazy">
        <img src={y2020_02.src} alt="Precipitacion de arenas 2020 — Sand over domestic objects" loading="lazy">
        <img src={y2020_03.src} alt="Precipitacion de arenas 2020 — Detail of sealed display case" loading="lazy">
        <img src={y2020_04.src} alt="Precipitacion de arenas 2020 — Ensemble view" loading="lazy">

        <h3 style="margin-top: var(--s3);">PRECIPITACIONES 2024</h3>
        <img src={y2024_01.src} alt="Precipitacion de arenas 2024 — Installation at MAMU" loading="lazy">
        <img src={y2024_02.src} alt="Precipitacion de arenas 2024 — Sand falling over furniture" loading="lazy">
        <img src={y2024_03.src} alt="Precipitacion de arenas 2024 — Detail of accumulation" loading="lazy">
        <img src={y2024_04.src} alt="Precipitacion de arenas 2024 — Security glass and sand" loading="lazy">
        <img src={y2024_05.src} alt="Precipitacion de arenas 2024 — Objects covered in sand" loading="lazy">
        <img src={y2024_06.src} alt="Precipitacion de arenas 2024 — Side view of installation" loading="lazy">
        <img src={y2024_07.src} alt="Precipitacion de arenas 2024 — Final view of the work" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <h3>PRECIPITATION OF SANDS FROM THE CAUCA RIVER (2008)</h3>
          <p class="curatorial" style="margin-top: var(--s2);">
            In 2008, the National Visual Arts Salon was held in the city of Cali. One of the venues was the Colegio La Sagrada Familia, a traditional school run by nuns, located in a residential area of the city. It was out of use, awaiting proposals from interested buyers.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The intervention was carried out in the school's waiting room, by making a perforation in the ceiling slab of this space to form a half-inch hole. Throughout the duration of the exhibition, a stream of sand extracted from the Cauca River was dropped through this hole. More than 7 tons of sand fell, progressively accumulating in the sparsely furnished waiting room with some of its original elements. The public viewed the installation from the door, sealed with glass.
          </p>

          <h3 style="margin-top: var(--s4);">PRECIPITATIONS 2020</h3>
          <p class="curatorial" style="margin-top: var(--s2);">
            The installation was carried out at the Galeria Espacio Continuo. A perforation was made in the ceiling slab of this space to form a half-inch hole. More than 4 tons of sand fell during the 5 weeks of the exhibition, progressively accumulating on a set of furniture stacked in a tower, a moving: the furniture from my house wrapped in packing paper. The public viewed the installation from the door, sealed with glass.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            As in the case of the Cali installation in 2008, I wanted a line of time to cross the space. In some way, the installation facilitates this perception of the passage of time. This stream of river sand falls and little by little covers the objects in the scene. As it falls, a cloud of fine dust rises that gradually adheres to the surfaces; everything loses its shine and sharpness, as does the glass through which we viewed the scene, in a manner similar to that diffuse quality that progressively takes over what recedes from us in time.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Precipitacion de arenas</strong><br>
            2008–2024<br><br>
            Installation — sand, furniture, security glass, speaker.<br><br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2008–2024). <em>Precipitacion de arenas</em>.
            Installation. Available at:
            mariaelviraescallon.com/en/works/precipitacion-de-arenas/
          </div>
        </aside>
      </div>

  </article>

</Layout>

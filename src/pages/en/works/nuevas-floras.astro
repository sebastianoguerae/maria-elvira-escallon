---
import Layout from '../../../components/layout/Layout.astro';
import QuoteBlock from '../../../components/content/QuoteBlock.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Nuevas Floras';

// Colombia (root)
const col01 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-01.webp')).default;
const col02 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-02.webp')).default;
const col03 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-03.webp')).default;
const col04 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-04.webp')).default;
const col05 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-05.webp')).default;
const col06 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-06.webp')).default;
const col08 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-08.webp')).default;
const col09 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-09.webp')).default;
const col10 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-10.webp')).default;
const col11 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-11.webp')).default;
const col12 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-12.webp')).default;
const col13 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-13.webp')).default;
// Bristol
const bristol01 = (await import('../../../assets/images/obras/nuevas-floras/bristol/bristol-01.webp')).default;
// Do Sul
const doSul01 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-01.webp')).default;
const doSul02 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-02.webp')).default;
const doSul03 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-03.webp')).default;
const doSul04 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-04.webp')).default;
const doSul05 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-05.webp')).default;
const doSul06 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-06.webp')).default;
const doSul07 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-07.webp')).default;
// Versalles
const versalles01 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-01.webp')).default;
const versalles02 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-02.webp')).default;
const versalles03 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-03.webp')).default;
const versalles04 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-04.webp')).default;
const versalles05 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-05.webp')).default;
---

<Layout
  lang={lang}
  title="Nuevas Floras — Work"
  description="Nuevas Floras (2003). Sculptural intervention on living native trees. III Luis Caballero Prize. Maria Elvira Escallon."
>

  <ArtworkSchema
    title="Nuevas Floras"
    year="2003"
    medium="Sculptural intervention on living native trees, chromogenic photograph"
    dimensions="120 x 80 cm (photographs)"
    description="Intervention on living native trees with baroque carvings. III Luis Caballero Prize, Galeria Santa Fe, Bogota."
    url="https://mariaelviraescallon.com/en/works/nuevas-floras/"
    collections={["Banco de la Republica, Bogota", "ESCALA, University of Essex, UK", "Seguros Bolivar Collection"]}
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 005</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2003 &nbsp;/&nbsp; Sculptural intervention on living native trees &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Gallery -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">COLOMBIA</h3>
        <img src={col01.src} alt="Nuevas Floras Colombia — Native tree with baroque carving" loading="eager">
        <img src={col02.src} alt="Nuevas Floras Colombia — Sculptural intervention on trunk" loading="lazy">
        <img src={col03.src} alt="Nuevas Floras Colombia — Detail of carved Solomonic column" loading="lazy">
        <img src={col04.src} alt="Nuevas Floras Colombia — Ornamental prosthesis on living tree" loading="lazy">
        <img src={col05.src} alt="Nuevas Floras Colombia — Baroque volute on bark" loading="lazy">
        <img src={col06.src} alt="Nuevas Floras Colombia — Altarpiece element on branch" loading="lazy">
        <img src={col08.src} alt="Nuevas Floras Colombia — Tree absorbing the intervention" loading="lazy">
        <img src={col09.src} alt="Nuevas Floras Colombia — Chromogenic photographic record" loading="lazy">
        <img src={col10.src} alt="Nuevas Floras Colombia — Carving almost imperceptible due to growth" loading="lazy">
        <img src={col11.src} alt="Nuevas Floras Colombia — Convergence of nature and culture" loading="lazy">
        <img src={col12.src} alt="Nuevas Floras Colombia — Detail of arboreal intervention" loading="lazy">
        <img src={col13.src} alt="Nuevas Floras Colombia — Ensemble view of the series" loading="lazy">

        <h3 style="margin-top: var(--s3);">BRISTOL</h3>
        <img src={bristol01.src} alt="Nuevas Floras Bristol — Intervention on tree in Bristol" loading="lazy">

        <h3 style="margin-top: var(--s3);">DO SUL</h3>
        <img src={doSul01.src} alt="Nuevas Floras do Sul — Intervened tree in Brazil" loading="lazy">
        <img src={doSul02.src} alt="Nuevas Floras do Sul — Detail of carving on trunk" loading="lazy">
        <img src={doSul03.src} alt="Nuevas Floras do Sul — Ornamental form on bark" loading="lazy">
        <img src={doSul04.src} alt="Nuevas Floras do Sul — Sculptural intervention" loading="lazy">
        <img src={doSul05.src} alt="Nuevas Floras do Sul — Record of tree growth" loading="lazy">
        <img src={doSul06.src} alt="Nuevas Floras do Sul — Detail of organic process" loading="lazy">
        <img src={doSul07.src} alt="Nuevas Floras do Sul — View of the complete series" loading="lazy">

        <h3 style="margin-top: var(--s3);">VERSALLES</h3>
        <img src={versalles01.src} alt="Nuevas Floras Versalles — Intervened tree in Versailles" loading="lazy">
        <img src={versalles02.src} alt="Nuevas Floras Versalles — Ornamental carving on trunk" loading="lazy">
        <img src={versalles03.src} alt="Nuevas Floras Versalles — Detail of intervention" loading="lazy">
        <img src={versalles04.src} alt="Nuevas Floras Versalles — Baroque form in living tree" loading="lazy">
        <img src={versalles05.src} alt="Nuevas Floras Versalles — Ensemble view" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Nuevas Floras is a series of interventions in the landscape, carried out on some trees of native forests in the mountains near Bogota, belonging to the Central Cordillera. Carved pieces made from their own wood have been applied to these trees, or parts of some of their branches or trunks have been carved.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            A master carver participated in the project, carrying out the carving work on the 7 trees, following models provided by the artist that come from colonial and baroque furniture and architecture.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Nuevas Floras is composed of seven large-format color photographs (80 x 120 cm) taken immediately after the carving process was completed. The project aims to follow over time how each of the trees will process these interventions. Therefore, these photographs represent the first stage of a living process in continuous change.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            From 2004 onward, Nuevas Floras became a nomadic project that responds to the specificities of the relationship between culture and nature particular to each place.
          </p>

          <QuoteBlock
            annotation="Curatorial text — Jose Roca (original in Spanish)"
            quote="La obra de Escallon se encamina a perturbar la naturalidad de ese orden. <em>Nuevas Floras</em> posee dos aspectos fundamentales: su caracter nomada — porque la idea de la que parte puede desarrollarse en otros espacios — y el concepto de temporalidad — porque su duracion es indefinida."
            cite="Jose Roca — Columna de Arena 53, August 2003"
          />
          <p style="margin-top: var(--s1); font-size: 0.75rem; color: var(--ink-light); font-style: italic;">
            [Translation: Escallon's work aims to disturb the naturalness of that order. <em>Nuevas Floras</em> possesses two fundamental aspects: its nomadic character — because the idea from which it departs can be developed in other spaces — and the concept of temporality — because its duration is indefinite.]
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            In 2003, Escallon won the First Prize of the III Luis Caballero Competition
            with this project, presented at the Galeria Santa Fe in Bogota. The jury,
            composed of curator Jose Roca among others, highlighted the way in which
            the work questions the boundaries between the natural and the cultural — a
            constant in the artist's trajectory.
          </p>

          <h3 style="margin-top: var(--s4);">RELATED WORKS</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/en/works/nuevas-floras-versalles/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Nuevas Floras Versalles (2017)</a>
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Nuevas Floras</strong><br>
            2003<br><br>
            Sculptural intervention on living native trees.
            Wood carving, prostheses.<br>
            Documentation: chromogenic photograph.<br><br>
            120 x 80 cm (photographs)<br>
            Edition of 5<br>
            Variable dimensions (interventions)
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            III Luis Caballero Prize — First prize<br>
            Galeria Santa Fe, Bogota, 2003
          </div>

          <h4 style="margin-top: var(--s3);">COLLECTIONS</h4>
          <div class="ficha">
            Banco de la Republica, Bogota<br>
            ESCALA, University of Essex, UK<br>
            Seguros Bolivar Collection
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/es/textos/jose-roca-columna-arena-53/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Jose Roca, Columna de Arena 53 (2003)
            </a>
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

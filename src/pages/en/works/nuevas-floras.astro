---
import Layout from '../../../components/layout/Layout.astro';
import QuoteBlock from '../../../components/content/QuoteBlock.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Nuevas Floras';

// Colombia (root)
const rootNums = ['01','02','03','04','05','06','08','09','10','11','12','13'];
const imgsRoot = await Promise.all(
  rootNums.map(n => import(`../../../assets/images/obras/nuevas-floras/nuevas-floras-${n}.webp`))
).then(m => m.map(x => x.default));
// Bristol
const imgBristol = (await import('../../../assets/images/obras/nuevas-floras/bristol/bristol-01.webp')).default;
// Do Sul
const imgsDoSul = await Promise.all(
  Array.from({ length: 7 }, (_, i) =>
    import(`../../../assets/images/obras/nuevas-floras/do-sul/do-sul-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// Versalles
const imgsVersalles = await Promise.all(
  Array.from({ length: 5 }, (_, i) =>
    import(`../../../assets/images/obras/nuevas-floras/versalles/versalles-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
---

<Layout
  lang={lang}
  title="Nuevas Floras — Work"
  description="Nuevas Floras (2003). Sculptural intervention on living native trees. III Luis Caballero Prize. Maria Elvira Escallon."
>

  <ArtworkSchema
    title="Nuevas Floras"
    year="2003"
    medium="Sculptural intervention on living native trees, chromogenic photograph"
    dimensions="120 × 80 cm (photographs)"
    description="Intervention on living native trees with baroque carvings. III Luis Caballero Prize, Galeria Santa Fe, Bogota."
    url="https://mariaelviraescallon.com/en/works/nuevas-floras/"
    collections={["Banco de la Republica, Bogota", "ESCALA, University of Essex, UK", "Seguros Bolivar Collection"]}
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 005</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2003 &nbsp;/&nbsp; Sculptural intervention on living native trees &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Gallery: Colombia -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">COLOMBIA</h3>
        {imgsRoot.map((img, i) => (
          <img src={img.src} alt={`Nuevas Floras Colombia — Image ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'}>
        ))}
      </div>

      <!-- Gallery: Bristol -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">BRISTOL</h3>
        <img src={imgBristol.src} alt="Nuevas Floras Bristol — Intervention on tree" loading="lazy">
      </div>

      <!-- Gallery: Do Sul -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">DO SUL</h3>
        {imgsDoSul.map((img, i) => (
          <img src={img.src} alt={`Nuevas Floras do Sul — Image ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Gallery: Versalles -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">VERSALLES</h3>
        {imgsVersalles.map((img, i) => (
          <img src={img.src} alt={`Nuevas Floras Versalles — Image ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            In <em>Nuevas Floras</em> the artist intervenes on living native trees with carvings
            or prostheses of forms generally evocative of classical architecture and common elements
            in baroque church altars. Based on prior research, Escallon determined how to proceed
            without causing collateral damage, and the carved fragments were executed by experts.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            In a second moment, the arboreal beings respond to the action by interrupting the
            intervention, until making it almost imperceptible. Her practice creates a space where
            the "wild" and the managed converge in time, where nature and culture are inextricably
            bound. The artist continues photographing these trees as they grow, making them active
            participants in the work.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            <em>Nuevas Floras</em> is presented as a series of large-format chromogenic photographs
            (120 x 80 cm) taken immediately after completing the intervention. The carvings made on
            the trees evoke forms from the Colombian colonial ornamental repertoire — Solomonic
            columns, volutes, elements of baroque altarpieces — creating a tension between the
            imposed cultural history and the organic response of the living being that absorbs and
            transforms it.
          </p>

          <QuoteBlock
            annotation="Curatorial text — Jose Roca (original in Spanish)"
            quote="La obra de Escallon se encamina a perturbar la naturalidad de ese orden. <em>Nuevas Floras</em> posee dos aspectos fundamentales: su caracter nomada — porque la idea de la que parte puede desarrollarse en otros espacios — y el concepto de temporalidad — porque su duracion es indefinida."
            cite="Jose Roca — Columna de Arena 53, August 2003"
          />
          <p style="margin-top: var(--s1); font-size: 0.75rem; color: var(--ink-light); font-style: italic;">
            [Translation: Escallon's work aims to disturb the naturalness of that order. <em>Nuevas Floras</em> possesses two fundamental aspects: its nomadic character — because the idea from which it departs can be developed in other spaces — and the concept of temporality — because its duration is indefinite.]
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            In 2003, Escallon won the First Prize of the III Luis Caballero Competition
            with this project, presented at the Galeria Santa Fe in Bogota. The jury,
            composed of curator Jose Roca among others, highlighted the way in which
            the work questions the boundaries between the natural and the cultural — a
            constant in the artist's trajectory.
          </p>

          <h3 style="margin-top: var(--s4);">RELATED WORKS</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/en/works/nuevas-floras-versalles/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Nuevas Floras Versalles (2017)</a>
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Nuevas Floras</strong><br>
            2003<br><br>
            Sculptural intervention on living native trees.
            Wood carving, prostheses.<br>
            Documentation: chromogenic photograph.<br><br>
            120 × 80 cm (photographs)<br>
            Edition of 5<br>
            Variable dimensions (interventions)
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            III Luis Caballero Prize — First prize<br>
            Galeria Santa Fe, Bogota, 2003
          </div>

          <h4 style="margin-top: var(--s3);">COLLECTIONS</h4>
          <div class="ficha">
            Banco de la Republica, Bogota<br>
            ESCALA, University of Essex, UK<br>
            Seguros Bolivar Collection
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/es/textos/jose-roca-columna-arena-53/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Jose Roca, Columna de Arena 53 (2003)
            </a>
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

---
import { Image } from 'astro:assets';
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Nuevas Floras';

// Colombia (root)
const col01 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-01.webp')).default;
const col03 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-03.webp')).default;
const col05 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-05.webp')).default;
const col09 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-09.webp')).default;
const col11 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-11.webp')).default;
const col12 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-12.webp')).default;
const col13 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-13.webp')).default;
// Follow-up records (cropped from the composite pages)
const seg01 = (await import('../../../assets/images/obras/nuevas-floras/seguimiento-01.webp')).default;
const seg03 = (await import('../../../assets/images/obras/nuevas-floras/seguimiento-03.webp')).default;
const seg05 = (await import('../../../assets/images/obras/nuevas-floras/seguimiento-05.webp')).default;
const seg09 = (await import('../../../assets/images/obras/nuevas-floras/seguimiento-09.webp')).default;
const seg13 = (await import('../../../assets/images/obras/nuevas-floras/seguimiento-13.webp')).default;
// Bristol
const bristol01 = (await import('../../../assets/images/obras/nuevas-floras/bristol/bristol-01.webp')).default;
// Do Sul
const doSul01 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-01.webp')).default;
const doSul02 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-02.webp')).default;
const doSul03 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-03.webp')).default;
const doSul04 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-04.webp')).default;
const doSul05 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-05.webp')).default;
const doSul06 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-06.webp')).default;
// Versalles
const versalles01 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-01.webp')).default;
const versalles04 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-04.webp')).default;
const versalles05 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-05.webp')).default;
---

<Layout
  lang={lang}
  title="Nuevas Floras — Work"
  description="Nuevas Floras (2003). Sculptural intervention on living native trees. III Luis Caballero Prize. Maria Elvira Escallon."
  ogImage={col01.src}
>

  <ArtworkSchema
    title="Nuevas Floras"
    year="2003"
    medium="Sculptural intervention on living native trees, chromogenic photograph"
    dimensions="120 x 80 cm (photographs)"
    description="Intervention on living native trees with baroque carvings. III Luis Caballero Prize, Galeria Santa Fe, Bogota."
    url="https://mariaelviraescallon.org/en/works/nuevas-floras/"
    collections={["Banco de la Republica, Bogota", "ESCALA, University of Essex, UK", "Seguros Bolivar Collection"]}
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 005</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2003 &nbsp;/&nbsp; Sculptural intervention on living native trees &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Gallery + texts per section -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">COLOMBIA</h3>
        <Image src={col01} alt="Nuevas floras — intervention on a mano de oso, La Calera" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seg01} alt="Follow-up record, 2004–2020 — mano de oso" loading="lazy" widths={[400, 800]} sizes="(max-width: 768px) 60vw, 660px" class="img-medium" />
        <Image src={col03} alt="Nuevas floras — intervention on a guayabo sabanero, La Calera" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seg03} alt="Follow-up record, 2004–2020 — guayabo sabanero" loading="lazy" widths={[400, 800]} sizes="(max-width: 768px) 60vw, 660px" class="img-medium" />
        <Image src={col05} alt="Nuevas floras — intervention on a tuno esmeraldo, La Calera" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seg05} alt="Follow-up record, 2004–2020 — tuno esmeraldo" loading="lazy" widths={[400, 800]} sizes="(max-width: 768px) 60vw, 660px" class="img-medium" />
        <Image src={col13} alt="Nuevas floras — intervention on an amarillo, La Calera" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seg13} alt="Follow-up record, 2004–2020 — amarillo" loading="lazy" widths={[400, 800]} sizes="(max-width: 768px) 60vw, 660px" class="img-medium" />
        <Image src={col09} alt="Nuevas floras — intervention on a raque, La Calera" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seg09} alt="Follow-up record, 2004–2020 — raque" loading="lazy" widths={[400, 800]} sizes="(max-width: 768px) 60vw, 660px" class="img-medium" />
        <Image src={col11} alt="Nuevas floras — the cube, carving on a stump" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={col12} alt="Nuevas floras — the cube, carving on the trunk" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <div class="work-page__text" style="margin: var(--s4) 0;">
          <p class="curatorial">
            Nuevas Floras is a series of interventions in the landscape, carried out on some trees of native forests in the mountains near Bogota, belonging to the Central Cordillera. Carved pieces made from their own wood have been applied to these trees, or parts of some of their branches or trunks have been carved.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            A master carver participated in the project, carrying out the carving work on the 7 trees, following models provided by the artist that come from colonial and baroque furniture and architecture.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            Nuevas Floras is composed of seven large-format color photographs (80 x 120 cm) taken immediately after the carving process was completed. The project aims to follow over time how each of the trees will process these interventions. Therefore, these photographs represent the first stage of a living process in continuous change.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            From 2004 onward, Nuevas Floras became a nomadic project that responds to the specificities of the relationship between culture and nature particular to each place.
          </p>
        </div>

        <h3 style="margin-top: var(--s3);">NUEVAS FLORAS BRISTOL</h3>
        <Image src={bristol01} alt="Nuevas Floras Bristol — intervention on the branch of a sycamore, Ashton Court" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <div class="work-page__text" style="margin: var(--s4) 0;">
          <p class="curatorial">
            The Nuevas Floras project, in its nomadic phase, was first developed in the United Kingdom, with the help of an art restorer, R. Peploe. On that occasion, the branch of a Sycamore was intervened in Ashton Court Estate Park (Bristol). This park is a representative example of what is known as “the English natural landscape.” It was carried out in the context of a Visiting Arts artistic residency at Spike Island, Bristol, during 2004 and 2005.
          </p>
        </div>

        <h3 style="margin-top: var(--s3);">NUEVAS FLORAS DO SUL</h3>
        <Image src={doSul01} alt="Nuevas Floras do Sul — San Isidro, VIII Mercosul Biennial" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={doSul02} alt="Nuevas Floras do Sul — carving on a native tree" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={doSul03} alt="Nuevas Floras do Sul — diptych of the temple" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={doSul04} alt="Nuevas Floras do Sul — diptych and list of endemic species" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={doSul05} alt="Nuevas Floras do Sul — Navigations over Rio Grande, satellite photograph" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={doSul06} alt="Nuevas Floras do Sul — Navigations over Rio Grande, islands of native flora" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <div class="work-page__text" style="margin: var(--s4) 0;">
          <p class="curatorial">
            In 2011 the Nuevas Floras project was invited to the VIII Mercosul Biennial to carry out an intervention at one of the sites of the old Missions that the Jesuits created to evangelize the Guarani indigenous people, in southern Brazil. The work, carried out in the National Historic Park of São Miguel das Missões, responds to the direct experience of the landscape of the area and of the statuary pieces found in the Museum.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            The landscape along the road to San Miguel is dominated by enormous monocultures of soy and millet. From time to time, small still-surviving islands of native flora come into view, resembling an oasis. Visiting them, I found gathered within a few square meters trees and plants of a wide variety of species that once populated those lands. I clearly felt agriculture to be the great shaper of the landscape.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            These “islands” are preserved by a decree of the Brazilian government to protect the migrations of birds that would otherwise find no rest on their journey.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            Fallen branches of some native trees and a tree that had already dried up were intervened with carvings alluding to the architecture of the temple and to the statuary of the Museum — in particular, to the figure of San Isidro Labrador, patron saint of agriculture. The original posture of the saint, who looks toward the sky in a gesture connoting strength and confidence, was modified and placed in relation to the current landscape of the area.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            The series is complemented by a satellite exploration of the road from Porto Alegre to São Miguel das Missões, in search of islands of native flora that have survived the monocultures. The series “Camino de San Miguel” and “Navegaciones sobre Rio Grande” present these images.
          </p>
          <p class="ficha" style="margin-top: var(--s2); color: var(--ash);">
            (*) Several trees of the intervened species were planted in the park.
          </p>
        </div>

        <h3 style="margin-top: var(--s3);">NUEVAS FLORAS VERSALLES</h3>
        <Image src={versalles01} alt="Nuevas Floras Versalles — exhibition in the Tuileries Garden, Paris" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={versalles04} alt="Nuevas Floras Versalles — detail of the carving on white chestnut" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={versalles05} alt="Nuevas Floras Versalles — Astronomical Clock of Louis XV, Palace of Versailles" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <div class="work-page__text" style="margin: var(--s4) 0;">
          <p class="curatorial">
            Nuevas Floras Versalles was carried out in 2017 on a botanical estate called the Arboretum de Chevreloup, which once formed part of the Gardens of the Palace of Versailles as a hunting ground and is now a vast collection of trees from all over the world, belonging to the Natural History Museum of France. The invitation took place within the framework of the Colombia-France year.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            The carving was carried out on two large branches of a white chestnut that had torn away from the trunk due to an ailment of the tree.
          </p>
          <p class="curatorial" style="margin-top: var(--s2);">
            The Gardens of Versailles respond emblematically to the conception of nature proposed by the French baroque garden. Man controls and believes he directs nature according to the aesthetic parameters of the era. The design was chosen from among the decorative elements of the Palace of Versailles and takes the form of the hour hand of Louis XV's Astronomical Clock.
          </p>
        </div>
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <h3 style="margin-top: var(--s4);">RELATED WORKS</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/es/exposiciones/nuevas-floras-versalles-2017/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Nuevas Floras Versalles (2017)</a>
            </li>
          </ul>

        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Nuevas Floras</strong><br>
            2003<br><br>
            Sculptural intervention on living native trees.
            Wood carving, prostheses.<br>
            Documentation: chromogenic photograph.<br><br>
            120 x 80 cm (photographs)<br>
            Edition of 5<br>
            Variable dimensions (interventions)
          </div>

          <h4 style="margin-top: var(--s3);">COLLECTIONS</h4>
          <div class="ficha">
            Banco de la Republica, Bogota<br>
            ESCALA, University of Essex, UK<br>
            Seguros Bolivar Collection
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/es/textos/jose-roca-columna-arena-53/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Jose Roca, Columna de Arena 53 (2003)
            </a>
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  :global(.img-medium) { max-width: 55%; }
  @media (max-width: 768px) {
    :global(.img-medium) { max-width: 80%; }
  }
</style>

const mesa20 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-20.webp')).default;
const mesa21 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-21.webp')).default;
const mesa22 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-22.webp')).default;
const mesa23 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-23.webp')).default;

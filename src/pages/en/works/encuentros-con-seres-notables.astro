---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Encuentros con seres notables';

const img1 = (await import('../../../assets/images/obras/encuentros-seres/encuentros-01.jpg')).default;
---

<Layout
  lang={lang}
  title="Encuentros con seres notables — Work"
  description="Encuentros con seres notables (2022). Sculpture — savanna jasmine branches, eucalyptus, wood carving, clay. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Encuentros con seres notables"
    year="2022"
    medium="Sculpture, carved branches"
    description="Sculptures carved from branches that explore the relationship between the human body and the vegetal."
    url="https://mariaelviraescallon.com/en/works/encuentros-con-seres-notables/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 011</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022 &nbsp;/&nbsp; Sculpture — savanna jasmine branches, eucalyptus, wood carving, clay &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Encuentros con seres notables — Hands extracting a face from the wall" loading="eager">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Encuentros con seres notables · Full video · 2:00 min</span>
        </div>
        <video controls preload="metadata" poster="">
          <source src="/maria-elvira-escallon/video/encuentros-obra.mp4" type="video/mp4">
          Your browser does not support HTML5 video.
        </video>
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            The title is inspired by the book by the Russian mystic George Gurdjieff,
            "Meetings with Remarkable Men," reimagined to celebrate connections with nature. The
            exhibition explores the kinship between human beings and other living beings — trees
            and plants — highlighting sensitive aspects that reveal great similarities among living beings.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Escallon discovered branches in the forest that resemble human skeletal anatomy:
            femurs, humeri, scapulae, radii and ulnae, phalanges. Through careful carving,
            she revealed forms where "their two branches stretch out their fingers trying to touch
            each other," creating visual echoes of Michelangelo's Creation scene.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The exhibition includes sculptures made from carved branches that resemble human bones,
            suggesting a structural correspondence between plant and animal organisms. The
            materials include sand, clay in various states (fresh and fired), and pieces
            shaped by water and sea sand.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            Escallon researched hybrids between nature and humans in art history,
            finding that hybrids between humans and plants are scarce — the mandrake,
            Daphne, Tolkien's Ents. This scarcity motivated a deep exploration of the
            structural correspondences between the vegetal and the animal, revealing kinships
            that normally go unnoticed.
          </p>

          <h3 style="margin-top: var(--s4);">INCLUDED PIECES</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Brazo</strong> — 2022. Fresh clay, 10 × 60 × 12 cm. Hands modeling an arm that connects to a frailejón.
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Desclavada</strong> — 2022. Sculpture.
            </li>
            <li style="padding: var(--s1) 0;">
              <strong>Carved branch sculptures</strong> — Savanna jasmine and eucalyptus branches carved to resemble human bones.
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Encuentros con seres notables</strong><br>
            2022<br><br>
            Sculpture — savanna jasmine branches, eucalyptus, wood carving, clay.<br><br>
            Variable dimensions<br>
            Galeria Espacio Continuo, Bogota
          </div>

          <h4 style="margin-top: var(--s3);">CURATORSHIP</h4>
          <div class="ficha">
            Ana Maria Lozano Rocha
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Encuentros con seres notables — Galeria Espacio Continuo, Bogota, 2022
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2022). <em>Encuentros con seres notables</em>.
            Sculpture. Available at:
            mariaelviraescallon.com/en/works/encuentros-con-seres-notables/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

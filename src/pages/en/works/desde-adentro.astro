---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Desde Adentro';

const img01 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-01.webp')).default;
const img02 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-02.webp')).default;
const img03 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-03.webp')).default;
const img04 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-04.webp')).default;
const img05 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-05.webp')).default;
const img06 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-06.webp')).default;
const img07 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-07.webp')).default;
const img08 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-08.webp')).default;
const img09 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-09.webp')).default;
const img10 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-10.webp')).default;
const img11 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-11.webp')).default;
const img12 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-12.webp')).default;
const img13 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-13.webp')).default;
const img14 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-14.webp')).default;
---

<Layout
  lang={lang}
  title="Desde Adentro — Work"
  description="Desde Adentro (2003). 12 C-type photographs, 12-hour video installation. Documentation of the Club El Nogal attack. Maria Elvira Escallon."
>

  <ArtworkSchema
    title="Desde Adentro"
    year="2003"
    medium="12 C-type photographs, 12-hour video installation"
    dimensions="89 x 123 cm (photographs), edition of 5"
    description="Photographic and video documentation of the aftermath of the attack on Club El Nogal, Bogota. The traces of absent people and missing objects transport the viewer to lived moments."
    url="https://mariaelviraescallon.com/en/works/desde-adentro/"
    collections={["Art Gallery of New South Wales, Sydney", "Banco de la Republica, Bogota"]}
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 004</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2003 &nbsp;/&nbsp; 12 C-type photographs, 12-hour video installation &nbsp;/&nbsp; 89 x 123 cm (photographs), edition of 5</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img01.src} alt="Desde Adentro — Trace on surface after the attack" loading="eager">
        <img src={img02.src} alt="Desde Adentro — Trace of absence on wall" loading="lazy">
        <img src={img03.src} alt="Desde Adentro — Silhouette of volatilized object" loading="lazy">
        <img src={img04.src} alt="Desde Adentro — Handprint on ash" loading="lazy">
        <img src={img05.src} alt="Desde Adentro — Outline of removed painting" loading="lazy">
        <img src={img06.src} alt="Desde Adentro — Door covered in ash film" loading="lazy">
        <img src={img07.src} alt="Desde Adentro — Devastated staircase" loading="lazy">
        <img src={img08.src} alt="Desde Adentro — Record of interior destruction" loading="lazy">
        <img src={img09.src} alt="Desde Adentro — Detail of ash-covered surface" loading="lazy">
        <img src={img10.src} alt="Desde Adentro — Devastated space of Club El Nogal" loading="lazy">
        <img src={img11.src} alt="Desde Adentro — Vestige of human presence" loading="lazy">
        <img src={img12.src} alt="Desde Adentro — Everyday object after the explosion" loading="lazy">
        <img src={img13.src} alt="Desde Adentro — Documentation of aftermath" loading="lazy">
        <img src={img14.src} alt="Desde Adentro — Final record of the series" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Series of photographs and video captured a few days after the attack on Club El Nogal on February 7, 2003, in which 39 people died and hundreds were injured. The artist was working at this institution at the time of the events.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            A few days after the attack of February 7, 2003, as the person responsible for the artistic heritage of Club El Nogal, I had to enter its premises to verify the condition of the artworks. What I saw during that visit will remain in my memory forever. As I carried out this task, I knew it was necessary to keep a record of what I found around me.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The building had been sealed off by the authorities until that moment. Everything was in the state it had been left in after the impact, as if after it, time had stopped. On the lower floors the darkness was total due to the electrical collapse, and a black veil of soot caused by the fire covered the walls and objects.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Desde Adentro arises from that experience. It seeks to approach what happened by capturing the atmosphere of what was lived there through the recording of a series of signs and traces that I found in different places, imprinted on dust and soot.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Most of the photographs were taken three days after the attack. Others, a week later when the removal of debris began, the moment when the video was also made: a record of 12 continuous hours of filming, from a fixed shot, from dawn until the end of the day.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            This document was captured while I was working at this institution. Made from a personal proximity to the events and the people, it constitutes a memory and a different perspective from the press versions, which were basically centered on the destruction, the material loss, and the identification of the culprits.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            This work is dedicated to all the people who were in the building on the night of February 7.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Desde Adentro</strong><br>
            2003<br><br>
            12 C-type photographs.<br>
            12-hour video installation.<br><br>
            89 x 123 cm (photographs)<br>
            Edition of 5<br><br>
            Club El Nogal, Bogota.
          </div>

          <h4 style="margin-top: var(--s3);">COLLECTIONS</h4>
          <div class="ficha">
            Art Gallery of New South Wales, Sydney<br>
            Banco de la Republica, Bogota
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Art Gallery of New South Wales, Sydney<br>
            Banco de la Republica, Bogota
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/en/texts/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Related texts
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2003). <em>Desde Adentro</em>.
            Photography and video installation. Available at:
            mariaelviraescallon.com/en/works/desde-adentro/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

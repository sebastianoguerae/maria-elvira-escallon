---
import Layout from '../../../components/layout/Layout.astro';

const lang = 'en' as const;

const imgInVitro = (await import('../../../assets/images/obras/in-vitro/in-vitro-01.jpg')).default;
const imgDesdeAdentro = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-01.jpg')).default;
const imgNuevasFloras = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-01.jpg')).default;
const imgInMemoriam = (await import('../../../assets/images/obras/in-memoriam/in-memoriam-01.jpg')).default;
const imgPrecipitacion = (await import('../../../assets/images/obras/precipitacion/precipitacion-mamu-2024.jpg')).default;
const imgElReino = (await import('../../../assets/images/obras/el-reino/el-reino-01.jpg')).default;
const imgComa = (await import('../../../assets/images/obras/en-estado-de-coma/coma-hospital-01.jpg')).default;
const imgAerolito = (await import('../../../assets/images/obras/aerolito/aerolito-ilustracion.jpg')).default;
const imgEncuentros = (await import('../../../assets/images/obras/encuentros-seres/encuentros-01.jpg')).default;
const imgPolvo = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-01.jpg')).default;
const imgCaminantes = (await import('../../../assets/images/obras/las-caminantes/caminantes-mamu-01.jpg')).default;
const imgDispositivos = (await import('../../../assets/images/obras/dispositivos/dispositivos-01.jpg')).default;
const imgFertilSuelo = (await import('../../../assets/images/obras/fertil-suelo/fertil-suelo-01.jpg')).default;

const works = [
  {
    num: '001',
    slug: 'in-vitro',
    title: 'In Vitro',
    year: '1997',
    description: 'Installation, mirror — Estacion de La Sabana',
    hasImage: true,
    image: imgInVitro,
  },
  {
    num: '002',
    slug: 'el-reino-de-este-mundo',
    title: 'El reino de este mundo',
    year: '2000',
    description: 'Installation, concrete — MAMBO',
    hasImage: true,
    image: imgElReino,
  },
  {
    num: '003',
    slug: 'in-memoriam',
    title: 'In Memoriam',
    year: '2001',
    description: 'Ephemeral sculpture, ice — Alianza Colombo Francesa',
    hasImage: true,
    image: imgInMemoriam,
  },
  {
    num: '004',
    slug: 'desde-adentro',
    title: 'Desde Adentro',
    year: '2003',
    description: '12 photographs, video — Club El Nogal',
    hasImage: true,
    image: imgDesdeAdentro,
  },
  {
    num: '005',
    slug: 'nuevas-floras',
    title: 'Nuevas Floras',
    year: '2003',
    description: 'Sculptural intervention on native trees — III Premio Luis Caballero',
    hasImage: true,
    image: imgNuevasFloras,
  },
  {
    num: '005b',
    slug: 'nuevas-floras-versalles',
    title: 'Nuevas Floras Versalles',
    year: '2017',
    description: 'Sculptural intervention — Arboretum de Chevreloup / FIAC, France',
    hasImage: false,
    image: null,
  },
  {
    num: '006',
    slug: 'en-estado-de-coma',
    title: 'En estado de coma',
    year: '2005–2007',
    description: 'Photography, video, installation — Hospital San Juan de Dios',
    hasImage: true,
    image: imgComa,
  },
  {
    num: '007',
    slug: 'aerolito',
    title: 'Pequeno Museo del Aerolito',
    year: '2014–2015',
    description: 'Research, installation — Museo Nacional',
    hasImage: true,
    image: imgAerolito,
  },
  {
    num: '008',
    slug: 'en-el-fertil-suelo',
    title: 'En el fertil suelo',
    year: '2017–2018',
    description: 'Video, sculpture — X Premio Luis Caballero',
    hasImage: true,
    image: imgFertilSuelo,
  },
  {
    num: '009',
    slug: 'dispositivos-para-ver-pasar-el-tiempo',
    title: 'Dispositivos para ver pasar el tiempo',
    year: '2020',
    description: 'Installation',
    hasImage: true,
    image: imgDispositivos,
  },
  {
    num: '010',
    slug: 'precipitacion-de-arenas',
    title: 'Precipitacion de arenas',
    year: '2024',
    description: 'Installation — MAMU',
    hasImage: true,
    image: imgPrecipitacion,
  },
  {
    num: '011',
    slug: 'encuentros-con-seres-notables',
    title: 'Encuentros con seres notables',
    year: '2022',
    description: 'Sculpture, carved branches — Galeria Espacio Continuo',
    hasImage: true,
    image: imgEncuentros,
  },
  {
    num: '012',
    slug: 'polvo-eres',
    title: 'Polvo eres',
    year: '2024',
    description: 'Wall carving — MAMU, Bogota',
    hasImage: true,
    image: imgPolvo,
  },
  {
    num: '013',
    slug: 'las-caminantes',
    title: 'Las caminantes',
    year: '2024',
    description: 'Living installation, Morse code — MAMU, Bogota',
    hasImage: true,
    image: imgCaminantes,
  },
  {
    num: '014',
    slug: 'ensayo-autorretrato',
    title: 'Ensayo autorretrato',
    year: '2022',
    description: 'Video — Galeria Espacio Continuo',
    hasImage: false,
    image: null,
  },
];
---

<Layout lang={lang} title="Works" description="Complete works by Maria Elvira Escallon. Project catalogue 1997–2024. Sculpture, installation, photography and video.">

  <div class="obra-index">
    <div class="container">

      <!-- Header -->
      <header class="section__header">
        <h1>Complete Works</h1>
        <span class="label">1997–2024</span>
      </header>

      <!-- Works list -->
      <div class="works-catalog">
        {works.map((work) => (
          <a href={`/maria-elvira-escallon/en/works/${work.slug}/`} class="work-entry-link" style="text-decoration:none; color:inherit;">
            <div class="work-entry">
              <div class="work-entry__num">{work.num}</div>
              <div class="work-entry__info">
                <h3>{work.title}</h3>
                <div class="ficha">
                  {work.year} &nbsp;/&nbsp; {work.description}
                </div>
              </div>
              <div class="work-entry__image">
                {work.hasImage && work.image ? (
                  <img
                    src={work.image.src}
                    alt={`${work.title} — Maria Elvira Escallon`}
                    loading="lazy"
                  />
                ) : (
                  <div class="placeholder-img" style="height:100%;display:flex;align-items:center;justify-content:center;color:var(--ash-light);font-family:var(--mono);font-size:0.55rem;letter-spacing:0.08em;text-transform:uppercase;">
                    [ {work.title} ]
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

</Layout>

<style>
  .obra-index {
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s5);
  }

  .works-catalog {
    margin-top: var(--s3);
  }

  .work-entry-link:last-child .work-entry {
    border-bottom: 1px solid var(--ink);
  }
</style>

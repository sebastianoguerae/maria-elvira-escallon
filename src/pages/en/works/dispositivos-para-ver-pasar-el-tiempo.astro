---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Dispositivos para ver pasar el tiempo';

const img1 = (await import('../../../assets/images/obras/dispositivos/port-176.jpg')).default;
const img2 = (await import('../../../assets/images/obras/dispositivos/port-178.jpg')).default;
const img3 = (await import('../../../assets/images/obras/dispositivos/port-180.jpg')).default;
const img4 = (await import('../../../assets/images/obras/dispositivos/port-183.jpg')).default;
const img5 = (await import('../../../assets/images/obras/dispositivos/port-186.jpg')).default;
const img6 = (await import('../../../assets/images/obras/dispositivos/port-189.jpg')).default;
const img7 = (await import('../../../assets/images/obras/dispositivos/port-192.jpg')).default;
const img8 = (await import('../../../assets/images/obras/dispositivos/port-196.jpg')).default;
---

<Layout
  lang={lang}
  title="Dispositivos para ver pasar el tiempo — Work"
  description="Dispositivos para ver pasar el tiempo (2020). Installation, sculpture. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Dispositivos para ver pasar el tiempo"
    year="2020"
    medium="Installation"
    description="Devices that make the passage of time visible through material processes."
    url="https://mariaelviraescallon.com/en/works/dispositivos-para-ver-pasar-el-tiempo/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 009</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2020 &nbsp;/&nbsp; Installation, sculpture &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Dispositivos para ver pasar el tiempo — General view of the installation" loading="eager">
        <img src={img2.src} alt="Dispositivos para ver pasar el tiempo — Detail of poetic mechanism" loading="lazy">
        <img src={img3.src} alt="Dispositivos para ver pasar el tiempo — Visible material transformation" loading="lazy">
        <img src={img4.src} alt="Dispositivos para ver pasar el tiempo — Sand accumulating on surfaces" loading="lazy">
        <img src={img5.src} alt="Dispositivos para ver pasar el tiempo — Record of wear" loading="lazy">
        <img src={img6.src} alt="Dispositivos para ver pasar el tiempo — Detail of erosion in the piece" loading="lazy">
        <img src={img7.src} alt="Dispositivos para ver pasar el tiempo — Accumulation of materials" loading="lazy">
        <img src={img8.src} alt="Dispositivos para ver pasar el tiempo — View of the work in the gallery" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Is it possible to create a device to watch time pass? This question articulates a
            series of pieces that seek to make the intangible tangible — duration, accumulation,
            wear. The artist creates poetic mechanisms that record the passage of time through
            the transformation of materials: falling sand, eroding surfaces, accumulating objects.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Each device functions as a poetic clock — it does not measure time in conventional
            units but in visible material transformations.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            This series connects conceptually with <em>Precipitacion de arenas</em> and with the
            broader axis "En la fabrica de polvo." The question "Is it possible to create a device
            to watch time pass?" became the inaugural question of the anthological exhibition
            at MAMU in 2024, articulating a reflection that runs through Escallon's entire
            trajectory: the obsession with making visible what normally escapes perception —
            time, transformation, the inevitable wear of everything that exists.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Dispositivos para ver pasar el tiempo</strong><br>
            2020<br><br>
            Installation, sculpture.<br><br>
            Variable dimensions
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2020). <em>Dispositivos para ver pasar el tiempo</em>.
            Installation, sculpture. Available at:
            mariaelviraescallon.com/en/works/dispositivos-para-ver-pasar-el-tiempo/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

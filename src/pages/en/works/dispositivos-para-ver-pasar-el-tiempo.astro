---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Dispositivos para ver pasar el tiempo';

const img01 = (await import('../../../assets/images/obras/dispositivos/dispositivos-01.webp')).default;
const img02 = (await import('../../../assets/images/obras/dispositivos/dispositivos-02.webp')).default;
const img03 = (await import('../../../assets/images/obras/dispositivos/dispositivos-03.webp')).default;
const img04 = (await import('../../../assets/images/obras/dispositivos/dispositivos-04.webp')).default;
const img05 = (await import('../../../assets/images/obras/dispositivos/dispositivos-05.webp')).default;
const img06 = (await import('../../../assets/images/obras/dispositivos/dispositivos-06.webp')).default;
const img07 = (await import('../../../assets/images/obras/dispositivos/dispositivos-07.webp')).default;
const img08 = (await import('../../../assets/images/obras/dispositivos/dispositivos-08.webp')).default;
const img10 = (await import('../../../assets/images/obras/dispositivos/dispositivos-10.webp')).default;
const img11 = (await import('../../../assets/images/obras/dispositivos/dispositivos-11.webp')).default;
const img12 = (await import('../../../assets/images/obras/dispositivos/dispositivos-12.webp')).default;
const img13 = (await import('../../../assets/images/obras/dispositivos/dispositivos-13.webp')).default;
const img14 = (await import('../../../assets/images/obras/dispositivos/dispositivos-14.webp')).default;
---

<Layout
  lang={lang}
  title="Dispositivos para ver pasar el tiempo — Work"
  description="Dispositivos para ver pasar el tiempo (2020). Installation, sculpture. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Dispositivos para ver pasar el tiempo"
    year="2020"
    medium="Installation"
    description="Devices that make the passage of time visible through material processes."
    url="https://mariaelviraescallon.com/en/works/dispositivos-para-ver-pasar-el-tiempo/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 009</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2020 &nbsp;/&nbsp; Installation, sculpture &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img01.src} alt="Dispositivos para ver pasar el tiempo — General installation view" loading="eager">
        <img src={img02.src} alt="Dispositivos para ver pasar el tiempo — Sand device" loading="lazy">
        <img src={img03.src} alt="Dispositivos para ver pasar el tiempo — Eroded surface" loading="lazy">
        <img src={img04.src} alt="Dispositivos para ver pasar el tiempo — Poetic mechanism" loading="lazy">
        <img src={img05.src} alt="Dispositivos para ver pasar el tiempo — Material accumulation" loading="lazy">
        <img src={img06.src} alt="Dispositivos para ver pasar el tiempo — Device detail" loading="lazy">
        <img src={img07.src} alt="Dispositivos para ver pasar el tiempo — Material transformation" loading="lazy">
        <img src={img08.src} alt="Dispositivos para ver pasar el tiempo — Record of wear" loading="lazy">
        <img src={img10.src} alt="Dispositivos para ver pasar el tiempo — Sculptural piece" loading="lazy">
        <img src={img11.src} alt="Dispositivos para ver pasar el tiempo — Process detail" loading="lazy">
        <img src={img12.src} alt="Dispositivos para ver pasar el tiempo — Ensemble view" loading="lazy">
        <img src={img13.src} alt="Dispositivos para ver pasar el tiempo — Temporal element" loading="lazy">
        <img src={img14.src} alt="Dispositivos para ver pasar el tiempo — Final view" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Project made during the pandemic.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            I am invited to contemplate what happens there. Somehow I know that my role is to witness everything in total stillness. I have confirmed it: it happens as in photography — if I move a little, everything blurs.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The phenomena unfold very slowly before me, almost like devices for watching time pass. Invasions of previously inert materials slowly enter the scene, strong currents of wind that seem to have a will of their own, great gestures of mourning on the wall, sunsets too intense, too long in these times when monuments fall.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            There is always more light than one expects in a house like this, even sometimes when I suddenly enter a room, it seems to me for instants — only for fractions of an instant — that it was resplendent.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Dispositivos para ver pasar el tiempo</strong><br>
            2020<br><br>
            Installation, sculpture.<br><br>
            Variable dimensions
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2020). <em>Dispositivos para ver pasar el tiempo</em>.
            Installation, sculpture. Available at:
            mariaelviraescallon.com/en/works/dispositivos-para-ver-pasar-el-tiempo/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

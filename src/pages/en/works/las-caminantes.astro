---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Las caminantes';

const img1 = (await import('../../../assets/images/obras/las-caminantes/caminantes-mamu-01.jpg')).default;
---

<Layout
  lang={lang}
  title="Las caminantes — Work"
  description="Las caminantes (2024). Living installation — weeds, plants, Morse code, speaker. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Las caminantes"
    year="2024"
    medium="Living installation, Morse code"
    description="Living plants that transmit Morse code. MAMU, Bogota."
    url="https://mariaelviraescallon.com/en/works/las-caminantes/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 013</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2024 &nbsp;/&nbsp; Living installation — weeds, plants, Morse code, speaker &nbsp;/&nbsp; Variable dimensions</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Las caminantes — Weed garden in the MAMU gallery" loading="eager">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            A weed garden that grows inside the exhibition hall, demonstrating the artist's
            intention regarding living works that are constantly transforming. The plants emit
            via Morse code a message that reads "En cada inhalacion nos encontramos."
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            This subtle yet powerful gesture invites reflection on how plant life and human
            life are part of one and the same whole, sharing times and spaces that, though
            generally imperceptible, connect us closely. The work challenges traditional
            perceptions of plant species and their relationship with us.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            <em>Las caminantes</em> is part of the "Exploring Kinships" axis of the anthological
            exhibition at MAMU (2024). The work embodies Escallon's ongoing exploration of the
            kinship between human life and plant life — a theme that runs through her entire
            artistic trajectory. The Morse code message — "En cada inhalacion nos encontramos" —
            synthesizes this fundamental connection: the oxygen that plants produce and we
            breathe as an invisible and constant bond.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Las caminantes</strong><br>
            2024<br><br>
            Living installation — weeds, plants, Morse code, speaker.<br><br>
            Variable dimensions<br>
            MAMU, Bogota
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Encuentros en la fabrica de polvo — MAMU, 2024
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2024). <em>Las caminantes</em>.
            Living installation. Available at:
            mariaelviraescallon.com/en/works/las-caminantes/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

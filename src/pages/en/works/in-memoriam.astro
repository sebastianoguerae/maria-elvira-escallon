---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'In Memoriam';

const img1 = (await import('../../../assets/images/obras/in-memoriam/in-memoriam-01.webp')).default;
const img2 = (await import('../../../assets/images/obras/in-memoriam/in-memoriam-02.webp')).default;
const img3 = (await import('../../../assets/images/obras/in-memoriam/in-memoriam-03.webp')).default;
---

<Layout
  lang={lang}
  title="In Memoriam — Work"
  description="In Memoriam (2001). Ephemeral sculpture — ice, glass, water. 300 kg, 20 hours. Alianza Colombo Francesa, Bogota. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="In Memoriam"
    year="2001"
    medium="Ephemeral sculpture, ice"
    description="Ice sculpture that gradually melted at the Alianza Colombo Francesa, Bogota."
    url="https://mariaelviraescallon.com/en/works/in-memoriam/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 003</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2001 &nbsp;/&nbsp; Ephemeral sculpture — ice, glass, water &nbsp;/&nbsp; 300 kg, duration 20 hours &nbsp;/&nbsp; Alianza Colombo Francesa, Bogota</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="In Memoriam — Doric ice column dissolving in water urn, 2001" loading="eager">
        <img src={img2.src} alt="In Memoriam — Intermediate state of the ice column dissolution" loading="lazy">
        <img src={img3.src} alt="In Memoriam — Detail of the transformation process of ice into water" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            A Doric ice column (155 x 50 x 50 cm and 300 kg) dissolves in a glass urn filled with water. The total dissolution takes 20 hours, during which the column progressively loses its golden contours, assuming unpredictable organic forms. The dissolution has an effervescent effect since the white parts we see in the ice, resembling needles, are air particles, and these are released in this process.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            In Memoriam provided the observer with the experience of witnessing the loss of solidity of a body that progressively dissolves into its own matter.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The photographic piece consists of a polyptych formed by four photographs or lightboxes, which bear witness to different moments of this dissolution.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>In Memoriam</strong><br>
            2001<br><br>
            Ephemeral sculpture.<br>
            Ice, glass, water.<br><br>
            Weight: 300 kg<br>
            Duration: 20 hours<br><br>
            Alianza Colombo Francesa, Bogota.
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Alianza Colombo Francesa, Bogota, 2001
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/en/texts/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Related texts
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2001). <em>In Memoriam</em>.
            Ephemeral sculpture. Available at:
            mariaelviraescallon.com/en/works/in-memoriam/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

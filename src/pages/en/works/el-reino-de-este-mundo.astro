---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'El reino de este mundo';

const img1 = (await import('../../../assets/images/obras/el-reino/el-reino-01.webp')).default;
const img2 = (await import('../../../assets/images/obras/el-reino/el-reino-02.webp')).default;
const img3 = (await import('../../../assets/images/obras/el-reino/el-reino-03.webp')).default;
---

<Layout
  lang={lang}
  title="El reino de este mundo — Work"
  description="El reino de este mundo (2000). Installation — concrete blocks, debris. Museo de Arte Moderno de Bogota (MAMBO). Maria Elvira Escallon."
>


  <ArtworkSchema
    title="El reino de este mundo"
    year="2000"
    medium="Installation, concrete"
    description="Concrete blocks made from the debris of a demolished house. MAMBO, Bogota."
    url="https://mariaelviraescallon.com/en/works/el-reino-de-este-mundo/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 002</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2000 &nbsp;/&nbsp; Installation — concrete blocks, debris &nbsp;/&nbsp; Museo de Arte Moderno de Bogota (MAMBO)</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="El reino de este mundo — Front view of the concrete wall with debris" loading="eager">
        <img src={img2.src} alt="El reino de este mundo — Shadow of debris on the museum floor" loading="lazy">
        <img src={img3.src} alt="El reino de este mundo — Detail of debris agglomerated in blocks" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            A wall built with concrete blocks that agglomerate debris from a demolished
            family house. The wall projects a "shadow" formed with debris scattered
            on the museum floor. Escallon focuses on reconstruction and reuse,
            weaving a narrative that highlights resilience.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            A woman named Fanny salvaged bricks from demolished buildings — human
            history is embedded in the material. The debris is not waste
            but matter charged with domestic history: fragments of walls that once
            delimited rooms, floors that sustained everyday lives, structures
            that gave shape to a home.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The "shadow" of debris on the museum floor establishes a relationship between the
            vertical wall and its horizontal projection — between construction and destruction,
            between what remains standing and what falls. The wall is simultaneously monument
            and ruin, new construction made from old destruction, the physical presence of
            domestic absence.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            The title references Alejo Carpentier's novel about Latin American magical realism
            and revolution. The work transforms domestic destruction into
            monumental presence. Carpentier coined the concept of "lo real maravilloso"
            (the marvelous real) to describe a Latin American reality that surpasses fiction —
            Escallon translates it into the language of materials: the debris of a house
            becomes the blocks of a new wall.
          </p>
          <p style="margin-top: var(--s2);">
            The work is situated at a moment of intense urban transformation in Bogota, where
            the demolition of houses and entire neighborhoods to make way for renovation
            projects produced enormous quantities of debris. The figure of Fanny — a woman
            who survived by salvaging construction materials from demolished buildings —
            embodies the informal economy of survival and the silent resistance
            against the destruction of the urban fabric.
          </p>
          <p style="margin-top: var(--s2);">
            <em>El reino de este mundo</em> establishes themes that Escallon would continue
            to explore: the relationship between destruction and memory, material heritage
            as a repository of invisibilized histories, and the capacity of materials
            to tell the stories that official narratives omit.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>El reino de este mundo</strong><br>
            2000<br><br>
            Installation.<br>
            Concrete blocks, debris.<br><br>
            Museo de Arte Moderno de Bogota (MAMBO).<br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Museo de Arte Moderno de Bogota (MAMBO), 2000
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/en/texts/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Related texts
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2000). <em>El reino de este mundo</em>.
            Installation. Available at:
            mariaelviraescallon.com/en/works/el-reino-de-este-mundo/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

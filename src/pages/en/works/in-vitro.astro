---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';
import QuoteBlock from '../../../components/content/QuoteBlock.astro';

const lang = 'en' as const;
const title = 'In Vitro';

const img1 = (await import('../../../assets/images/obras/in-vitro/in-vitro-01.webp')).default;
const img2 = (await import('../../../assets/images/obras/in-vitro/in-vitro-02.webp')).default;
---

<Layout
  lang={lang}
  title="In Vitro — Work"
  description="In Vitro (1997). Installation — mirror, glass. La Sabana Station, Bogota. 1st Prize, VIII Regional Artists' Salon. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="In Vitro"
    year="1997"
    medium="Installation, mirror"
    description="Site-specific intervention at La Sabana Station, Bogota. A 30-meter mirror that reflected the deterioration of the historic building."
    url="https://mariaelviraescallon.com/en/works/in-vitro/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 001</p>
        <h1>{title}</h1>
        <p class="work-page__meta">1997 &nbsp;/&nbsp; Installation — mirror, glass &nbsp;/&nbsp; La Sabana Station, Bogota</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="In Vitro — Mirror installation at La Sabana Station, Bogota" loading="eager">
        <img src={img2.src} alt="In Vitro — Detail of the floor and reflection in the mirror" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Installation carried out in the former La Sabana Train Station, which was abandoned at that time, like most of Colombia's railway network.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The work is the framing of a state of affairs, the state of abandonment of the building, preserving a long office corridor from the cleaning process that was being carried out to prepare it. A section of the corridor was sealed with safety glass so that the visitor could not pass through, but could peer in as if into a display case, at this panorama of a recent past.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            At the end of the 30-meter corridor, a large mirror was placed whose edges were not visible, reflecting the image of the viewer and the space behind them. Thus, the observer found themselves simultaneously situated outside and at the center of the work.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>In Vitro</strong><br>
            1997<br><br>
            Installation.<br>
            Mirror, glass.<br><br>
            La Sabana Station, Bogota.<br>
            Variable dimensions.
          </div>

          <h4 style="margin-top: var(--s3);">AWARDS</h4>
          <div class="ficha">
            1st Prize — VIII Regional Artists' Salon<br>
            Central Zone, 1997
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            VIII Regional Artists' Salon — Central Zone, 1997<br>
            La Sabana Station, Bogota
          </div>

          <h4 style="margin-top: var(--s3);">TEXTS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/es/textos/jose-roca-columna-arena-28/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Jose Roca, Columna de Arena 28 (2000) (ES)
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (1997). <em>In Vitro</em>.
            Installation. Available at:
            mariaelviraescallon.com/en/works/in-vitro/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

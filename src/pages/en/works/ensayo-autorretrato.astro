---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'en' as const;
const title = 'Ensayo autorretrato';

const img1 = (await import('../../../assets/images/obras/ensayo-autorretrato/ensayo-01.jpg')).default;
const img2 = (await import('../../../assets/images/obras/ensayo-autorretrato/port-061.jpg')).default;
const img3 = (await import('../../../assets/images/obras/ensayo-autorretrato/port-062.jpg')).default;
const img4 = (await import('../../../assets/images/obras/ensayo-autorretrato/port-063.jpg')).default;
const img5 = (await import('../../../assets/images/obras/ensayo-autorretrato/port-064.jpg')).default;
const img6 = (await import('../../../assets/images/obras/ensayo-autorretrato/port-065.jpg')).default;
const img7 = (await import('../../../assets/images/obras/ensayo-autorretrato/port-066.jpg')).default;
---

<Layout
  lang={lang}
  title="Ensayo autorretrato — Work"
  description="Ensayo autorretrato (2022). Video. Maria Elvira Escallon."
>


  <ArtworkSchema
    title="Ensayo autorretrato"
    year="2022"
    medium="Video"
    description="Autobiographical video-essay presented at Galeria Espacio Continuo."
    url="https://mariaelviraescallon.com/en/works/ensayo-autorretrato/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Work / 014</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022 &nbsp;/&nbsp; Video &nbsp;/&nbsp; Galeria Espacio Continuo, Bogota</p>
      </header>

      <!-- Main gallery -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Ensayo autorretrato — Video still, the artist's hands" loading="eager">
        <img src={img2.src} alt="Ensayo autorretrato — Hands scratching the wall searching for a nail" loading="lazy">
        <img src={img3.src} alt="Ensayo autorretrato — Destruction of a Venus de Milo mask" loading="lazy">
        <img src={img4.src} alt="Ensayo autorretrato — Hands modeling an arm connected to a frailejon" loading="lazy">
        <img src={img5.src} alt="Ensayo autorretrato — Face molds grated with a cheese grater" loading="lazy">
        <img src={img6.src} alt="Ensayo autorretrato — Process of simultaneous destruction and creation" loading="lazy">
        <img src={img7.src} alt="Ensayo autorretrato — Detail of the sculptural action of the hands" loading="lazy">
      </div>

      <!-- Text + Technical sheet -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            In video, the artist's hands search for something on a wall, scratching with their
            nails until they find a nail. In another sequence, her hands systematically destroy
            a Venus de Milo mask with various mallets, and then model an arm that connects not
            to a shoulder but to a frailejon — a plant of the Colombian paramos.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            The self-portrait is constructed not from the face but from the hands: hands that
            extract, that destroy canons of beauty, that model the connection between the human
            and the vegetal. The work uses molds that seek to recreate the artist's face, which
            are grated with a cheese grater in a gesture that undoes conventional representation.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXT</h3>
          <p style="margin-top: var(--s2);">
            <em>Ensayo autorretrato</em> is part of the exhibition "Encuentros con seres
            notables" at Galeria Espacio Continuo (2022). The video works reveal Escallon's
            process — the hands as sculptural agents, destroying and creating simultaneously.
            The self-portrait is defined not by the representation of the face but by the action
            of the hands: artistic identity as gesture, as process, as relationship with matter.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>TECHNICAL SHEET</h4>
          <div class="ficha">
            <strong>Ensayo autorretrato</strong><br>
            2022<br><br>
            Video.<br><br>
            Galeria Espacio Continuo, Bogota
          </div>

          <h4 style="margin-top: var(--s3);">EXHIBITIONS</h4>
          <div class="ficha">
            Encuentros con seres notables — Galeria Espacio Continuo, Bogota, 2022
          </div>

          <h4 style="margin-top: var(--s3);">HOW TO CITE</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallon, M.E. (2022). <em>Ensayo autorretrato</em>.
            Video. Available at:
            mariaelviraescallon.com/en/works/ensayo-autorretrato/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

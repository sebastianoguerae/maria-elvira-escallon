---
import { Image } from 'astro:assets';
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Extracciones en el Hospital Universitario';

const img1 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-01.webp')).default;
const img2 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-02.webp')).default;
const img3 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-03.webp')).default;
const img4 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-04.webp')).default;
const img5 = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-05.webp')).default;
---

<Layout
  lang={lang}
  title="Extracciones en el Hospital Universitario — Obra"
  description="Extracciones en el Hospital Universitario (2012). Instalación, impresión digital giclée sobre papel de algodón. María Elvira Escallón."
  ogImage={img1.src}
>

  
  <ArtworkSchema
    title="Extracciones en el Hospital Universitario"
    year="2012"
    medium="Instalación, impresión digital giclée"
    description="Intervención en el Hospital Santa Rosa. Extracciones materiales del edificio en deterioro."
    url="https://mariaelviraescallon.org/es/obra/extracciones-hospital/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 012</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2012 &nbsp;/&nbsp; Instalación, impresión digital giclée sobre papel de algodón &nbsp;/&nbsp; 36 × 60 cm c/u</p>
      </header>

      <!-- Galería principal -->
      <div class="work-page__gallery">
        <Image src={img1} alt="Extracciones en el Hospital Universitario — Vista de la intervención" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img2} alt="Extracciones en el Hospital Universitario — Proceso de remoción del revestimiento" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img3} alt="Extracciones en el Hospital Universitario — Habitación en obra gris" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img4} alt="Extracciones en el Hospital Universitario — Detalle de la extracción" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img5} alt="Extracciones en el Hospital Universitario — Registro del proceso" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Se realizó la acción de remover el revestimiento arquitectónico de las habitaciones del Hospital conocidas como el Triage, situadas en el área de urgencias donde se atienden y diagnostican el paciente en emergencia médica. Dicho revestimiento se removió manualmente con cincel y mazo, reversando así el proceso constructivo hasta llevarlas dichas habitaciones a un estado de obra gris. El proceso se ha concebido como el aceleramiento de una ruina.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Extracciones en el Hospital Universitario</strong><br>
            2012<br><br>
            Instalación, impresión digital giclée sobre papel de algodón.<br><br>
            36 × 60 cm c/u<br>
            Hospital Santa Rosa, Universidad Nacional de Colombia
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2012). “Extracciones en el Hospital Universitario”.
            Instalación. Disponible en:
            mariaelviraescallon.org/es/obra/extracciones-hospital/
          </div>
        </aside>
      </div>

  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

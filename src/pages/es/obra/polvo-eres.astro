---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Polvo eres';

const img01 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-01.webp')).default;
const img02 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-02.webp')).default;
const img03 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-03.webp')).default;
const img04 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-04.webp')).default;
const img05 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-05.webp')).default;
const img06 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-06.webp')).default;
const img07 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-07.webp')).default;
const img08 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-08.webp')).default;
const img09 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-09.webp')).default;
const img10 = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-10.webp')).default;
---

<Layout
  lang={lang}
  title="Polvo eres — Obra"
  description="Polvo eres (2024). Talla sobre pared, muro de ladrillo, residuos de la talla, yeso, pintura. María Elvira Escallón."
>

  
  <ArtworkSchema
    title="Polvo eres"
    year="2024"
    medium="Talla sobre pared"
    description="Inscripción tallada directamente sobre el muro del MAMU, Bogotá. Referencia bíblica al polvo y la mortalidad."
    url="https://mariaelviraescallon.com/es/obra/polvo-eres/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 012</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2024 &nbsp;/&nbsp; Talla sobre pared, muro de ladrillo, residuos de la talla, yeso, pintura &nbsp;/&nbsp; Aprox. 60 × 400 cm</p>
      </header>

      <!-- Galeria principal -->
      <div class="work-page__gallery">
        <img src={img01.src} alt="Polvo eres — Vista general de la talla sobre pared" loading="eager">
        <img src={img02.src} alt="Polvo eres — Detalle de inscripción tallada" loading="lazy">
        <img src={img03.src} alt="Polvo eres — Residuos de la talla sobre el suelo" loading="lazy">
        <img src={img04.src} alt="Polvo eres — Textura del muro de ladrillo expuesto" loading="lazy">
        <img src={img05.src} alt="Polvo eres — Detalle de letras talladas" loading="lazy">
        <img src={img06.src} alt="Polvo eres — Vista lateral de la intervención" loading="lazy">
        <img src={img07.src} alt="Polvo eres — Acumulación de polvo al pie del muro" loading="lazy">
        <img src={img08.src} alt="Polvo eres — Detalle del proceso de talla" loading="lazy">
        <img src={img09.src} alt="Polvo eres — Vista de sala en el MAMU" loading="lazy">
        <img src={img10.src} alt="Polvo eres — Vista final de la obra instalada" loading="lazy">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Polvo eres</span>
        </div>
        <video controls preload="metadata">
          <source src="/maria-elvira-escallon/video/polvo-eres-web.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Proyecto planeado para el hall central del Hospital Santa Rosa. Video stop motion de la frase Polvo eres va apareciendo lentamente siendo grabada a cincel y mazo sobre la pared de recibo del hall. Se ven los golpes aparecer en la pared, nunca es visible el sujeto que realiza la acción. Primero fue proyectado sobre un muro del Hospital Santa Rosa en 2008 y posteriormente grabado en el muro del Museo de Arte de la Universidad Nacional de Colombia.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Posteriormente a medida que el tiempo ha pasado este gesto ha sido repetido cargándose de otras connotaciones en otros espacios. Polvo eres como polvo de estrellas en el sentido que somos constituidos por los mismos átomos que los astros, Polvo eres en el sentido que no somos seres tan solidos como percibimos, realmente somos agrupaciones de moléculas y disolviéndonos estamos en la medida que "todo esta ardiendo" como dice el Buda.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Polvo eres</strong><br>
            2008–2024<br><br>
            Talla sobre pared, muro de ladrillo, residuos de la talla, yeso, pintura.<br><br>
            Dimensiones variables.
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2008–2024). <em>Polvo eres</em>.
            Talla sobre pared. Disponible en:
            mariaelviraescallon.com/es/obra/polvo-eres/
          </div>
        </aside>
      </div>

  </article>

</Layout>

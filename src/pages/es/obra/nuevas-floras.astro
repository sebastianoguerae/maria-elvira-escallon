---
import Layout from '../../../components/layout/Layout.astro';
import QuoteBlock from '../../../components/content/QuoteBlock.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Nuevas Floras';

// Colombia (root)
const col01 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-01.webp')).default;
const col02 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-02.webp')).default;
const col03 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-03.webp')).default;
const col04 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-04.webp')).default;
const col05 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-05.webp')).default;
const col06 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-06.webp')).default;
const col08 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-08.webp')).default;
const col09 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-09.webp')).default;
const col10 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-10.webp')).default;
const col11 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-11.webp')).default;
const col12 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-12.webp')).default;
const col13 = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-13.webp')).default;
// Bristol
const bristol01 = (await import('../../../assets/images/obras/nuevas-floras/bristol/bristol-01.webp')).default;
// Do Sul
const doSul01 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-01.webp')).default;
const doSul02 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-02.webp')).default;
const doSul03 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-03.webp')).default;
const doSul04 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-04.webp')).default;
const doSul05 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-05.webp')).default;
const doSul06 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-06.webp')).default;
const doSul07 = (await import('../../../assets/images/obras/nuevas-floras/do-sul/do-sul-07.webp')).default;
// Versalles
const versalles01 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-01.webp')).default;
const versalles02 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-02.webp')).default;
const versalles03 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-03.webp')).default;
const versalles04 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-04.webp')).default;
const versalles05 = (await import('../../../assets/images/obras/nuevas-floras/versalles/versalles-05.webp')).default;
---

<Layout
  lang={lang}
  title="Nuevas Floras — Obra"
  description="Nuevas Floras (2003). Intervención escultórica sobre árboles nativos. III Premio Luis Caballero. María Elvira Escallón."
>

  <ArtworkSchema
    title="Nuevas Floras"
    year="2003"
    medium="Intervención escultórica sobre árboles nativos, fotografía cromogénica"
    dimensions="120 × 80 cm (fotografías)"
    description="Intervención sobre árboles nativos vivos con tallas barrocas. III Premio Luis Caballero, Galería Santa Fe, Bogotá."
    url="https://mariaelviraescallon.com/es/obra/nuevas-floras/"
    collections={["Banco de la República, Bogotá", "ESCALA, Universidad de Essex, UK", "Colección Seguros Bolívar"]}
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 005</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2003 &nbsp;/&nbsp; Intervención escultórica sobre árboles nativos &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galeria -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">COLOMBIA</h3>
        <img src={col01.src} alt="Nuevas Floras Colombia — Árbol nativo con talla barroca" loading="eager">
        <img src={col02.src} alt="Nuevas Floras Colombia — Intervención escultórica sobre tronco" loading="lazy">
        <img src={col03.src} alt="Nuevas Floras Colombia — Detalle de columna salomónica tallada" loading="lazy">
        <img src={col04.src} alt="Nuevas Floras Colombia — Prótesis ornamental en árbol vivo" loading="lazy">
        <img src={col05.src} alt="Nuevas Floras Colombia — Voluta barroca sobre corteza" loading="lazy">
        <img src={col06.src} alt="Nuevas Floras Colombia — Elemento de retablo en rama" loading="lazy">
        <img src={col08.src} alt="Nuevas Floras Colombia — Árbol absorbiendo la intervención" loading="lazy">
        <img src={col09.src} alt="Nuevas Floras Colombia — Registro fotográfico cromogénico" loading="lazy">
        <img src={col10.src} alt="Nuevas Floras Colombia — Talla casi imperceptible por crecimiento" loading="lazy">
        <img src={col11.src} alt="Nuevas Floras Colombia — Convergencia de naturaleza y cultura" loading="lazy">
        <img src={col12.src} alt="Nuevas Floras Colombia — Detalle de intervención arbórea" loading="lazy">
        <img src={col13.src} alt="Nuevas Floras Colombia — Vista de conjunto de la serie" loading="lazy">

        <h3 style="margin-top: var(--s3);">BRISTOL</h3>
        <img src={bristol01.src} alt="Nuevas Floras Bristol — Intervención sobre árbol en Bristol" loading="lazy">

        <h3 style="margin-top: var(--s3);">DO SUL</h3>
        <img src={doSul01.src} alt="Nuevas Floras do Sul — Árbol intervenido en Brasil" loading="lazy">
        <img src={doSul02.src} alt="Nuevas Floras do Sul — Detalle de talla sobre tronco" loading="lazy">
        <img src={doSul03.src} alt="Nuevas Floras do Sul — Forma ornamental en corteza" loading="lazy">
        <img src={doSul04.src} alt="Nuevas Floras do Sul — Intervención escultórica" loading="lazy">
        <img src={doSul05.src} alt="Nuevas Floras do Sul — Registro de crecimiento del árbol" loading="lazy">
        <img src={doSul06.src} alt="Nuevas Floras do Sul — Detalle de proceso orgánico" loading="lazy">
        <img src={doSul07.src} alt="Nuevas Floras do Sul — Vista de la serie completa" loading="lazy">

        <h3 style="margin-top: var(--s3);">VERSALLES</h3>
        <img src={versalles01.src} alt="Nuevas Floras Versalles — Árbol intervenido en Versalles" loading="lazy">
        <img src={versalles02.src} alt="Nuevas Floras Versalles — Talla ornamental sobre tronco" loading="lazy">
        <img src={versalles03.src} alt="Nuevas Floras Versalles — Detalle de intervención" loading="lazy">
        <img src={versalles04.src} alt="Nuevas Floras Versalles — Forma barroca en árbol vivo" loading="lazy">
        <img src={versalles05.src} alt="Nuevas Floras Versalles — Vista de conjunto" loading="lazy">
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            En <em>Nuevas Floras</em> la artista interviene árboles nativos vivos con tallas
            o prótesis de formas generalmente evocativas de la arquitectura clásica y elementos
            comunes en altares de iglesias barrocas. Basándose en investigación previa, Escallón
            determinó cómo proceder sin causar daño colateral, y los fragmentos tallados fueron
            ejecutados por expertos.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            En un segundo momento, los seres arbóreos responden a la acción interrumpiendo la
            intervención, hasta hacerla casi imperceptible. Su práctica crea un espacio donde
            lo «salvaje» y lo manejado convergen en el tiempo, donde naturaleza y cultura están
            inextricablemente ligadas. La artista continúa fotografiando estos árboles a medida
            que crecen, haciéndolos participantes activos en la obra.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            <em>Nuevas Floras</em> se presenta como una serie de fotografías cromogénicas de gran
            formato (120 x 80 cm) tomadas inmediatamente después de completar la intervención.
            Las tallas realizadas sobre los árboles evocan formas del repertorio ornamental
            colonial colombiano — columnas salomónicas, volutas, elementos de retablos barrocos —
            creando una tensión entre la historia cultural impuesta y la respuesta orgánica del
            ser vivo que la absorbe y la transforma.
          </p>

          <QuoteBlock
            annotation="Texto curatorial — José Roca"
            quote="La obra de Escallón se encamina a perturbar la naturalidad de ese orden. <em>Nuevas Floras</em> posee dos aspectos fundamentales: su carácter nómada — porque la idea de la que parte puede desarrollarse en otros espacios — y el concepto de temporalidad — porque su duración es indefinida."
            cite="José Roca — Columna de Arena 53, agosto 2003"
          />

          <h3 style="margin-top: var(--s4);">CONTEXTO</h3>
          <p style="margin-top: var(--s2);">
            En 2003, Escallón ganó el Primer Premio del III Concurso Luis Caballero
            con este proyecto, presentado en la Galería Santa Fe de Bogotá. El jurado,
            compuesto por el curador José Roca entre otros, destacó la manera en que
            la obra cuestiona los límites entre lo natural y lo cultural — una constante
            en la trayectoria de la artista.
          </p>

          <h3 style="margin-top: var(--s4);">OBRAS RELACIONADAS</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/es/obra/nuevas-floras-versalles/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Nuevas Floras Versalles (2017)</a>
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Nuevas Floras</strong><br>
            2003<br><br>
            Intervención escultórica sobre árboles nativos vivos.
            Talla en madera, prótesis.<br>
            Documentación: fotografía cromogénica.<br><br>
            120 × 80 cm (fotografías)<br>
            Edición de 5<br>
            Dimensiones variables (intervenciones)
          </div>

          <h4 style="margin-top: var(--s3);">PREMIOS</h4>
          <div class="ficha">
            III Premio Luis Caballero — Primer premio<br>
            Galería Santa Fe, Bogotá, 2003
          </div>

          <h4 style="margin-top: var(--s3);">COLECCIONES</h4>
          <div class="ficha">
            Banco de la República, Bogotá<br>
            ESCALA, Universidad de Essex, UK<br>
            Colección Seguros Bolívar
          </div>

          <h4 style="margin-top: var(--s3);">TEXTOS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/es/textos/jose-roca-columna-arena-53/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              José Roca, Columna de Arena 53 (2003)
            </a>
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

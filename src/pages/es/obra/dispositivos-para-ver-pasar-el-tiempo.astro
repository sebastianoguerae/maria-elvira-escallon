---
import { Image } from 'astro:assets';
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Dispositivos para ver pasar el tiempo';

const img01 = (await import('../../../assets/images/obras/dispositivos/dispositivos-01.webp')).default;
const img02 = (await import('../../../assets/images/obras/dispositivos/dispositivos-02.webp')).default;
const img03 = (await import('../../../assets/images/obras/dispositivos/dispositivos-03.webp')).default;
const img04 = (await import('../../../assets/images/obras/dispositivos/dispositivos-04.webp')).default;
const img05 = (await import('../../../assets/images/obras/dispositivos/dispositivos-05.webp')).default;
const img06 = (await import('../../../assets/images/obras/dispositivos/dispositivos-06.webp')).default;
const img07 = (await import('../../../assets/images/obras/dispositivos/dispositivos-07.webp')).default;
const img08 = (await import('../../../assets/images/obras/dispositivos/dispositivos-08.webp')).default;
const img10 = (await import('../../../assets/images/obras/dispositivos/dispositivos-10.webp')).default;
const img11 = (await import('../../../assets/images/obras/dispositivos/dispositivos-11.webp')).default;
const img12 = (await import('../../../assets/images/obras/dispositivos/dispositivos-12.webp')).default;
const img13 = (await import('../../../assets/images/obras/dispositivos/dispositivos-13.webp')).default;
const img14 = (await import('../../../assets/images/obras/dispositivos/dispositivos-14.webp')).default;
---

<Layout
  lang={lang}
  title="Dispositivos para ver pasar el tiempo — Obra"
  description="Dispositivos para ver pasar el tiempo (2020). Instalación, escultura. María Elvira Escallón."
  ogImage={img01.src}
>

  
  <ArtworkSchema
    title="Dispositivos para ver pasar el tiempo"
    year="2020"
    medium="Instalación"
    description="Dispositivos que hacen visible el paso del tiempo a través de procesos materiales."
    url="https://mariaelviraescallon.org/es/obra/dispositivos-para-ver-pasar-el-tiempo/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 009</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2020 &nbsp;/&nbsp; Instalación, escultura &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galeria principal -->
      <div class="work-page__gallery">
        <Image src={img01} alt="Dispositivos para ver pasar el tiempo — Vista general de instalación" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img02} alt="Dispositivos para ver pasar el tiempo — Dispositivo de arena" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img03} alt="Dispositivos para ver pasar el tiempo — Superficie erosionada" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img04} alt="Dispositivos para ver pasar el tiempo — Mecanismo poético" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img05} alt="Dispositivos para ver pasar el tiempo — Acumulación de material" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img06} alt="Dispositivos para ver pasar el tiempo — Detalle de dispositivo" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img07} alt="Dispositivos para ver pasar el tiempo — Transformación material" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img08} alt="Dispositivos para ver pasar el tiempo — Registro de desgaste" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img10} alt="Dispositivos para ver pasar el tiempo — Pieza escultórica" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img11} alt="Dispositivos para ver pasar el tiempo — Detalle de proceso" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img12} alt="Dispositivos para ver pasar el tiempo — Vista de conjunto" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img13} alt="Dispositivos para ver pasar el tiempo — Elemento temporal" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={img14} alt="Dispositivos para ver pasar el tiempo — Vista final" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Proyecto realizado durante la pandemia.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Soy invitada a contemplar lo que ocurre allí. De algún modo sé que mi papel es atestiguarlo todo en total quietud. Lo he comprobado, sucede como en la fotografía, si me muevo un poco, todo se desdibuja.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Los fenómenos se despliegan muy lentamente frente a mí, casi como dispositivos para ver pasar el tiempo. Invasiones de materiales antes inertes, entran lentamente en la escena, fuertes corrientes de viento que parecen tener voluntad propia, grandes gestos de luto sobre la pared, crepúsculos demasiado intensos, demasiado largos en estos tiempos cuando los monumentos caen.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Siempre hay más luz de la que uno espera en una casa así, incluso a veces cuando entro de repente un salón, me parece por instantes -sólo por fracciones de instante- que estaba resplandeciente.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Dispositivos para ver pasar el tiempo</strong><br>
            2020<br><br>
            Instalación, escultura.<br><br>
            Dimensiones variables
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2020). “Dispositivos para ver pasar el tiempo”.
            Instalación, escultura. Disponible en:
            mariaelviraescallon.org/es/obra/dispositivos-para-ver-pasar-el-tiempo/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

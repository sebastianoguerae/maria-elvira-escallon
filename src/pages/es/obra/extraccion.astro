---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Extracción';

const img1 = (await import('../../../assets/images/obras/extraccion/extraccion-01.webp')).default;
---

<Layout
  lang={lang}
  title="Extracción — Obra"
  description="Extracción (2018). Video monocanal. María Elvira Escallón."
>

  
  <ArtworkSchema
    title="Extracción"
    year="2018"
    medium="Video monocanal"
    description="Extracción (2018). Video monocanal que registra el gesto delicado de extraer fragmentos de materia. María Elvira Escallón."
    url="https://mariaelviraescallon.com/es/obra/extraccion/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 018</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2018 &nbsp;/&nbsp; Video monocanal</p>
      </header>

      <!-- Galería principal -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Extracción — Fotograma del video monocanal" loading="eager">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Extracción</span>
        </div>
        <video controls preload="metadata">
          <source src="/maria-elvira-escallon/video/extraccion-web.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Extracción es un video monocanal que registra un gesto delicado y repetitivo: una mano extrae cuidadosamente pequeños fragmentos de materia de la piel. La acción, filmada a través de una lente circular que recuerda un instrumento médico o científico, transforma un acto cotidiano en una observación casi quirúrgica de la relación entre el cuerpo y sus residuos materiales.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Extracción</strong><br>
            2018<br><br>
            Video monocanal.
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2018). <em>Extracción</em>.
            Video monocanal. Disponible en:
            mariaelviraescallon.com/es/obra/extraccion/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

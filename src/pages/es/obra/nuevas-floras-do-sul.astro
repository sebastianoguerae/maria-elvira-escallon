---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Nuevas Floras do Sul';

const img1 = (await import('../../../assets/images/obras/nuevas-floras-do-sul/do-sul-01.jpg')).default;
const img2 = (await import('../../../assets/images/obras/nuevas-floras-do-sul/do-sul-02.jpg')).default;
---

<Layout
  lang={lang}
  title="Nuevas Floras do Sul — Obra"
  description="Nuevas Floras do Sul (2011). Intervención escultórica sobre árboles. Ruinas jesuíticas, sur de Brasil. María Elvira Escallón."
>

  <ArtworkSchema
    title="Nuevas Floras do Sul"
    year="2011"
    medium="Intervención escultórica sobre árboles"
    description="Versión de Nuevas Floras realizada en el sur de Brasil, cerca de las ruinas jesuíticas. Las tallas barrocas sobre árboles dialogan con el barroco histórico de las misiones jesuíticas."
    url="https://mariaelviraescallon.com/es/obra/nuevas-floras-do-sul/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 005c</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2011 &nbsp;/&nbsp; Intervención escultórica sobre árboles &nbsp;/&nbsp; Ruinas jesuíticas, sur de Brasil</p>
      </header>

      <!-- Galería principal -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Nuevas Floras do Sul — Intervención escultórica sobre árbol cerca de las ruinas jesuíticas" loading="eager">
        <img src={img2.src} alt="Nuevas Floras do Sul — Detalle de talla barroca en diálogo con las ruinas de las misiones" loading="lazy">
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            <em>Nuevas Floras do Sul</em> es la versión de <em>Nuevas Floras</em> realizada
            en el sur de Brasil, en las inmediaciones de las ruinas de las misiones jesuíticas.
            Escallón interviene árboles vivos con tallas de formas barrocas — el mismo
            procedimiento desarrollado originalmente en Colombia en 2003 — pero aquí el
            contexto geográfico e histórico añade una dimensión particular.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Las tallas barrocas sobre los árboles entran en diálogo directo con el barroco
            histórico de las misiones jesuíticas en ruinas. Las reducciones jesuíticas del
            sur de Brasil, fundadas en los siglos XVII y XVIII, fueron centros de producción
            artística donde la ornamentación barroca europea se fusionó con las tradiciones
            indígenas guaraníes. Las ruinas de esas misiones conservan fragmentos de esa
            hibridación cultural.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Al tallar formas barrocas sobre árboles vivos junto a esas ruinas, Escallón
            produce un eco temporal: el barroco vuelve a inscribirse sobre la naturaleza,
            pero esta vez en un gesto artístico consciente de la historia que lo precede.
            Los árboles, como en todas las versiones de <em>Nuevas Floras</em>, responderán
            con el tiempo absorbiendo y transformando la intervención — haciendo visible
            la relación entre cultura y naturaleza que las misiones jesuíticas también
            encarnaron a su manera.
          </p>

          <h3 style="margin-top: var(--s4);">OBRAS RELACIONADAS</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/es/obra/nuevas-floras/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Nuevas Floras (2003) — Colombia</a>
            </li>
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <a href="/maria-elvira-escallon/es/obra/nuevas-floras-versalles/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">Nuevas Floras Versalles (2017) — Francia</a>
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Nuevas Floras do Sul</strong><br>
            2011<br><br>
            Intervención escultórica sobre árboles.<br>
            Talla en madera.<br><br>
            Dimensiones variables.<br>
            Ruinas jesuíticas, sur de Brasil.
          </div>

          <h4 style="margin-top: var(--s3);">LUGAR</h4>
          <div class="ficha">
            Sur de Brasil<br>
            Inmediaciones de las ruinas de las misiones jesuíticas
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2011). <em>Nuevas Floras do Sul</em>.
            Intervención escultórica sobre árboles. Disponible en:
            mariaelviraescallon.com/es/obra/nuevas-floras-do-sul/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

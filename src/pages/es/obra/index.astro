---

<Layout lang={lang} title="Obra" description="Obra completa de María Elvira Escallón. Catálogo de proyectos 1997–2024. Escultura, instalación, fotografía y video.">

  <div class="obra-index">
    <div class="container">

      <!-- Header -->
      <header class="section__header">
        <h1>Obra completa</h1>
        <span class="label">1997–2024</span>
      </header>

      <!-- Works list -->
      <div class="works-catalog">
        {works.map((work) => (
          <a href={`/maria-elvira-escallon/es/obra/${work.slug}/`} class="work-entry-link" style="text-decoration:none; color:inherit;">
            <div class="work-entry">
              <div class="work-entry__num">{work.num}</div>
              <div class="work-entry__info">
                <h3>{work.title}</h3>
                <div class="ficha">
                  {work.year} &nbsp;/&nbsp; {work.description}
                </div>
              </div>
              <div class="work-entry__image">
                {work.hasImage && work.image ? (
                  <img
                    src={work.image.src}
                    alt={`${work.title} — María Elvira Escallón`}
                    loading="lazy"
                  />
                ) : (
                  <div class="placeholder-img" style="height:100%;display:flex;align-items:center;justify-content:center;color:var(--ash-light);font-family:var(--mono);font-size:0.55rem;letter-spacing:0.08em;text-transform:uppercase;">
                    [ {work.title} ]
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

</Layout>

<style>
  .obra-index {
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s5);
  }

  .works-catalog {
    margin-top: var(--s3);
  }

  .work-entry-link:last-child .work-entry {
    border-bottom: 1px solid var(--ink);
  }
</style>

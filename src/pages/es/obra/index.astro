---
import Layout from '../../../components/layout/Layout.astro';

const lang = 'es' as const;

const imgInVitro = (await import('../../../assets/images/obras/in-vitro/in-vitro-01.webp')).default;
const imgElReino = (await import('../../../assets/images/obras/el-reino/el-reino-01.webp')).default;
const imgDesdeAdentro = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-01.webp')).default;
const imgNuevasFloras = (await import('../../../assets/images/obras/nuevas-floras/nuevas-floras-13.webp')).default;
const imgComa = (await import('../../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-01.webp')).default;
const imgAerolito = (await import('../../../assets/images/obras/aerolito/aerolito-01.webp')).default;
const imgInMemoriam = (await import('../../../assets/images/obras/in-memoriam/in-memoriam-01.webp')).default;
const imgPrecipitacion = (await import('../../../assets/images/obras/precipitacion/precipitacion-01.webp')).default;
const imgEncuentros = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-03.webp')).default;
const imgPolvo = (await import('../../../assets/images/obras/polvo-eres/polvo-eres-01.webp')).default;
const imgRecelaron = (await import('../../../assets/images/obras/recelaron-del-cielo/recelaron-del-cielo-01.webp')).default;
const imgPaisaje = (await import('../../../assets/images/obras/paisaje-domestico/paisaje-domestico-01.webp')).default;
const imgExtracciones = (await import('../../../assets/images/obras/extracciones-hospital/extracciones-hospital-01.webp')).default;
const imgDispositivos = (await import('../../../assets/images/obras/dispositivos/dispositivos-01.webp')).default;
const imgFertilSuelo = (await import('../../../assets/images/obras/fertil-suelo/fertil-suelo-01.webp')).default;
const imgDivino = (await import('../../../assets/images/obras/divino-fragmento/divino-fragmento-01.webp')).default;
const imgTravesia = (await import('../../../assets/images/obras/la-travesia/la-travesia-01.webp')).default;
const imgSabian = (await import('../../../assets/images/obras/sabian-no-recordaban/sabian-no-recordaban-01.webp')).default;
const imgEnsayo = (await import('../../../assets/images/obras/ensayo-autorretrato/ensayo-autorretrato-01.webp')).default;
const imgExtraccion = (await import('../../../assets/images/obras/extraccion/extraccion-01.webp')).default;
const imgUnMensaje = (await import('../../../assets/images/obras/un-mensaje/un-mensaje-01.webp')).default;

const works = [
  { slug: 'polvo-eres', title: 'Polvo eres', year: '2024', image: imgPolvo },
  { slug: 'sabian-no-recordaban', title: 'Sabían, pero no recordaban', year: '2024', image: imgSabian },
  { slug: 'precipitacion-de-arenas', title: 'Precipitación de arenas', year: '2022–2024', image: imgPrecipitacion },
  { slug: 'la-travesia', title: 'La travesía', year: '2017–2024', image: imgTravesia },
  { slug: 'encuentros-con-seres-notables', title: 'Encuentros', year: '2022', image: imgEncuentros },
  { slug: 'ensayo-autorretrato', title: 'Ensayo autorretrato', year: '2022', image: imgEnsayo },
  { slug: 'dispositivos-para-ver-pasar-el-tiempo', title: 'Dispositivos para ver pasar el tiempo', year: '2020', image: imgDispositivos },
  { slug: 'extraccion', title: 'Extracción', year: '2018', image: imgExtraccion },
  { slug: 'en-el-fertil-suelo', title: 'En el fértil suelo', year: '2017–2018', image: imgFertilSuelo },
  { slug: 'aerolito', title: 'Pequeño Museo del Aerolito', year: '2014–2015', image: imgAerolito },
  { slug: 'extracciones-hospital', title: 'Extracciones en el Hospital', year: '2012', image: imgExtracciones },
  { slug: 'recelaron-del-cielo', title: 'Recelaron del cielo', year: '2008', image: imgRecelaron },
  { slug: 'en-estado-de-coma', title: 'En estado de coma', year: '2005–2007', image: imgComa },
  { slug: 'paisaje-domestico', title: 'Paisaje doméstico', year: '2005', image: imgPaisaje },
  { slug: 'divino-fragmento', title: 'Divino Fragmento', year: '2003', image: imgDivino },
  { slug: 'nuevas-floras', title: 'Nuevas Floras', year: '2003', image: imgNuevasFloras },
  { slug: 'desde-adentro', title: 'Desde Adentro', year: '2003', image: imgDesdeAdentro },
  { slug: 'in-memoriam', title: 'In Memoriam', year: '2001', image: imgInMemoriam },
  { slug: 'el-reino-de-este-mundo', title: 'El reino de este mundo', year: '2000', image: imgElReino },
  { slug: 'in-vitro', title: 'In Vitro', year: '1997', image: imgInVitro },
  { slug: 'un-mensaje', title: 'Un mensaje', year: '', image: imgUnMensaje },
];
---

<Layout lang={lang} title="Obra" description="Obra completa de María Elvira Escallón. Catálogo de proyectos 1997–2024. Escultura, instalación, fotografía y video.">

  <div class="obra-index">
    <div class="container">

      <header class="obra-index__header">
        <h1>Obra</h1>
        <span class="label">{works.length} proyectos &nbsp;/&nbsp; 1997–2024</span>
      </header>

      <div class="obra-grid">
        {works.map((work) => (
          <a href={`/maria-elvira-escallon/es/obra/${work.slug}/`} class="obra-card">
            <div class="obra-card__img">
              {work.image ? (
                <img
                  src={work.image.src}
                  alt={`${work.title} — María Elvira Escallón`}
                  loading="lazy"
                />
              ) : (
                <span class="obra-card__placeholder">{work.title}</span>
              )}
            </div>
            <div class="obra-card__info">
              <span class="obra-card__title">{work.title}</span>
              {work.year && <span class="obra-card__year">{work.year}</span>}
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>

</Layout>

<style>
  .obra-index {
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s5);
  }

  .obra-index__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: var(--s2);
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--s4);
  }

  .obra-index__header h1 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  /* ── Dense grid ── */
  .obra-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  /* ── Card ── */
  .obra-card {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
  }

  .obra-card__img {
    aspect-ratio: 4 / 3;
    background-color: var(--paper-dark);
    overflow: hidden;
    position: relative;
  }

  .obra-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.4s ease, transform 0.6s ease;
  }

  .obra-card:hover .obra-card__img img {
    opacity: 0.85;
    transform: scale(1.03);
  }

  .obra-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-family: var(--mono);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ash-light);
    text-align: center;
    padding: var(--s2);
    line-height: 1.6;
  }

  .obra-card__info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s1);
    padding: 0.6rem 0 1rem;
  }

  .obra-card__title {
    font-family: var(--mono);
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--ink);
    line-height: 1.4;
    flex: 1;
    min-width: 0;
  }

  .obra-card__year {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ash-light);
    letter-spacing: 0.03em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .obra-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .obra-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
    }

    .obra-card__info {
      flex-direction: column;
      gap: 2px;
      padding: 0.5rem 0 0.8rem;
    }

    .obra-card__title {
      font-size: 0.58rem;
    }
  }
</style>

const caminantes11 = (await import('../../../assets/images/obras/encuentros/encuentros-las-caminantes/encuentros-las-caminantes-11.webp')).default;
---

<Layout
  lang={lang}
  title="Encuentros — Obra"
  description="Encuentros (2017–2022). Escultura — ramas de jazmín de la sabana, eucalipto, talla en madera, arcilla. María Elvira Escallón."
  ogImage={enc01.src}
>

  
  <ArtworkSchema
    title="Encuentros con seres notables"
    year="2022"
    medium="Escultura, ramas talladas"
    description="Esculturas talladas sobre ramas que exploran la relación entre el cuerpo humano y el vegetal."
    url="https://mariaelviraescallon.org/es/obra/encuentros-con-seres-notables/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 011</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022 &nbsp;/&nbsp; Escultura — ramas de jazmín de la sabana, eucalipto, talla en madera, arcilla &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galeria -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">ENCUENTROS</h3>
        <Image src={enc01} alt="Encuentros — Escultura sobre rama, figura emergente" loading="eager" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={enc02} alt="Encuentros — Talla en madera sobre rama natural" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={enc07} alt="Encuentros — Detalle de intervención escultórica" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={enc08} alt="Encuentros — Forma humana en rama de árbol" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">ENCUENTROS CON SERES NOTABLES</h3>
        <Image src={seres01} alt="Encuentros con seres notables — Escultura tallada sobre rama" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seres03} alt="Encuentros con seres notables — Cuerpo vegetal intervenido" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seres04} alt="Encuentros con seres notables — Detalle de talla en madera" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seres05} alt="Encuentros con seres notables — Forma orgánica tallada" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seres06} alt="Encuentros con seres notables — Rama con figura escultórica" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={seres10} alt="Encuentros con seres notables — Vista de conjunto" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">MESA DE TRABAJO</h3>
        <Image src={mesa01} alt="Mesa de trabajo — Vista general del espacio de trabajo" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa15} alt="Mesa de trabajo — Herramientas y materiales" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa16} alt="Mesa de trabajo — Proceso de talla" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa17} alt="Mesa de trabajo — Ramas en preparación" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image class="img-small" src={mesa18} alt="Mesa de trabajo — Detalle de proceso creativo" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image class="img-small" src={mesa19} alt="Mesa de trabajo — Piezas en desarrollo" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image class="img-small" src={mesa20} alt="Mesa de trabajo — Material escultórico" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa21} alt="Mesa de trabajo — Fragmentos de talla" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa22} alt="Mesa de trabajo — Elementos de trabajo" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa23} alt="Mesa de trabajo — Vista del taller" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa24} alt="Mesa de trabajo — Detalle de herramientas" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa25} alt="Mesa de trabajo — Piezas terminadas" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa26} alt="Mesa de trabajo — Registro de proceso" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={mesa27} alt="Mesa de trabajo — Vista final del espacio" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">ARBOREA</h3>
        <Image src={arborea08} alt="Arbórea — Escultura arbórea intervenida" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={arborea09} alt="Arbórea — Detalle de intervención sobre árbol" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">ENCUENTROS CERCANOS</h3>
        <Image src={cercanos12} alt="Encuentros cercanos — Figura tallada en primer plano" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={cercanos13} alt="Encuentros cercanos — Detalle de forma escultórica" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <Image src={cercanos14} alt="Encuentros cercanos — Vista cercana de talla" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />

        <h3 style="margin-top: var(--s3);">LAS CAMINANTES</h3>
        <Image src={caminantes11} alt="Las caminantes — Figura caminante tallada en rama" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Encuentros</span>
        </div>
        <video controls preload="metadata">
          <source src="/video/encuentros-web.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Con estas piezas, ponemos en consideración las características que nos aproximan a los seres vegetales, en lugar de poner el acento en aquello que nos diferencia de las demás especies y familias, como se ha hecho durante siglos. El proyecto también sugiere una imagen del humano modificada, cuya estructura anatómica se asocia y dialoga con la de los seres vegetales.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Encuentros -1 En este conjunto de piezas escultóricas ramas de distintas especies botánicas se encuentran y se funden unas en otras surgiendo un continuo. Así una rama de encenillo -especie nativa del sub páramo de los Andes- se funde con una rama de eucalipto, especie proviene del Japón. La serie remata con la pieza La superneurona, realizada en Francia, donde se acopla la copa de un pino proveniente de América con un Castaño Blanco Europeo.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Encuentros con Seres Notables. La pieza nos presenta simultáneamente tres imágenes que el público puede reconocer de inmediato: la imagen de la pintura La creación de Adán de Miguel Ángel, la imagen de los huesos de brazos y manos humanos y, las ramas de dos variedades de árboles levemente intervenidas. Suscita asociaciones con conceptos de creación, vida, muerte, tanto como de pactos, alianzas y transmisiones de conocimiento. Nos presenta fusiones entre especies distantes e incluso entre diferentes reinos.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            En el video Mesa de trabajo, que es parte de esta serie, una replica del rostro de la escultura de Venus, es quebradas y reducida a polvo con ayuda de varios implementos domésticos. Dicho polvo después se mezcla con agua para modelar una figura que reúne anatomía humana y vegetal.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Encuentros cercanos, es una instalación que está afuera del espacio del Museo o la Galería y que se ve estando adentro, desde una ventana. Vemos un árbol que emite una señal morse, de modo que la imagen del árbol y de la señal entra a la sala donde el mensaje es decodificado en una pequeña pantalla cerca de la ventana. La frase que se emite es “En cada inhalación nos encontramos”.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Encuentros</strong><br>
            2017–2022<br><br>
            Escultura — ramas de jazmín de la sabana, eucalipto, talla en madera, arcilla.<br><br>
            Dimensiones variables.
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2017–2022). “Encuentros”.
            Escultura. Disponible en:
            mariaelviraescallon.org/es/obra/encuentros-con-seres-notables/
          </div>
        </aside>
      </div>

  </article>

</Layout>

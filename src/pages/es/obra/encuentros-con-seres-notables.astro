---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Encuentros';

// Encuentros
const enc01 = (await import('../../../assets/images/obras/encuentros/encuentros/encuentros-01.webp')).default;
const enc02 = (await import('../../../assets/images/obras/encuentros/encuentros/encuentros-02.webp')).default;
const enc07 = (await import('../../../assets/images/obras/encuentros/encuentros/encuentros-07.webp')).default;
const enc08 = (await import('../../../assets/images/obras/encuentros/encuentros/encuentros-08.webp')).default;
// Encuentros con seres notables
const seres01 = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-01.webp')).default;
const seres03 = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-03.webp')).default;
const seres04 = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-04.webp')).default;
const seres05 = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-05.webp')).default;
const seres06 = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-06.webp')).default;
const seres10 = (await import('../../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-10.webp')).default;
// Mesa de trabajo
const mesa01 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-01.webp')).default;
const mesa15 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-15.webp')).default;
const mesa16 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-16.webp')).default;
const mesa17 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-17.webp')).default;
const mesa18 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-18.webp')).default;
const mesa19 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-19.webp')).default;
const mesa20 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-20.webp')).default;
const mesa21 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-21.webp')).default;
const mesa22 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-22.webp')).default;
const mesa23 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-23.webp')).default;
const mesa24 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-24.webp')).default;
const mesa25 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-25.webp')).default;
const mesa26 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-26.webp')).default;
const mesa27 = (await import('../../../assets/images/obras/encuentros/encuentros-mesa-de-trabajo/encuentros-mesa-de-trabajo-27.webp')).default;
// Arborea
const arborea08 = (await import('../../../assets/images/obras/encuentros/encuentros--arborea/encuentros--arborea-08.webp')).default;
const arborea09 = (await import('../../../assets/images/obras/encuentros/encuentros--arborea/encuentros--arborea-09.webp')).default;
// Encuentros cercanos
const cercanos12 = (await import('../../../assets/images/obras/encuentros/encuentros-cercanos/encuentros-cercanos-12.webp')).default;
const cercanos13 = (await import('../../../assets/images/obras/encuentros/encuentros-cercanos/encuentros-cercanos-13.webp')).default;
const cercanos14 = (await import('../../../assets/images/obras/encuentros/encuentros-cercanos/encuentros-cercanos-14.webp')).default;
// Las caminantes
const caminantes11 = (await import('../../../assets/images/obras/encuentros/encuentros-las-caminantes/encuentros-las-caminantes-11.webp')).default;
---

<Layout
  lang={lang}
  title="Encuentros — Obra"
  description="Encuentros (2017–2022). Escultura — ramas de jazmín de la sabana, eucalipto, talla en madera, arcilla. María Elvira Escallón."
>

  
  <ArtworkSchema
    title="Encuentros con seres notables"
    year="2022"
    medium="Escultura, ramas talladas"
    description="Esculturas talladas sobre ramas que exploran la relación entre el cuerpo humano y el vegetal."
    url="https://mariaelviraescallon.com/es/obra/encuentros-con-seres-notables/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 011</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022 &nbsp;/&nbsp; Escultura — ramas de jazmín de la sabana, eucalipto, talla en madera, arcilla &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galeria -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">ENCUENTROS</h3>
        <img src={enc01.src} alt="Encuentros — Escultura sobre rama, figura emergente" loading="eager">
        <img src={enc02.src} alt="Encuentros — Talla en madera sobre rama natural" loading="lazy">
        <img src={enc07.src} alt="Encuentros — Detalle de intervención escultórica" loading="lazy">
        <img src={enc08.src} alt="Encuentros — Forma humana en rama de árbol" loading="lazy">

        <h3 style="margin-top: var(--s3);">ENCUENTROS CON SERES NOTABLES</h3>
        <img src={seres01.src} alt="Encuentros con seres notables — Escultura tallada sobre rama" loading="lazy">
        <img src={seres03.src} alt="Encuentros con seres notables — Cuerpo vegetal intervenido" loading="lazy">
        <img src={seres04.src} alt="Encuentros con seres notables — Detalle de talla en madera" loading="lazy">
        <img src={seres05.src} alt="Encuentros con seres notables — Forma orgánica tallada" loading="lazy">
        <img src={seres06.src} alt="Encuentros con seres notables — Rama con figura escultórica" loading="lazy">
        <img src={seres10.src} alt="Encuentros con seres notables — Vista de conjunto" loading="lazy">

        <h3 style="margin-top: var(--s3);">MESA DE TRABAJO</h3>
        <img src={mesa01.src} alt="Mesa de trabajo — Vista general del espacio de trabajo" loading="lazy">
        <img src={mesa15.src} alt="Mesa de trabajo — Herramientas y materiales" loading="lazy">
        <img src={mesa16.src} alt="Mesa de trabajo — Proceso de talla" loading="lazy">
        <img src={mesa17.src} alt="Mesa de trabajo — Ramas en preparación" loading="lazy">
        <img class="img-small" src={mesa18.src} alt="Mesa de trabajo — Detalle de proceso creativo" loading="lazy">
        <img class="img-small" src={mesa19.src} alt="Mesa de trabajo — Piezas en desarrollo" loading="lazy">
        <img class="img-small" src={mesa20.src} alt="Mesa de trabajo — Material escultórico" loading="lazy">
        <img src={mesa21.src} alt="Mesa de trabajo — Fragmentos de talla" loading="lazy">
        <img src={mesa22.src} alt="Mesa de trabajo — Elementos de trabajo" loading="lazy">
        <img src={mesa23.src} alt="Mesa de trabajo — Vista del taller" loading="lazy">
        <img src={mesa24.src} alt="Mesa de trabajo — Detalle de herramientas" loading="lazy">
        <img src={mesa25.src} alt="Mesa de trabajo — Piezas terminadas" loading="lazy">
        <img src={mesa26.src} alt="Mesa de trabajo — Registro de proceso" loading="lazy">
        <img src={mesa27.src} alt="Mesa de trabajo — Vista final del espacio" loading="lazy">

        <h3 style="margin-top: var(--s3);">ARBOREA</h3>
        <img src={arborea08.src} alt="Arbórea — Escultura arbórea intervenida" loading="lazy">
        <img src={arborea09.src} alt="Arbórea — Detalle de intervención sobre árbol" loading="lazy">

        <h3 style="margin-top: var(--s3);">ENCUENTROS CERCANOS</h3>
        <img src={cercanos12.src} alt="Encuentros cercanos — Figura tallada en primer plano" loading="lazy">
        <img src={cercanos13.src} alt="Encuentros cercanos — Detalle de forma escultórica" loading="lazy">
        <img src={cercanos14.src} alt="Encuentros cercanos — Vista cercana de talla" loading="lazy">

        <h3 style="margin-top: var(--s3);">LAS CAMINANTES</h3>
        <img src={caminantes11.src} alt="Las caminantes — Figura caminante tallada en rama" loading="lazy">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Encuentros</span>
        </div>
        <video controls preload="metadata">
          <source src="/maria-elvira-escallon/video/encuentros-web.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Con estas piezas, ponemos en consideración las características que nos aproximan a los seres vegetales, en lugar de poner el acento en aquello que nos diferencia de las demás especies y familias, como se ha hecho durante siglos. El proyecto también sugiere una imagen del humano modificada, cuya estructura anatómica se asocia y dialoga con la de los seres vegetales.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Encuentros -1 En este conjunto de piezas escultóricas ramas de distintas especies botánicas se encuentran y se funden unas en otras surgiendo un continuo. Así una rama de encenillo -especie nativa del sub páramo de los Andes- se funde con una rama de eucalipto, especie proviene del Japón. La serie remata con la pieza La superneurona, realizada en Francia, donde se acopla la copa de un pino proveniente de América con un Castaño Blanco Europeo.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Encuentros con Seres Notables. La pieza nos presenta simultáneamente tres imágenes que el público puede reconocer de inmediato: la imagen de la pintura La creación de Adán de Miguel Ángel, la imagen de los huesos de brazos y manos humanos y, las ramas de dos variedades de árboles levemente intervenidas. Suscita asociaciones con conceptos de creación, vida, muerte, tanto como de pactos, alianzas y transmisiones de conocimiento. Nos presenta fusiones entre especies distantes e incluso entre diferentes reinos.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            En el video Mesa de trabajo, es parte de esta serie, una replica del rostro de la escultura de Venus, es quebradas y reducida a polvo con ayuda de varios implementos domésticos. Dicho polvo después se mezcla con agua para modelar una figura que reúne anatomía humana y vegetal.
          </p>

        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Encuentros</strong><br>
            2017–2022<br><br>
            Escultura — ramas de jazmín de la sabana, eucalipto, talla en madera, arcilla.<br><br>
            Dimensiones variables.
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2017–2022). <em>Encuentros</em>.
            Escultura. Disponible en:
            mariaelviraescallon.com/es/obra/encuentros-con-seres-notables/
          </div>
        </aside>
      </div>

  </article>

</Layout>

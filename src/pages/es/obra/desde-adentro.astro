---
import Layout from '../../../components/layout/Layout.astro';
import AudioPlayer from '../../../components/interactive/AudioPlayer';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Desde Adentro';

const img1 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-01.jpg')).default;
const img2 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-02.jpg')).default;
const img3 = (await import('../../../assets/images/obras/desde-adentro/desde-adentro-03.jpg')).default;
const img4 = (await import('../../../assets/images/obras/desde-adentro/port-067.jpg')).default;
const img5 = (await import('../../../assets/images/obras/desde-adentro/port-069.jpg')).default;
const img6 = (await import('../../../assets/images/obras/desde-adentro/port-073.jpg')).default;
const img7 = (await import('../../../assets/images/obras/desde-adentro/port-076.jpg')).default;
const img8 = (await import('../../../assets/images/obras/desde-adentro/port-079.jpg')).default;
const img9 = (await import('../../../assets/images/obras/desde-adentro/port-080.jpg')).default;
---

<Layout
  lang={lang}
  title="Desde Adentro — Obra"
  description="Desde Adentro (2003). 12 fotografías tipo C, video-instalación de 12 horas. Documentación del atentado al Club El Nogal. María Elvira Escallón."
>

  <ArtworkSchema
    title="Desde Adentro"
    year="2003"
    medium="12 fotografías tipo C, video-instalación de 12 horas"
    dimensions="89 × 123 cm (fotografías), edición de 5"
    description="Documentación fotográfica y en video de las secuelas del atentado al Club El Nogal, Bogotá. Las huellas de las personas ausentes y los objetos desaparecidos transportan al espectador a momentos vividos."
    url="https://mariaelviraescallon.com/es/obra/desde-adentro/"
    collections={["Art Gallery of New South Wales, Sydney", "Banco de la República, Bogotá"]}
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 004</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2003 &nbsp;/&nbsp; 12 fotografías tipo C, video-instalación de 12 horas &nbsp;/&nbsp; 89 × 123 cm (fotografías), edición de 5</p>
      </header>

      <!-- Galería principal -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Desde Adentro — Documentación fotográfica del interior del Club El Nogal tras el atentado" loading="eager">
        <img src={img2.src} alt="Desde Adentro — Huellas y rastros sobre superficies cubiertas de ceniza" loading="lazy">
        <img src={img3.src} alt="Desde Adentro — Detalle de objetos cotidianos tras la explosión" loading="lazy">
        <img src={img4.src} alt="Desde Adentro — Impresiones sobre superficies cubiertas de ceniza" loading="lazy">
        <img src={img5.src} alt="Desde Adentro — Rastros y siluetas de objetos desaparecidos" loading="lazy">
        <img src={img6.src} alt="Desde Adentro — Huellas de manos sobre muros cubiertos de hollín" loading="lazy">
        <img src={img7.src} alt="Desde Adentro — Escaleras y pasillos tras el atentado" loading="lazy">
        <img src={img8.src} alt="Desde Adentro — Contornos de cuadros descolgados en la pared" loading="lazy">
        <img src={img9.src} alt="Desde Adentro — Registro fotográfico de la destrucción interior" loading="lazy">
      </div>

      <!-- Audio -->
      <div style="margin: var(--s3) 0;">
        <AudioPlayer client:visible title="María Elvira sobre Desde Adentro" />
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            Cinco días después del atentado terrorista contra el Club El Nogal en febrero de
            2003, Escallón — quien se desempeñaba como Directora Cultural del club — documentó
            las secuelas en 12 fotografías y un video de 12 horas. Las huellas de las personas
            ausentes y los objetos desaparecidos transportan al espectador a momentos vividos,
            a pesar de llegar «tarde a la escena de los hechos».
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Las fotografías capturan impresiones encontradas sobre superficies y objetos
            cotidianos — puertas, muros, escaleras — preservando la atmósfera de destrucción
            y la memoria del incidente. La película de ceniza que cubría todo se convirtió en
            un registro de la ausencia. Los rastros funcionan como índices de lo que ya no está:
            las marcas de manos, los contornos de cuadros descolgados, las siluetas de objetos
            volatilizados.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            La video-instalación de 12 horas recorre lentamente los espacios devastados,
            construyendo un tiempo paralelo al de la destrucción. La cámara se detiene en
            detalles que la mirada cotidiana pasaría por alto, convirtiendo el documento en
            una meditación sobre la fragilidad de los espacios que habitamos.
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXTO</h3>
          <p style="margin-top: var(--s2);">
            El 7 de febrero de 2003, un carro bomba explotó dentro del Club El Nogal en el
            norte de Bogotá, matando a 36 personas e hiriendo a más de 200. El atentado fue
            atribuido a las FARC y sacudió profundamente a la sociedad colombiana. La
            documentación de Escallón se convirtió en una de las respuestas artísticas más
            significativas a la violencia urbana en el arte contemporáneo colombiano.
          </p>
          <p style="margin-top: var(--s2);">
            La posición singular de Escallón — como Directora Cultural del club y artista
            visual — le permitió un acceso único al escenario del atentado. Su documentación
            opera en la intersección entre el registro forense y la mirada artística,
            transformando la evidencia de la destrucción en una reflexión sobre la pérdida,
            la memoria y la huella como forma de presencia.
          </p>
          <p style="margin-top: var(--s2);">
            <em>Desde Adentro</em> consolidó la práctica de Escallón en torno a la llegada
            «tarde a la escena de los hechos» — una posición que se repetirá en obras
            posteriores como <em>En estado de coma</em> — donde la artista no documenta el
            evento sino sus consecuencias, los rastros que permanecen cuando todo lo demás
            ha desaparecido.
          </p>
        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Desde Adentro</strong><br>
            2003<br><br>
            12 fotografías tipo C.<br>
            Video-instalación de 12 horas.<br><br>
            89 × 123 cm (fotografías)<br>
            Edición de 5<br><br>
            Club El Nogal, Bogotá.
          </div>

          <h4 style="margin-top: var(--s3);">COLECCIONES</h4>
          <div class="ficha">
            Art Gallery of New South Wales, Sydney<br>
            Banco de la República, Bogotá
          </div>

          <h4 style="margin-top: var(--s3);">EXPOSICIONES</h4>
          <div class="ficha">
            Art Gallery of New South Wales, Sydney<br>
            Banco de la República, Bogotá
          </div>

          <h4 style="margin-top: var(--s3);">TEXTOS</h4>
          <div class="ficha">
            <a href="/maria-elvira-escallon/es/textos/" style="color: var(--moss); border-bottom: 1px solid var(--paper-dark);">
              Textos relacionados
            </a>
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2003). <em>Desde Adentro</em>.
            Fotografía y video-instalación. Disponible en:
            mariaelviraescallon.com/es/obra/desde-adentro/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  .work-page {
    padding-top: calc(var(--s5) + 40px);
  }

  .work-page__header {
    margin-bottom: var(--s4);
  }

  .work-page__header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4rem);
    margin: var(--s1) 0;
  }

  .work-page__meta {
    font-size: 0.75rem;
    color: var(--ash);
    letter-spacing: 0.03em;
  }

  .work-page__gallery {
    display: grid;
    gap: var(--s2);
    margin-bottom: var(--s4);
  }

  .work-page__gallery img {
    width: 100%;
    display: block;
  }

  .work-page__body {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--s5);
    margin-bottom: var(--s5);
  }

  .work-page__text h3 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--ash);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .work-page__ficha h4 {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    margin-bottom: var(--s1);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .placeholder-img {
    width: 100%;
    background-color: var(--paper-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ash-light);
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .work-page__body {
      grid-template-columns: 1fr;
    }
  }
</style>

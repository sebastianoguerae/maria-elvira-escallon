---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Precipitación de arenas';

// Rio Cauca 2008 (root)
const prec01 = (await import('../../../assets/images/obras/precipitacion/precipitacion-01.webp')).default;
const prec02 = (await import('../../../assets/images/obras/precipitacion/precipitacion-02.webp')).default;
// 2020
const y2020_01 = (await import('../../../assets/images/obras/precipitacion/2020/2020-01.webp')).default;
const y2020_02 = (await import('../../../assets/images/obras/precipitacion/2020/2020-02.webp')).default;
const y2020_03 = (await import('../../../assets/images/obras/precipitacion/2020/2020-03.webp')).default;
const y2020_04 = (await import('../../../assets/images/obras/precipitacion/2020/2020-04.webp')).default;
// 2024
const y2024_01 = (await import('../../../assets/images/obras/precipitacion/2024/2024-01.webp')).default;
const y2024_02 = (await import('../../../assets/images/obras/precipitacion/2024/2024-02.webp')).default;
const y2024_03 = (await import('../../../assets/images/obras/precipitacion/2024/2024-03.webp')).default;
const y2024_04 = (await import('../../../assets/images/obras/precipitacion/2024/2024-04.webp')).default;
const y2024_05 = (await import('../../../assets/images/obras/precipitacion/2024/2024-05.webp')).default;
const y2024_06 = (await import('../../../assets/images/obras/precipitacion/2024/2024-06.webp')).default;
const y2024_07 = (await import('../../../assets/images/obras/precipitacion/2024/2024-07.webp')).default;
---

<Layout
  lang={lang}
  title="Precipitación de arenas — Obra"
  description="Precipitación de arenas (2022–2024). Instalación — arena, muebles, vidrio de seguridad, parlante. María Elvira Escallón."
>

  
  <ArtworkSchema
    title="Precipitación de arenas"
    year="2022–2024"
    medium="Instalación"
    description="Arena precipitándose lentamente sobre objetos domésticos dentro de una vitrina sellada. MAMU, Bogotá."
    url="https://mariaelviraescallon.com/es/obra/precipitacion-de-arenas/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 010</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022–2024 (varias versiones) &nbsp;/&nbsp; Instalación — arena, muebles, vidrio de seguridad, parlante &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galeria -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">RIO CAUCA, 2008</h3>
        <img src={prec01.src} alt="Precipitación de arenas — Río Cauca, arena precipitándose" loading="eager">
        <img src={prec02.src} alt="Precipitación de arenas — Río Cauca, registro de arena" loading="lazy">

        <h3 style="margin-top: var(--s3);">PRECIPITACIONES 2020</h3>
        <img src={y2020_01.src} alt="Precipitación de arenas 2020 — Instalación con arena y muebles" loading="lazy">
        <img src={y2020_02.src} alt="Precipitación de arenas 2020 — Arena sobre objetos domésticos" loading="lazy">
        <img src={y2020_03.src} alt="Precipitación de arenas 2020 — Detalle de vitrina sellada" loading="lazy">
        <img src={y2020_04.src} alt="Precipitación de arenas 2020 — Vista de conjunto" loading="lazy">

        <h3 style="margin-top: var(--s3);">PRECIPITACIONES 2024</h3>
        <img src={y2024_01.src} alt="Precipitación de arenas 2024 — Instalación en el MAMU" loading="lazy">
        <img src={y2024_02.src} alt="Precipitación de arenas 2024 — Arena cayendo sobre muebles" loading="lazy">
        <img src={y2024_03.src} alt="Precipitación de arenas 2024 — Detalle de acumulación" loading="lazy">
        <img src={y2024_04.src} alt="Precipitación de arenas 2024 — Vidrio de seguridad y arena" loading="lazy">
        <img src={y2024_05.src} alt="Precipitación de arenas 2024 — Objetos cubiertos de arena" loading="lazy">
        <img src={y2024_06.src} alt="Precipitación de arenas 2024 — Vista lateral de instalación" loading="lazy">
        <img src={y2024_07.src} alt="Precipitación de arenas 2024 — Vista final de la obra" loading="lazy">
      </div>
  </article>

</Layout>

---
import Layout from '../../../components/layout/Layout.astro';
import ArtworkSchema from '../../../components/seo/ArtworkSchema.astro';

const lang = 'es' as const;
const title = 'Precipitación de arenas';

// Cauca 2008 (root)
const imgsCauca = await Promise.all(
  ['01','02'].map(n =>
    import(`../../../assets/images/obras/precipitacion/precipitacion-${n}.webp`)
  )
).then(m => m.map(x => x.default));
// 2020
const imgs2020 = await Promise.all(
  Array.from({ length: 4 }, (_, i) =>
    import(`../../../assets/images/obras/precipitacion/2020/2020-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
// 2024
const imgs2024 = await Promise.all(
  Array.from({ length: 7 }, (_, i) =>
    import(`../../../assets/images/obras/precipitacion/2024/2024-${String(i + 1).padStart(2, '0')}.webp`)
  )
).then(m => m.map(x => x.default));
---

<Layout
  lang={lang}
  title="Precipitación de arenas — Obra"
  description="Precipitación de arenas (2022–2024). Instalación — arena, muebles, vidrio de seguridad, parlante. María Elvira Escallón."
>

  
  <ArtworkSchema
    title="Precipitación de arenas"
    year="2022–2024"
    medium="Instalación"
    description="Arena precipitándose lentamente sobre objetos domésticos dentro de una vitrina sellada. MAMU, Bogotá."
    url="https://mariaelviraescallon.com/es/obra/precipitacion-de-arenas/"
  />

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 010</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022–2024 (varias versiones) &nbsp;/&nbsp; Instalación — arena, muebles, vidrio de seguridad, parlante &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galeria: Cauca 2008 -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">CAUCA 2008</h3>
        {imgsCauca.map((img, i) => (
          <img src={img.src} alt={`Precipitación de arenas — Cauca 2008, imagen ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'}>
        ))}
      </div>

      <!-- Galeria: 2020 -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">PRECIPITACIONES 2020</h3>
        {imgs2020.map((img, i) => (
          <img src={img.src} alt={`Precipitación de arenas 2020 — Imagen ${i + 1}`} loading="lazy">
        ))}
      </div>

      <!-- Galeria: 2024 -->
      <div class="work-page__gallery">
        <h3 style="margin-top: var(--s3);">PRECIPITACIONES 2024</h3>
        {imgs2024.map((img, i) => (
          <img src={img.src} alt={`Precipitación de arenas 2024 — Imagen ${i + 1}`} loading="lazy">
        ))}
      </div>
  </article>

</Layout>

<style>
  @media (max-width: 768px) {
    }
</style>

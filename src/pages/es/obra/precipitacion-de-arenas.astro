---
import Layout from '../../../components/layout/Layout.astro';

const lang = 'es' as const;
const title = 'Precipitación de arenas';

const img1 = (await import('../../../assets/images/obras/precipitacion/precipitacion-mamu-2024.jpg')).default;
const img2 = (await import('../../../assets/images/obras/precipitacion/port-126.jpg')).default;
const img3 = (await import('../../../assets/images/obras/precipitacion/port-127.jpg')).default;
const img4 = (await import('../../../assets/images/obras/precipitacion/port-129.jpg')).default;
const img5 = (await import('../../../assets/images/obras/precipitacion/port-131.jpg')).default;
const img6 = (await import('../../../assets/images/obras/precipitacion/port-134.jpg')).default;
const img7 = (await import('../../../assets/images/obras/precipitacion/port-138.jpg')).default;
const img8 = (await import('../../../assets/images/obras/precipitacion/port-140.jpg')).default;
---

<Layout
  lang={lang}
  title="Precipitación de arenas — Obra"
  description="Precipitación de arenas (2022–2024). Instalación — arena, muebles, vidrio de seguridad, parlante. María Elvira Escallón."
>

  <article class="work-page">
    <div class="container">

      <!-- Header -->
      <header class="work-page__header">
        <p class="label">Obra / 010</p>
        <h1>{title}</h1>
        <p class="work-page__meta">2022–2024 (varias versiones) &nbsp;/&nbsp; Instalación — arena, muebles, vidrio de seguridad, parlante &nbsp;/&nbsp; Dimensiones variables</p>
      </header>

      <!-- Galería principal -->
      <div class="work-page__gallery">
        <img src={img1.src} alt="Precipitaciones 2024 — Arena cayendo sobre mesas, MAMU" loading="eager">
        <img src={img2.src} alt="Precipitación de arenas — Muebles siendo sepultados por arena dorada" loading="lazy">
        <img src={img3.src} alt="Precipitación de arenas — Detalle de la arena acumulándose sobre superficies" loading="lazy">
        <img src={img4.src} alt="Precipitación de arenas — Vista a través del vidrio de seguridad" loading="lazy">
        <img src={img5.src} alt="Precipitación de arenas — Objetos domésticos cubiertos de arena" loading="lazy">
        <img src={img6.src} alt="Precipitación de arenas — Arena cayendo desde el techo" loading="lazy">
        <img src={img7.src} alt="Precipitación de arenas — Estado avanzado de la instalación" loading="lazy">
        <img src={img8.src} alt="Precipitación de arenas — Vista general de la sala en el MAMU" loading="lazy">
      </div>

      <!-- Video -->
      <div class="work-page__video">
        <div class="work-page__video-header">
          <h3>VIDEO</h3>
          <span class="label">Polvo eres — Video relacionado · 2:00 min</span>
        </div>
        <video controls preload="metadata" poster="">
          <source src="/maria-elvira-escallon/video/polvo-eres-obra.mp4" type="video/mp4">
          Tu navegador no soporta video HTML5.
        </video>
      </div>

      <!-- Texto + Ficha -->
      <div class="work-page__body">
        <div class="work-page__text">

          <p class="curatorial">
            La obra busca transformar un fenómeno no físico —el paso del tiempo— en algo material
            y tangible. Escallón define estas piezas como "dispositivos para ver pasar el tiempo."
            Arena dorada del río Guamo cae desde el techo en diferentes intervalos, cubriendo
            superficies y transformando constantemente el estado de la habitación.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            Muebles domésticos comprimidos son gradualmente sepultados bajo toneladas de arena.
            El espacio está separado del espectador por un vidrio de seguridad y un parlante
            permite escuchar el ruido de la caída. Los objetos personales se convierten en restos
            arqueológicos. En la versión del MAMU se precipitaron 10 toneladas de arena por
            primera vez, amplificando la escala e impacto de la instalación.
          </p>

          <p class="curatorial" style="margin-top: var(--s2);">
            La obra se desarrolló a partir del concepto anterior "Precipitaciones del río Cauca."
          </p>

          <h3 style="margin-top: var(--s4);">CONTEXTO</h3>
          <p style="margin-top: var(--s2);">
            <em>Precipitación de arenas</em> ha tenido múltiples versiones, cada una adaptada
            al espacio de exhibición específico. La versión presentada en el MAMU en 2024 fue
            la más ambiciosa, con 10 toneladas de arena precipitándose sobre los muebles
            comprimidos. La pieza transforma la sala de exhibición en un dispositivo poético
            donde el tiempo se hace visible a través de la acumulación material.
          </p>

          <h3 style="margin-top: var(--s4);">EXPOSICIONES</h3>
          <ul style="margin-top: var(--s2); list-style: none;">
            <li style="padding: var(--s1) 0; border-bottom: 1px solid var(--paper-dark);">
              <strong>Encuentros en la fábrica de polvo</strong> — MAMU, Bogotá, 2024. Versión más ambiciosa (10 toneladas de arena).
            </li>
            <li style="padding: var(--s1) 0;">
              <strong>Galería Espacio Continuo</strong> — Bogotá, 2022.
            </li>
          </ul>
        </div>

        <aside class="work-page__ficha">
          <h4>FICHA TÉCNICA</h4>
          <div class="ficha">
            <strong>Precipitación de arenas</strong><br>
            2022–2024 (varias versiones)<br><br>
            Instalación — arena, muebles, vidrio de seguridad, parlante.<br><br>
            Dimensiones variables<br>
            Múltiples sedes / MAMU, Bogotá (2024, versión más ambiciosa)
          </div>

          <h4 style="margin-top: var(--s3);">EXPOSICIONES</h4>
          <div class="ficha">
            Encuentros en la fábrica de polvo — MAMU, 2024<br>
            Galería Espacio Continuo, 2022
          </div>

          <h4 style="margin-top: var(--s3);">CÓMO CITAR</h4>
          <div class="ficha" style="font-size: 0.65rem;">
            Escallón, M.E. (2022–2024). <em>Precipitación de arenas</em>.
            Instalación. Disponible en:
            mariaelviraescallon.com/es/obra/precipitacion-de-arenas/
          </div>
        </aside>
      </div>

    </div>
  </article>

</Layout>

<style>
  .work-page {
    padding-top: calc(var(--s5) + 40px);
  }

  .work-page__header {
    margin-bottom: var(--s4);
  }

  .work-page__header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4rem);
    margin: var(--s1) 0;
  }

  .work-page__meta {
    font-size: 0.75rem;
    color: var(--ash);
    letter-spacing: 0.03em;
  }

  .work-page__gallery {
    display: grid;
    gap: var(--s2);
    margin-bottom: var(--s4);
  }

  .work-page__gallery img {
    width: 100%;
    display: block;
  }

  .work-page__body {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--s5);
    margin-bottom: var(--s5);
  }

  .work-page__text h3 {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--ash);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .work-page__ficha h4 {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    margin-bottom: var(--s1);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .placeholder-img {
    width: 100%;
    background-color: var(--paper-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ash-light);
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-page__video {
    margin: var(--s4) 0;
  }
  .work-page__video-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s2);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--ink);
  }
  .work-page__video-header h3 {
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .work-page__video video {
    width: 100%;
    background: var(--ink);
    display: block;
  }

  @media (max-width: 768px) {
    .work-page__body {
      grid-template-columns: 1fr;
    }
  }
</style>

---

<Layout lang={lang} title="Exposiciones" description="Historia completa de exposiciones de María Elvira Escallón: individuales y colectivas internacionales, 1997–2024. Bogotá, París, Londres, La Habana, Nueva York.">

  <!-- Hero with Polvo Eres video -->
  <section class="expo-hero">
    <div class="expo-hero__video-bg">
      <video autoplay muted loop playsinline>
        <source src="/maria-elvira-escallon/video/hero-polvo-v3.mp4" type="video/mp4">
      </video>
    </div>
    <div class="container" style="position: relative; z-index: 2;">
      <div class="expo-hero__content">
        <p class="hero__label">Archivo / 1997–2024</p>
        <h1 class="hero__name">Exposiciones</h1>
        <p class="hero__sub">{individuales.length} individuales &nbsp;&middot;&nbsp; {colectivas.length} colectivas internacionales</p>
        <p class="hero__meta">
          Bogotá &middot; París &middot; Londres &middot; La Habana &middot; Nueva York &middot; Sydney &middot; Arles &middot; Berlín
        </p>
      </div>
    </div>
    <div class="expo-hero__scroll" aria-hidden="true">
      <span>&darr;</span>
    </div>
  </section>

  <div class="expo-index">
    <div class="container">

      <!-- Page header spacer (hero replaces the old header) -->

      <!-- ── Individuales ── -->
      <section class="expo-section">
        <h3 class="expo-section__title">Exposiciones individuales</h3>
        <div class="expo-list">
          {individuales.map((e) => (
            <div class="expo-entry">
              <div class="expo-entry__year">{e.year}</div>
              <div class="expo-entry__info">
                {e.slug ? (
                  <a href={`/maria-elvira-escallon/es/exposiciones/${e.slug}/`} class="expo-entry__link">
                    <strong>{e.title}</strong>
                  </a>
                ) : (
                  <strong>{e.title}</strong>
                )}
                {e.note && <span class="expo-entry__note"> ({e.note})</span>}
                <span class="expo-entry__venue">
                  {e.venue ? `${e.venue}, ${e.city}` : e.city}
                </span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <hr class="rule rule--light" />

      <!-- ── Colectivas internacionales ── -->
      <section class="expo-section">
        <h3 class="expo-section__title">Exposiciones colectivas internacionales</h3>
        <div class="expo-list">
          {colectivas.map((e) => (
            <div class="expo-entry">
              <div class="expo-entry__year">{e.year}</div>
              <div class="expo-entry__info">
                {e.slug ? (
                  <a href={`/maria-elvira-escallon/es/exposiciones/${e.slug}/`} class="expo-entry__link">
                    <strong>{e.title}</strong>
                  </a>
                ) : (
                  <strong>{e.title}</strong>
                )}
                {e.note && <span class="expo-entry__note"> ({e.note})</span>}
                <span class="expo-entry__venue">
                  {e.venue ? `${e.venue}, ${e.city}` : e.city}
                </span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Nota al pie ── -->
      <div class="expo-footnote">
        <p>Para una lista completa, consultar el CV de la artista disponible en <a href="https://www.espaciocontinuo.com" target="_blank" rel="noopener noreferrer">Galería Espacio Continuo</a>.</p>
      </div>

    </div>
  </div>

</Layout>

<style>
  /* ── Hero with video ── */
  .expo-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s4);
    overflow: hidden;
    border-bottom: 1px solid var(--ink);
  }

  .expo-hero__video-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }

  .expo-hero__video-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
    filter: grayscale(40%) contrast(1.1);
    mix-blend-mode: multiply;
  }

  .expo-hero__content {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--s3);
    width: 100%;
  }

  .expo-hero__scroll {
    position: absolute;
    bottom: var(--s3);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 1.4rem;
    color: var(--ash-light);
    z-index: 2;
    animation: expo-bounce 2s ease infinite;
  }

  @keyframes expo-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ── Page wrapper ── */
  .expo-index {
    padding-top: var(--s4);
    padding-bottom: var(--s5);
  }

  /* ── Section titles ── */
  .expo-section {
    margin-top: var(--s4);
  }

  .expo-section__title {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    padding-bottom: var(--s2);
    border-bottom: 1px solid var(--ink);
    margin-bottom: 0;
  }

  /* ── Entry grid ── */
  .expo-list {
    margin: 0;
  }

  .expo-entry {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--s3);
    padding: var(--s2) 0;
    border-bottom: 1px solid var(--paper-dark);
    align-items: baseline;
  }

  .expo-entry:last-child {
    border-bottom: 1px solid var(--ash-light);
  }

  .expo-entry__year {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ash-light);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .expo-entry__info {
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--ink);
  }

  .expo-entry__info strong {
    font-weight: 700;
    font-size: 0.8rem;
  }

  .expo-entry__note {
    font-size: 0.7rem;
    color: var(--ash);
    font-style: italic;
  }

  .expo-entry__venue {
    display: block;
    font-size: 0.7rem;
    color: var(--ash);
    margin-top: 2px;
    line-height: 1.5;
  }

  /* ── Links ── */
  .expo-entry__link {
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--ash-light);
    padding-bottom: 1px;
    transition: border-color 0.2s, color 0.2s;
  }

  .expo-entry__link:hover {
    border-bottom-color: var(--ink);
  }

  .expo-entry__link strong {
    font-weight: 700;
  }

  /* ── Footnote ── */
  .expo-footnote {
    margin-top: var(--s5);
    padding-top: var(--s3);
    border-top: 1px dashed var(--ash-light);
  }

  .expo-footnote p {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--ash);
    letter-spacing: 0.04em;
    line-height: 1.8;
    max-width: var(--text-w);
  }

  .expo-footnote a {
    color: var(--ash);
    border-bottom: 1px solid var(--ash-light);
    transition: color 0.2s, border-color 0.2s;
  }

  .expo-footnote a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .expo-entry {
      grid-template-columns: 56px 1fr;
      gap: var(--s2);
      padding: var(--s1) 0;
    }

    .expo-entry__year {
      font-size: 0.7rem;
    }

    .expo-entry__info {
      font-size: 0.75rem;
    }

    .expo-entry__info strong {
      font-size: 0.75rem;
    }

    .expo-entry__venue {
      font-size: 0.65rem;
    }

    .expo-section__title {
      font-size: 0.65rem;
    }
  }
</style>

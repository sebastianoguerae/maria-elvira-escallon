---
import Layout from '../../components/layout/Layout.astro';
import ArtistSchema from '../../components/seo/ArtistSchema.astro';

const lang = 'es' as const;
const title = 'Biografía';

const retrato = (await import('../../assets/images/retrato/retrato.jpg')).default;
const libroEnEstadoDeComa = (await import('../../assets/images/libros/en-estado-de-coma-libro.jpg')).default;
const libroPolvoEres = (await import('../../assets/images/libros/polvo-eres-portada.jpg')).default;
const libroEncuentros = (await import('../../assets/images/libros/encuentros-catalogo-001.jpg')).default;
---

<Layout
  lang={lang}
  title="Biografía — María Elvira Escallón"
  description="Biografía de María Elvira Escallón. Artista visual colombiana. Nacida en Londres, 1954. Escultura, instalación, fotografía."
>

  <ArtistSchema />

  <article class="bio-page">
    <div class="container">

      <!-- ===== 1. OPENING ===== -->
      <header class="bio-page__header">
        <p class="label">Biografía</p>
        <h1>María Elvira<br>Escallón</h1>
      </header>

      <div class="bio-page__opening">
        <div class="bio-page__portrait">
          <img src={retrato.src} alt="Retrato de María Elvira Escallón" loading="eager">
        </div>
        <div class="bio-page__intro">
          <p class="curatorial" style="margin-top: var(--s3);">
            Escultora, instaladora y fotógrafa colombiana, su trabajo se caracteriza por investigaciones de larga duración y procesos extendidos. Con frecuencia realiza acciones o intervenciones escultóricas de carácter efímero o en lugares inaccesibles que luego documenta en fotografía o video. Otras veces, instala dispositivos para señalar o crear una condición especial de observación. Los recursos expositivos a los que recurre surgen de sueños, intuiciones o procesos expandidos. Su obra se desarrolla en torno a temas como el tiempo, la memoria, la ruina y la vulnerabilidad de los monumentos. Así mismo, es central su reflexión sobre la relación cultura-naturaleza. Sus últimos trabajos se dirigen a enfatizar el vínculo entre los seres humanos y los seres vegetales.
          </p>
        </div>
      </div>

      <hr class="rule">

      <!-- ===== 2. PREMIOS Y RECONOCIMIENTOS ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Premios y Reconocimientos</h2>
          <span class="label">1993–2024</span>
        </div>

        <div class="bio-entry bio-entry--highlight">
          <span class="bio-entry__year">2024</span>
          <div class="bio-entry__info">
            <strong>Premio Nacional de Fotografía</strong>
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2019</span>
          <div class="bio-entry__info">
            Mención de Honor — Beca de Creación Individual, Ministerio de Cultura
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2018</span>
          <div class="bio-entry__info">
            Nominación X Premio Luis Caballero — IDARTES (<em>En el fértil suelo</em>)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2014</span>
          <div class="bio-entry__info">
            Beca Nacional de Creación Individual — MinCultura (<em>Aerolito</em>)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2006</span>
          <div class="bio-entry__info">
            Primer Premio Categoría Patrimonio — IDCT (<em>En estado de coma</em>)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2005</span>
          <div class="bio-entry__info">
            Beca Nacional de Creación Individual — MinCultura (<em>En estado de coma</em>)
          </div>
        </div>

        <div class="bio-entry bio-entry--highlight">
          <span class="bio-entry__year">2003</span>
          <div class="bio-entry__info">
            <strong>Primer Premio — III Premio Luis Caballero (<em>Nuevas Floras</em>)</strong>
          </div>
        </div>

        <div class="bio-entry bio-entry--highlight">
          <span class="bio-entry__year">1997</span>
          <div class="bio-entry__info">
            <strong>Primer Premio — VIII Salón Regional Zona Centro (<em>In Vitro</em>)</strong>
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">1993</span>
          <div class="bio-entry__info">
            Primera Beca de Creación Individual — Colcultura (<em>Turismo en la frontera</em>)
          </div>
        </div>
      </section>

      <hr class="rule--light">

      <!-- ===== 3. EXPOSICIONES INDIVIDUALES ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Exposiciones Individuales Seleccionadas</h2>
          <span class="label">2000–2024</span>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2024</span>
          <div class="bio-entry__info">
            <em>Encuentros en la fábrica de polvo</em> — MAMU, Banco de la República (80 obras)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2019</span>
          <div class="bio-entry__info">
            <em>En el fértil suelo</em> — MAMBO
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2017</span>
          <div class="bio-entry__info">
            <em>Nuevas Floras Versalles</em> — Jardín de Tullerías/FIAC, Arboretum de Chevreloup, Francia
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2014</span>
          <div class="bio-entry__info">
            <em>Pequeño Museo del Aerolito</em> — Museo Nacional de Colombia
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2012</span>
          <div class="bio-entry__info">
            <em>Urgencias</em> — Museo de Arte Universidad Nacional
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2007</span>
          <div class="bio-entry__info">
            <em>En estado de coma</em> — Museo de Bogotá / Planetario Distrital
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2003</span>
          <div class="bio-entry__info">
            <em>Nuevas Floras</em> — Galería Santa Fe (III Premio Luis Caballero)
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2000</span>
          <div class="bio-entry__info">
            <em>El reino de este mundo</em> — MAMBO
          </div>
        </div>
      </section>

      <hr class="rule--light">

      <!-- ===== 4. EXPOSICIONES COLECTIVAS INTERNACIONALES ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Exposiciones Colectivas Internacionales</h2>
          <span class="label">2000–2019</span>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2019</span>
          <div class="bio-entry__info">
            <em>Urban Impulses: Latin American Photography</em> — The Photographers' Gallery, Londres
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2018</span>
          <div class="bio-entry__info">
            <em>Híbridos</em> — Deutsche Bank Gallery, Nueva York
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2017</span>
          <div class="bio-entry__info">
            <em>La vuelta</em> — Les Rencontres de la Photographie, Arles, Francia
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2013</span>
          <div class="bio-entry__info">
            <em>Palimpsestes</em> — Galería Mor-Charpentier, París / <em>In Motion</em> — Galeria Bianconi, Milán
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2011</span>
          <div class="bio-entry__info">
            VIII Bienal del Mercosur
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2009</span>
          <div class="bio-entry__info">
            X Bienal de La Habana
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2008</span>
          <div class="bio-entry__info">
            <em>Focus on Contemporary</em> — Sydney / <em>Colombian Contemporary Photography</em> — FotoFest, Houston
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2007</span>
          <div class="bio-entry__info">
            <em>Displaced: Contemporary Art from Colombia</em> — Glynn Vivian Gallery, Gales
          </div>
        </div>

        <div class="bio-entry">
          <span class="bio-entry__year">2000</span>
          <div class="bio-entry__info">
            VII Bienal de La Habana — <em>Escenas de Caza</em>
          </div>
        </div>
      </section>

      <hr class="rule">

      <!-- ===== 5. PUBLICACIONES ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Publicaciones</h2>
          <span class="label">Monografías</span>
        </div>

        <div class="bio-publications">

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover">
              <img src={libroEncuentros.src} alt="Portada — Encuentros en la fábrica de polvo" loading="lazy">
            </div>
            <div class="bio-pub-card__info">
              <h3>Encuentros en la fábrica de polvo</h3>
              <div class="ficha">
                2024<br>
                Catálogo exposición antológica<br>
                MAMU, Banco de la República
              </div>
            </div>
          </article>

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover bio-pub-card__cover--placeholder"></div>
            <div class="bio-pub-card__info">
              <h3>Colección Seguros Bolívar de Arte Contemporáneo</h3>
              <div class="ficha">
                2018<br>
                Dir. José Roca<br>
                Monografía, 112 pp.
              </div>
            </div>
          </article>

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover">
              <img src={libroPolvoEres.src} alt="Portada — Polvo Eres" loading="lazy">
            </div>
            <div class="bio-pub-card__info">
              <h3>Polvo Eres: El correr del tiempo</h3>
              <div class="ficha">
                2014<br>
                Julia Buenaventura<br>
                MinCultura, 212 pp.
              </div>
            </div>
          </article>

          <article class="bio-pub-card">
            <div class="bio-pub-card__cover">
              <img src={libroEnEstadoDeComa.src} alt="Portada — En estado de coma" loading="lazy">
            </div>
            <div class="bio-pub-card__info">
              <h3>En estado de coma</h3>
              <div class="ficha">
                2007<br>
                IDPC / Johns Hopkins
              </div>
            </div>
          </article>

        </div>
      </section>

      <hr class="rule">

      <!-- ===== 6. COLECCIONES + REPRESENTACIÓN ===== -->
      <section class="section">
        <div class="section__header">
          <h2>Colecciones y Representación</h2>
        </div>

        <div class="bio-two-col">
          <div class="bio-two-col__left">
            <h4>COLECCIONES</h4>
            <ul class="ficha">
              <li>Art Gallery of NSW, Sydney</li>
              <li>Banco de la República, Bogotá</li>
              <li>MAMBO — Museo de Arte Moderno de Bogotá</li>
              <li>Museo Nacional de Colombia</li>
              <li>ESCALA, Universidad de Essex, Reino Unido</li>
              <li>Colección Seguros Bolívar</li>
              <li>Fundación Alzate Avendaño</li>
              <li>FNAC, Francia</li>
              <li>Fundación Cisneros Fontanals (CIFO)</li>
              <li>LPS Latin American Photography Collection</li>
              <li>Art Gallery of South West Sydney</li>
            </ul>
          </div>

          <div class="bio-two-col__right">
            <h4>REPRESENTACIÓN</h4>
            <div class="ficha" style="margin-bottom: var(--s3);">
              Galería Espacio Continuo
            </div>

            <h4>DOCENCIA</h4>
            <div class="ficha">
              Universidad Javeriana (2007–presente)<br>
              MA Historia y Teoría del Arte — Universidad Nacional
            </div>
          </div>
        </div>
      </section>

    </div>
  </article>

</Layout>

<style>
  /* ===== Page base ===== */
  .bio-page {
    padding-top: calc(var(--s5) + 40px);
  }

  .bio-page__header {
    margin-bottom: var(--s4);
  }

  .bio-page__header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.4rem, 6vw, 5rem);
    line-height: 1;
    margin: var(--s1) 0;
  }

  /* ===== Opening: portrait + text grid ===== */
  .bio-page__opening {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--s4);
    margin-bottom: var(--s4);
    align-items: start;
  }

  .bio-page__portrait img {
    width: 100%;
    display: block;
    filter: grayscale(15%);
  }

  .bio-page__intro .curatorial {
    font-size: 1.15rem;
    line-height: 1.8;
  }

  /* ===== Bio entries (year + info) ===== */
  .bio-entry {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--s3);
    padding: var(--s2) 0;
    border-bottom: 1px solid var(--paper-dark);
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .bio-entry__year {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ash-light);
    padding-top: 0.15rem;
    letter-spacing: 0.05em;
  }

  .bio-entry__info {
    color: var(--ink-soft);
  }

  .bio-entry__info em {
    font-style: italic;
  }

  .bio-entry__info strong {
    font-weight: 700;
    color: var(--ink);
  }

  .bio-entry--highlight {
    background-color: var(--white);
  }

  /* ===== Publications grid ===== */
  .bio-publications {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s3);
  }

  .bio-pub-card {
    display: flex;
    flex-direction: column;
  }

  .bio-pub-card__cover {
    aspect-ratio: 3/4;
    background-color: var(--paper-dark);
    overflow: hidden;
    margin-bottom: var(--s2);
  }

  .bio-pub-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bio-pub-card__cover--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bio-pub-card__cover--placeholder span {
    font-family: var(--mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ash-light);
  }

  .bio-pub-card__info h3 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--s1);
  }

  /* ===== Two-column (Collections + Representation) ===== */
  .bio-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s5);
  }

  .bio-two-col h4 {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    margin-bottom: var(--s2);
    padding-bottom: var(--s1);
    border-bottom: 1px solid var(--paper-dark);
  }

  .bio-two-col ul {
    list-style: none;
  }

  .bio-two-col ul li {
    padding: var(--s1) 0;
    border-bottom: 1px solid var(--paper-dark);
  }

  /* ===== hr overrides inside bio-page ===== */
  .bio-page .rule--light {
    border: none;
    border-top: 1px solid var(--paper-dark);
    margin: var(--s4) 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .bio-page__opening {
      grid-template-columns: 1fr;
    }

    .bio-page__portrait {
      max-width: 280px;
    }

    .bio-entry {
      grid-template-columns: 56px 1fr;
      gap: var(--s2);
    }

    .bio-publications {
      grid-template-columns: 1fr;
    }

    .bio-two-col {
      grid-template-columns: 1fr;
      gap: var(--s4);
    }
  }
</style>

---
import { Image } from 'astro:assets';
import Layout from '../../components/layout/Layout.astro';
import QuoteBlock from '../../components/content/QuoteBlock.astro';
import ArtistSchema from '../../components/seo/ArtistSchema.astro';

const lang = 'es' as const;

const heroImage = (await import('../../assets/images/obras/ensayo-autorretrato/ensayo-autorretrato-06.webp')).default;
const expoActual = (await import('../../assets/images/obras/polvo-eres/polvo-eres-09.webp')).default;
const nuevasFloras = (await import('../../assets/images/obras/nuevas-floras/nuevas-floras-01.webp')).default;
const featuredComa = (await import('../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-01.webp')).default;
const desdeAdentro = (await import('../../assets/images/obras/desde-adentro/desde-adentro-01.webp')).default;
const retrato = (await import('../../assets/images/retrato/retrato.jpg')).default;
const enEstadoDeComaLibro = (await import('../../assets/images/libros/en-estado-de-coma-libro.jpg')).default;
const libroEncuentros = (await import('../../assets/images/libros/encuentros-catalogo-001.jpg')).default;
const libroPolvoEres = (await import('../../assets/images/libros/polvo-eres-portada.jpg')).default;
const libroSeguros = (await import('../../assets/images/libros/seguros-bolivar-001.jpg')).default;

const featuredWorks = [
  {
    slug: 'nuevas-floras',
    title: 'NUEVAS FLORAS',
    year: '2003',
    hasImage: true,
    major: true,
    importedImage: (await import('../../assets/images/obras/nuevas-floras/nuevas-floras-13.webp')).default,
  },
  {
    slug: 'encuentros-con-seres-notables',
    title: 'ENCUENTROS',
    year: '2022',
    hasImage: true,
    major: true,
    importedImage: (await import('../../assets/images/obras/encuentros/encuentros-con-seres-notables/encuentros-con-seres-notables-03.webp')).default,
  },
  {
    slug: 'en-estado-de-coma',
    title: 'EN ESTADO DE COMA',
    year: '2005-2007',
    hasImage: true,
    major: true,
    importedImage: (await import('../../assets/images/obras/en-estado-de-coma/cultivos/cultivos-01.webp')).default,
  },
  {
    slug: 'polvo-eres',
    title: 'POLVO ERES',
    year: '2024',
    hasImage: true,
    major: true,
    importedImage: (await import('../../assets/images/obras/polvo-eres/polvo-eres-portada.webp')).default,
  },
  {
    slug: 'precipitacion-de-arenas',
    title: 'PRECIPITACIÓN DE ARENAS',
    year: '2022-2024',
    hasImage: true,
    major: true,
    importedImage: (await import('../../assets/images/obras/precipitacion/precipitacion-01.webp')).default,
  },
  {
    slug: 'aerolito',
    title: 'PEQUEÑO MUSEO DEL AEROLITO',
    year: '2014-2015',
    hasImage: true,
    importedImage: (await import('../../assets/images/obras/aerolito/aerolito-01.webp')).default,
  },
  {
    slug: 'dispositivos-para-ver-pasar-el-tiempo',
    title: 'DISPOSITIVOS PARA VER PASAR EL TIEMPO',
    year: '2020',
    hasImage: true,
    importedImage: (await import('../../assets/images/obras/dispositivos/dispositivos-01.webp')).default,
  },
];

const timelineEntries = [
  { year: '2025', title: 'BIAM Medellín' },
  { year: '2024', title: 'Fábrica de polvo' },
  { year: '2022', title: 'Encuentros' },
  { year: '2020', title: 'Dispositivos' },
  { year: '2017', title: 'Nuevas Floras, Versalles' },
  { year: '2014', title: 'Aerolito' },
  { year: '2007', title: 'En estado de coma' },
  { year: '2003', title: 'Nuevas Floras' },
  { year: '2000', title: 'El reino de este mundo' },
  { year: '1997', title: 'In Vitro' },
];
---

<Layout lang={lang} description="Página oficial de María Elvira Escallón. Artista visual colombiana. Escultura, instalación, fotografía y video.">

  <ArtistSchema />

  <!-- Section 1: HERO with video -->
  <section class="hero home-section home-section--hero">
    <div class="hero-video-bg">
      <video autoplay muted loop playsinline poster={heroImage.src}>
        <source src="/video/hero-encuentros-v2.mp4" type="video/mp4">
      </video>
    </div>
    <div class="container" style="position: relative; z-index: 2;">
      <div class="hero__content">
        <p class="hero__label">Artista visual / Bogotá, Colombia</p>
        <h1 class="hero__name">María Elvira<br>Escallón</h1>
        <p class="hero__sub">El cuestionamiento de los límites entre lo natural y lo cultural</p>
        <p class="hero__meta">
          B. 1954, Londres &mdash; Vive y trabaja en Bogotá &nbsp;/&nbsp;
          Escultura &middot; Instalación &middot; Fotografía &middot; Video
        </p>
      </div>
    </div>
    <div class="home-scroll-indicator" aria-hidden="true" style="position: relative; z-index: 2;">
      <span>&darr;</span>
    </div>
  </section>

  <!-- Section 2: HERO IMAGE — full bleed -->
  <section class="home-hero-image fade-in">
    <Image src={heroImage} alt="Ensayo para un autorretrato — María Elvira Escallón" fetchpriority="high" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
    <div class="home-hero-image__caption">
      <span>Ensayo para un autorretrato, 2017–2022</span>
    </div>
  </section>

  <!-- Section 3: QUOTE (José Roca) -->
  <section class="home-section home-section--quote fade-in">
    <div class="container">
      <QuoteBlock
        annotation="Texto curatorial"
        quote="En un proceso de gran heterogeneidad formal donde cada obra sigue un rumbo propio, único y preciso, es posible sin embargo encontrar una constante en el trabajo de María Elvira Escallón: el cuestionamiento de los límites entre lo natural y lo cultural."
        cite="José Roca &mdash; Columna de Arena 53, 2003"
      />
    </div>
  </section>

  <!-- Section 3: FEATURED WORK -->
  <section class="home-section home-section--alt fade-in">
    <div class="container">
      <p class="label">Obra destacada</p>
      <a href="/es/obra/en-estado-de-coma/" class="home-featured">
        <Image src={featuredComa} alt="En estado de coma &mdash; María Elvira Escallón" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        <div class="home-featured__caption">
          <h3>EN ESTADO DE COMA</h3>
          <span class="ficha">2005&ndash;2007 &middot; Hospital San Juan de Dios</span>
        </div>
      </a>
      <a href="/es/obra/en-estado-de-coma/" class="home-teaser-link">Ver obra completa &rarr;</a>
    </div>
  </section>

  <!-- Section 4: WORKS PREVIEW -->
  <section class="home-section fade-in">
    <div class="container">
      <div class="section__header">
        <h2>Obra</h2>
        <span class="label">1997&ndash;2024</span>
      </div>

      <div class="works-grid">
        {featuredWorks.map((work) => (
          <a href={`/es/obra/${work.slug}/`} class="work-card-link" style="text-decoration:none; color:inherit;">
            <article class={`work-card-static ${work.major ? "work-card--major" : ""}`}>
              <div class="work-card__thumb">
                {work.hasImage && work.importedImage ? (
                  <Image src={work.importedImage} alt={`${work.title} \u2014 María Elvira Escallón`} loading="lazy" style="width:100%;height:auto;" widths={[400, 800]} sizes="(max-width: 640px) 50vw, 33vw" />
                ) : (
                  <div class="placeholder-img" style="height:100%;aspect-ratio:4/3;background:var(--paper-dark);"></div>
                )}
              </div>
              <div class="work-card__title">
                <h3>{work.title}</h3>
                <span class="year">{work.year}</span>
              </div>
            </article>
          </a>
        ))}
      </div>

      <div class="home-section__cta">
        <a href="/es/obra/" class="home-teaser-link">Ver catálogo completo &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Section 5: EXHIBITION HIGHLIGHT -->
  <section class="home-section home-section--alt fade-in">
    <div class="container">
      <a href="/es/obra/polvo-eres/" class="home-exhibition__image fade-in">
        <Image src={expoActual} alt="Polvo eres — instalación en el Edificio Coltabaco, I Bienal Internacional de Antioquia y Medellín" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
      </a>
      <div class="home-exhibition">
        <p class="label">Exposición actual</p>
        <h2 class="home-exhibition__title">Polvo eres</h2>
        <p class="home-exhibition__subtitle">
          I Bienal Internacional de Antioquia y Medellín (BIAM) &mdash; Edificio Coltabaco &mdash; 2025
        </p>
        <p class="home-exhibition__desc curatorial">
          Una nueva versión de Polvo eres instalada en el Edificio de Coltabaco. Un gran espacio tapizado con escombros provenientes de muros del propio edificio, donde emergen pequeñas plantas pioneras como si algo insistiese en resurgir.
        </p>
        <a href="/es/exposiciones/" class="home-teaser-link">Ver exposiciones &rarr;</a>
      </div>
    </div>
  </section>


  <!-- Section 7: TIMELINE TEASER -->
  <section class="home-section home-timeline-strip fade-in">
    <div class="container">
      <p class="label" style="color: var(--ash-light);">Línea de tiempo</p>
      <div class="home-timeline__entries">
        {timelineEntries.map((entry) => (
          <div class="home-timeline__entry">
            <span class="home-timeline__year">{entry.year}</span>
            <span class="home-timeline__title">{entry.title}</span>
          </div>
        ))}
      </div>
      <a href="/es/linea-de-tiempo/" class="home-teaser-link home-teaser-link--light">Explorar línea de tiempo &rarr;</a>
    </div>
  </section>

  <!-- Section 8: MAP TEASER -->
  <section class="home-section home-section--alt fade-in">
    <div class="container">
      <p class="label">Geografía</p>
      <div class="home-stats">
        <div class="home-stats__item">
          <span class="home-stats__number">15+</span>
          <span class="home-stats__label">ciudades</span>
        </div>
        <span class="home-stats__sep">&middot;</span>
        <div class="home-stats__item">
          <span class="home-stats__number">12+</span>
          <span class="home-stats__label">países</span>
        </div>
        <span class="home-stats__sep">&middot;</span>
        <div class="home-stats__item">
          <span class="home-stats__number">44</span>
          <span class="home-stats__label">exposiciones</span>
        </div>
      </div>
      <a href="/es/mapa/" class="home-teaser-link">Explorar mapa &rarr;</a>
    </div>
  </section>

  <!-- Section 9: PUBLICATIONS -->
  <section class="home-section fade-in">
    <div class="container">
      <div class="section__header">
        <h2>Publicaciones</h2>
        <span class="label">Catálogos</span>
      </div>
      <div class="home-publications">
        <a href="/es/biografia/" class="home-publications__book">
          <div class="home-publications__cover">
            <Image src={libroEncuentros} alt="Encuentros en la fábrica de polvo — Catálogo" loading="lazy" widths={[400, 800]} sizes="(max-width: 640px) 50vw, 33vw" />
          </div>
          <p class="home-publications__title">Encuentros en la fábrica de polvo</p>
          <p class="home-publications__year">2024</p>
        </a>
        <a href="/es/publicaciones/polvo-eres-libro/" class="home-publications__book">
          <div class="home-publications__cover">
            <Image src={libroPolvoEres} alt="Polvo Eres — Libro" loading="lazy" widths={[400, 800]} sizes="(max-width: 640px) 50vw, 33vw" />
          </div>
          <p class="home-publications__title">Polvo eres</p>
          <p class="home-publications__year">2014</p>
        </a>
        <a href="/es/publicaciones/coleccion-seguros-bolivar/" class="home-publications__book">
          <div class="home-publications__cover">
            <Image src={libroSeguros} alt="Colección Seguros Bolívar — Monografía" loading="lazy" widths={[400, 800]} sizes="(max-width: 640px) 50vw, 33vw" />
          </div>
          <p class="home-publications__title">Colección Seguros Bolívar</p>
          <p class="home-publications__year">2018</p>
        </a>
        <a href="/es/publicaciones/en-estado-de-coma-libro/" class="home-publications__book">
          <div class="home-publications__cover">
            <Image src={enEstadoDeComaLibro} alt="En estado de coma — Catálogo" loading="lazy" widths={[400, 800]} sizes="(max-width: 640px) 50vw, 33vw" />
          </div>
          <p class="home-publications__title">En estado de coma</p>
          <p class="home-publications__year">2007</p>
        </a>
      </div>
      <div class="home-section__cta">
        <a href="/es/publicaciones/" class="home-teaser-link">Ver publicaciones &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Section 10: BIOGRAPHY TEASER -->
  <section class="home-section home-section--alt fade-in">
    <div class="container">
      <div class="home-bio-teaser">
        <div class="home-bio-teaser__portrait">
          <Image src={retrato} alt="María Elvira Escallón &mdash; Retrato" loading="lazy" widths={[480, 900, 1400]} sizes="(max-width: 768px) 100vw, 1200px" />
        </div>
        <div class="home-bio-teaser__text">
          <p class="label">Biografía</p>
          <p class="curatorial home-bio-teaser__quote">
            Su obra se desarrolla en torno a temas como el tiempo, la memoria, la ruina y la vulnerabilidad de los monumentos.
          </p>
          <p class="home-bio-teaser__body">
            Nacida en Londres en 1954, Escallón ha desarrollado a lo largo de tres décadas un cuerpo de obra que interroga las fronteras entre lo natural y lo construido, la memoria y el olvido, el deterioro y la permanencia.
          </p>
          <a href="/es/biografia/" class="home-teaser-link">Leer biografía completa &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 11: CONTACT TEASER -->
  <section class="home-section home-section--contact fade-in">
    <div class="container">
      <p class="label">Representación</p>
      <p class="home-contact__gallery">Galería Espacio Continuo, Bogotá</p>
      <a href="/es/contacto/" class="home-teaser-link">Contactar &rarr;</a>
    </div>
  </section>

</Layout>

<style>
  /* ============================================
     Home — Long scroll immersive experience
     ============================================ */

  /* --- Hero image full bleed --- */
  .home-hero-image {
    width: 100%;
    position: relative;
    background: var(--ink);
  }

  .home-hero-image img {
    width: 100%;
    max-height: 85vh;
    object-fit: cover;
    display: block;
  }

  .home-hero-image__caption {
    position: absolute;
    bottom: var(--s2);
    right: var(--s3);
    font-family: var(--mono);
    font-size: 0.6rem;
    color: rgba(242, 237, 232, 0.6);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* --- Hero video background --- */
  .hero-video-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }

  /* velo oscuro muy leve para que el texto del hero respire */
  .hero-video-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.14);
    pointer-events: none;
  }

  .hero-video-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
    filter: grayscale(60%) contrast(1.1);
    mix-blend-mode: multiply;
  }

  /* --- Hero layout with image --- */
  .home-section--hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s4);
    border-bottom: 1px solid var(--ink);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s4);
    align-items: end;
    width: 100%;
  }

  .hero-image {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .hero-image img {
    width: 100%;
    max-height: 70vh;
    object-fit: contain;
    object-position: bottom right;
  }

  .hero-image__caption {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ash-light);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: var(--s1);
    text-align: right;
  }

  @media (max-width: 768px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: var(--s3);
    }

    .hero-image img {
      max-height: 50vh;
    }
  }

  /* --- Base section rhythm --- */
  .home-section {
    padding: var(--s6) 0;
    position: relative;
  }

  .home-section--alt {
    background-color: var(--paper-dark);
  }

  .home-section--quote {
    padding: var(--s6) 0;
  }

  .home-section--contact {
    padding: var(--s5) 0;
    text-align: center;
  }

  .home-section__cta {
    margin-top: var(--s4);
  }

  /* --- Scroll indicator --- */
  .home-scroll-indicator {
    position: absolute;
    bottom: var(--s3);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 1.4rem;
    color: var(--ash-light);
    animation: home-bounce 2s ease infinite;
  }

  @keyframes home-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* --- Featured work (hero image) --- */
  .home-featured {
    display: block;
    margin-top: var(--s3);
    text-decoration: none;
    color: inherit;
  }

  .home-featured img {
    width: 100%;
    max-height: 75vh;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .home-featured:hover img {
    opacity: 0.9;
  }

  .home-featured__caption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--s2) 0;
  }

  .home-featured__caption h3 {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .home-featured__caption .ficha {
    text-align: right;
  }

  /* --- Teaser links --- */
  .home-teaser-link {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 0.75rem 1.5rem;
    margin-top: var(--s3);
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .home-teaser-link:hover {
    background-color: var(--ink);
    color: var(--paper);
  }

  .home-teaser-link--light {
    color: var(--paper);
    border-color: var(--paper);
  }

  .home-teaser-link--light:hover {
    background-color: var(--paper);
    color: var(--ink);
  }

  /* --- Work cards (reused) --- */
  .work-card-static {
    cursor: pointer;
    border-bottom: 1px solid var(--paper-dark);
  }
  .work-card-static .work-card__thumb {
    width: 100%;
    background-color: var(--paper-dark);
    overflow: hidden;
  }
  .work-card-static .work-card__thumb img {
    transition: opacity 0.4s ease;
  }
  .work-card-static:hover .work-card__thumb img {
    opacity: 0.8;
  }
  .work-card-static .work-card__title {
    padding: var(--s2) 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .work-card-static .work-card__title h3 {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .work-card-static .work-card__title .year {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ash-light);
  }

  /* --- Exhibition highlight --- */
  .home-exhibition__image {
    display: block;
    margin-bottom: var(--s3);
  }

  .home-exhibition__image img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s;
  }

  .home-exhibition__image:hover img {
    opacity: 0.9;
  }

  .home-exhibition {
    max-width: var(--text-w);
  }

  .home-exhibition__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.15;
    margin-top: var(--s2);
    margin-bottom: var(--s2);
    text-transform: none;
    letter-spacing: -0.01em;
  }

  .home-exhibition__subtitle {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ash);
    letter-spacing: 0.05em;
    margin-bottom: var(--s3);
  }

  .home-exhibition__desc {
    margin-bottom: var(--s3);
    max-width: 50ch;
  }

  /* --- Timeline strip --- */
  .home-timeline-strip {
    background-color: var(--ink);
    color: var(--paper);
    padding: var(--s5) 0;
  }

  .home-timeline__entries {
    display: flex;
    gap: var(--s4);
    overflow-x: auto;
    padding: var(--s4) 0 var(--s3);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .home-timeline__entry {
    display: flex;
    flex-direction: column;
    gap: var(--s1);
    flex-shrink: 0;
    min-width: 100px;
  }

  .home-timeline__year {
    font-family: var(--mono);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--paper);
    letter-spacing: -0.02em;
  }

  .home-timeline__title {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--ash-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  /* --- Stats (map teaser) --- */
  .home-stats {
    display: flex;
    align-items: baseline;
    gap: var(--s3);
    margin: var(--s4) 0;
    flex-wrap: wrap;
  }


---
import Layout from '../../components/layout/Layout.astro';
import QuoteBlock from '../../components/content/QuoteBlock.astro';

const lang = 'fr' as const;

const featuredWorks = [
  {
    slug: 'in-vitro',
    title: 'IN VITRO',
    year: '1997',
    image: '/placeholder-in-vitro.jpg',
    hasImage: true,
    importedImage: (await import('../../assets/images/obras/in-vitro/in-vitro-01.webp')).default,
  },
  {
    slug: 'desde-adentro',
    title: 'DESDE ADENTRO',
    year: '2003',
    hasImage: true,
    importedImage: (await import('../../assets/images/obras/desde-adentro/desde-adentro-01.webp')).default,
  },
  {
    slug: 'nuevas-floras',
    title: 'NUEVAS FLORAS',
    year: '2003–2007',
    hasImage: true,
    importedImage: (await import('../../assets/images/obras/nuevas-floras/nuevas-floras-01.webp')).default,
  },
  {
    slug: 'en-estado-de-coma',
    title: 'EN ESTADO DE COMA',
    year: '2005–2007',
    hasImage: false,
  },
  {
    slug: 'aerolito',
    title: 'PEQUEÑO MUSEO DEL AEROLITO',
    year: '2014–2015',
    hasImage: false,
  },
  {
    slug: 'en-el-fertil-suelo',
    title: 'EN EL FÉRTIL SUELO',
    year: '2017–2018',
    hasImage: false,
  },
];
---

<Layout lang={lang} description="Page officielle de María Elvira Escallón. Artiste visuelle colombienne. Sculpture, installation, photographie et video.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <p class="hero__label">Artiste visuelle / Bogotá, Colombie</p>
      <h1 class="hero__name">María Elvira<br>Escallón</h1>
      <p class="hero__sub">Le questionnement des limites entre le naturel et le culturel</p>
      <p class="hero__meta">
        Née en 1954, Londres &mdash; Vit et travaille à Bogotá &nbsp;/&nbsp;
        Sculpture &middot; Installation &middot; Photographie &middot; Vidéo
      </p>
    </div>
  </section>

  <div class="container">

    <!-- Citation Jose Roca -->
    <QuoteBlock
      annotation="Texte curatorial"
      quote="Chaque œuvre suit sa propre voie, unique et précise. Il est cependant possible de trouver une constante dans l'œuvre de María Elvira Escallón : le questionnement des limites entre le naturel et le culturel."
      cite="José Roca — Columna de Arena 53, 2003"
    />

    <hr class="rule">

    <!-- Oeuvres -->
    <section class="section">
      <div class="section__header">
        <h2>Œuvres</h2>
        <span class="label">1997–2024</span>
      </div>

      <div class="works-grid">
        {featuredWorks.map((work) => (
          <a href={`/maria-elvira-escallon/en/works/${work.slug}/`} class="work-card-link" style="text-decoration:none; color:inherit;">
            <article class="work-card-static">
              <div class="work-card__thumb">
                {work.hasImage && work.importedImage ? (
                  <img
                    src={work.importedImage.src}
                    alt={`${work.title} — María Elvira Escallón`}
                    loading="lazy"
                    style="width:100%;height:100%;object-fit:cover;"
                  />
                ) : (
                  <div class="placeholder-img" style="height:100%;aspect-ratio:4/3;background:var(--paper-dark);display:flex;align-items:center;justify-content:center;color:var(--ash-light);font-family:var(--mono);font-size:0.55rem;letter-spacing:0.08em;text-transform:uppercase;">
                    [ {work.title} ]
                  </div>
                )}
              </div>
              <div class="work-card__title">
                <h3>{work.title}</h3>
                <span class="year">{work.year}</span>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>

    <hr class="rule">

    <!-- Seconde citation -->
    <QuoteBlock
      annotation="Sur l'artiste"
      quote="Son œuvre articule des processus sculpturaux, la photographie et le travail in situ, révélant un présent menacé par des échecs historiques, se positionnant entre l'histoire et la mémoire en établissant des seuils pour connecter des temps et des fragments de récits à travers des éléments de culture matérielle."
      cite="Colección Seguros Bolívar de Arte Contemporáneo, 2018"
    />

  </div>
</Layout>

<style>
  .work-card-static {
    cursor: pointer;
    border-bottom: 1px solid var(--paper-dark);
  }
  .work-card-static .work-card__thumb {
    width: 100%;
    aspect-ratio: 4/3;
    background-color: var(--paper-dark);
    overflow: hidden;
  }
  .work-card-static .work-card__thumb img {
    transition: opacity 0.4s ease;
  }
  .work-card-static:hover .work-card__thumb img {
    opacity: 0.8;
  }
  .work-card-static .work-card__title {
    padding: var(--s2) 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .work-card-static .work-card__title h3 {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .work-card-static .work-card__title .year {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ash-light);
  }
</style>

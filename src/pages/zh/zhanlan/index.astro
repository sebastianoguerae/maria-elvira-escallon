---

<Layout lang={lang} title="展览" description="玛丽亚·埃尔维拉·埃斯卡隆完整展览历史：个展与国际群展，1997–2024。波哥大、巴黎、伦敦、哈瓦那、纽约。">

  <div class="expo-index">
    <div class="container">

      <!-- 页面标题 -->
      <header class="section__header">
        <h1>展览</h1>
        <span class="label">1997–2024</span>
      </header>

      <!-- -- 个展 -- -->
      <section class="expo-section">
        <h3 class="expo-section__title">个展</h3>
        <div class="expo-list">
          {solo.map((e) => (
            <div class="expo-entry">
              <div class="expo-entry__year">{e.year}</div>
              <div class="expo-entry__info">
                {e.slug ? (
                  <a href={`/maria-elvira-escallon/es/exposiciones/${e.slug}/`} class="expo-entry__link">
                    <strong>{e.title}</strong>
                  </a>
                ) : (
                  <strong>{e.title}</strong>
                )}
                {e.note && <span class="expo-entry__note"> ({e.note})</span>}
                <span class="expo-entry__venue">
                  {e.venue ? `${e.venue}, ${e.city}` : e.city}
                </span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <hr class="rule rule--light" />

      <!-- -- 国际群展 -- -->
      <section class="expo-section">
        <h3 class="expo-section__title">国际群展</h3>
        <div class="expo-list">
          {group.map((e) => (
            <div class="expo-entry">
              <div class="expo-entry__year">{e.year}</div>
              <div class="expo-entry__info">
                {e.slug ? (
                  <a href={`/maria-elvira-escallon/es/exposiciones/${e.slug}/`} class="expo-entry__link">
                    <strong>{e.title}</strong>
                  </a>
                ) : (
                  <strong>{e.title}</strong>
                )}
                {e.note && <span class="expo-entry__note"> ({e.note})</span>}
                <span class="expo-entry__venue">
                  {e.venue ? `${e.venue}, ${e.city}` : e.city}
                </span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- -- 页脚说明 -- -->
      <div class="expo-footnote">
        <p>完整列表请参阅艺术家简历，可在<a href="https://www.espaciocontinuo.com" target="_blank" rel="noopener noreferrer">Galería Espacio Continuo</a>获取。</p>
      </div>

    </div>
  </div>

</Layout>

<style>
  /* -- Page wrapper -- */
  .expo-index {
    padding-top: calc(var(--s5) + 40px);
    padding-bottom: var(--s5);
  }

  /* -- Section titles -- */
  .expo-section {
    margin-top: var(--s4);
  }

  .expo-section__title {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ash);
    padding-bottom: var(--s2);
    border-bottom: 1px solid var(--ink);
    margin-bottom: 0;
  }

  /* -- Entry grid -- */
  .expo-list {
    margin: 0;
  }

  .expo-entry {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--s3);
    padding: var(--s2) 0;
    border-bottom: 1px solid var(--paper-dark);
    align-items: baseline;
  }

  .expo-entry:last-child {
    border-bottom: 1px solid var(--ash-light);
  }

  .expo-entry__year {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ash-light);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .expo-entry__info {
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--ink);
  }

  .expo-entry__info strong {
    font-weight: 700;
    font-size: 0.8rem;
  }

  .expo-entry__note {
    font-size: 0.7rem;
    color: var(--ash);
    font-style: italic;
  }

  .expo-entry__venue {
    display: block;
    font-size: 0.7rem;
    color: var(--ash);
    margin-top: 2px;
    line-height: 1.5;
  }

  /* -- Links -- */
  .expo-entry__link {
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--ash-light);
    padding-bottom: 1px;
    transition: border-color 0.2s, color 0.2s;
  }

  .expo-entry__link:hover {
    border-bottom-color: var(--ink);
  }

  .expo-entry__link strong {
    font-weight: 700;
  }

  /* -- Footnote -- */
  .expo-footnote {
    margin-top: var(--s5);
    padding-top: var(--s3);
    border-top: 1px dashed var(--ash-light);
  }

  .expo-footnote p {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--ash);
    letter-spacing: 0.04em;
    line-height: 1.8;
    max-width: var(--text-w);
  }

  .expo-footnote a {
    color: var(--ash);
    border-bottom: 1px solid var(--ash-light);
    transition: color 0.2s, border-color 0.2s;
  }

  .expo-footnote a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* -- Responsive -- */
  @media (max-width: 768px) {
    .expo-entry {
      grid-template-columns: 56px 1fr;
      gap: var(--s2);
      padding: var(--s1) 0;
    }

    .expo-entry__year {
      font-size: 0.7rem;
    }

    .expo-entry__info {
      font-size: 0.75rem;
    }

    .expo-entry__info strong {
      font-size: 0.75rem;
    }

    .expo-entry__venue {
      font-size: 0.65rem;
    }

    .expo-section__title {
      font-size: 0.65rem;
    }
  }
</style>

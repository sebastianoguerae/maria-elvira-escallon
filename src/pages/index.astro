---
// Instant redirect to ES (canonical language). Static build emits this page at the site root.
const base = import.meta.env.BASE_URL?.replace(/\/$/, '') || '';
const target = `${base}/es/`;
const targetAbs = new URL(target, Astro.site).href;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>María Elvira Escallón</title>
  <meta name="robots" content="noindex">
  <link rel="canonical" href={targetAbs}>
  <meta http-equiv="refresh" content={`0;url=${target}`}>
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</head>
<body>
  <p><a href={target}>María Elvira Escallón</a></p>
</body>
</html>
